/* custom-tab-bar/index.wxss */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  display: flex;
  background: #FFFFFF;
  border-top: 1rpx solid #E0E0E0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999;
}

.tab-bar.theme-dark {
  background: #1C1C1E;
  border-top: 1rpx solid #333333;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
}

.tab-icon {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #666666;
}

.tab-bar.theme-dark .tab-text {
  color: #AAAAAA;
}

.tab-text.selected {
  color: #FF9800;
  font-weight: bold;
}

.tab-bar.theme-dark .tab-text.selected {
  color: #FF9800;
}

/* 童趣模式 (Girl Style) */
.tab-bar.style-girl {
  background: linear-gradient(180deg, #FFC0CB 0%, #FFB6C1 50%, #FF69B4 100%) !important;
  border-top: 3rpx solid rgba(255, 255, 255, 0.6) !important;
  box-shadow: 0 -4rpx 20rpx rgba(255, 182, 193, 0.5) !important;
}

.tab-bar.style-girl.theme-dark {
  background: linear-gradient(180deg, #FFB6C1 0%, #FF69B4 50%, #C2185B 100%) !important;
  border-top: 3rpx solid rgba(255, 255, 255, 0.4) !important;
}

.tab-bar.style-girl .tab-icon {
  filter: drop-shadow(1rpx 1rpx 3rpx rgba(194, 24, 91, 0.3));
}

.tab-bar.style-girl .tab-text {
  color: #C2185B !important;
  font-weight: 600;
  text-shadow: 1rpx 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

.tab-bar.style-girl .tab-text.selected {
  color: #C2185B !important;
  font-weight: 900;
  font-size: 24rpx;
  text-shadow:
    1rpx 1rpx 2rpx rgba(255, 255, 255, 0.9),
    0 0 8rpx rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.5) !important;
  backdrop-filter: blur(10rpx) !important;
  -webkit-backdrop-filter: blur(10rpx) !important;
  padding: 8rpx 18rpx;
  border-radius: 25rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.7) !important;
  box-shadow:
    inset -3rpx -3rpx 10rpx rgba(255, 255, 255, 0.6),
    inset 3rpx 3rpx 10rpx rgba(255, 182, 193, 0.3),
    0 4rpx 12rpx rgba(255, 105, 180, 0.25),
    0 8rpx 20rpx rgba(255, 182, 193, 0.2);
}

.tab-bar.style-girl.theme-dark .tab-text {
  color: rgba(255, 255, 255, 0.9) !important;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.tab-bar.style-girl.theme-dark .tab-text.selected {
  color: #FFFFFF !important;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.4);
}

