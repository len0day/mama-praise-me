<!--custom-tab-bar/index.wxml-->
<view class="tab-bar {{themeClass}} {{isFunTheme ? 'style-girl' : ''}} color-tone-{{colorTone}}">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-bar-item"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab">
    <view class="tab-icon">{{selected === index ? item.selectedIcon : item.icon}}</view>
    <view class="tab-text {{selected === index ? 'selected' : ''}}">{{item.text}}</view>
  </view>
</view>
