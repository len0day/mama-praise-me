/* app.wxss - 全局样式 */
page {
  background: #FFF8E1;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

/* 深色主题下的page背景 - 使用更强的选择器 */
page[class="theme-dark"] {
  background: #1C1C1E !important;
}

/* 深色主题容器背景 - 使用更强的选择器 */
view.theme-dark {
  background: #1C1C1E !important;
}

/* 童趣模式 - 女孩色调（默认粉色） */
.style-girl.color-tone-girl {
  --primary-color: #FF69B4;
  --secondary-color: #FFB6C1;
  --accent-color: #C2185B;
  --bg-gradient: linear-gradient(180deg, #FFC0CB 0%, #FFB6C1 50%, #FF69B4 100%);
  --card-bg: rgba(255, 255, 255, 0.6);
  --card-border: rgba(255, 255, 255, 0.9);
}

/* 童趣模式 - 男孩色调（硬朗蓝色） */
.style-girl.color-tone-boy {
  --primary-color: #1976D2;
  --secondary-color: #64B5F6;
  --accent-color: #0D47A1;
  --bg-gradient: linear-gradient(180deg, #64B5F6 0%, #42A5F5 50%, #1976D2 100%);
  --card-bg: rgba(255, 255, 255, 0.6);
  --card-border: rgba(255, 255, 255, 0.9);
}

.style-girl.color-tone-boy.container:not(.theme-dark) {
  background: #E3F2FD !important;
}

.style-girl.color-tone-boy .tab-bar {
  background: linear-gradient(180deg, #64B5F6 0%, #42A5F5 50%, #1976D2 100%) !important;
}

.style-girl.color-tone-boy .tab-text {
  color: #0D47A1 !important;
  text-shadow: 1rpx 1rpx 2rpx rgba(255, 255, 255, 0.8) !important;
}

.style-girl.color-tone-boy .tab-text.selected {
  color: #FFFFFF !important;
  background: rgba(255, 255, 255, 0.5) !important;
  backdrop-filter: blur(10rpx) !important;
  -webkit-backdrop-filter: blur(10rpx) !important;
  text-shadow: 1rpx 1rpx 2rpx rgba(13, 71, 161, 0.5) !important;
}

.style-girl.color-tone-boy .task-item {
  background: linear-gradient(135deg, rgba(227, 242, 253, 0.7), rgba(187, 222, 251, 0.8)) !important;
  color: #0D47A1 !important;
  box-shadow:
    inset -8rpx -8rpx 20rpx rgba(25, 118, 210, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(66, 165, 245, 0.3) !important;
}

.style-girl.color-tone-boy .section-title {
  color: #0D47A1 !important;
}

/* 童趣模式 - 中性色调（灰色系） */
.style-girl.color-tone-neutral {
  --primary-color: #757575;
  --secondary-color: #BDBDBD;
  --accent-color: #424242;
  --bg-gradient: linear-gradient(180deg, #E0E0E0 0%, #BDBDBD 50%, #9E9E9E 100%);
  --card-bg: rgba(255, 255, 255, 0.6);
  --card-border: rgba(255, 255, 255, 0.9);
}

.style-girl.color-tone-neutral.container:not(.theme-dark) {
  background: #F5F5F5 !important;
}

.style-girl.color-tone-neutral .tab-bar {
  background: linear-gradient(180deg, #E0E0E0 0%, #BDBDBD 50%, #9E9E9E 100%) !important;
}

.style-girl.color-tone-neutral .tab-text {
  color: #424242 !important;
  text-shadow: 1rpx 1rpx 2rpx rgba(255, 255, 255, 0.8) !important;
}

.style-girl.color-tone-neutral .tab-text.selected {
  color: #424242 !important;
  background: rgba(255, 255, 255, 0.5) !important;
  backdrop-filter: blur(10rpx) !important;
  -webkit-backdrop-filter: blur(10rpx) !important;
  text-shadow: 1rpx 1rpx 2rpx rgba(66, 66, 66, 0.5) !important;
}

.style-girl.color-tone-neutral .task-item {
  background: linear-gradient(135deg, rgba(245, 245, 245, 0.7), rgba(235, 235, 235, 0.8)) !important;
  color: #424242 !important;
  box-shadow:
    inset -8rpx -8rpx 20rpx rgba(117, 117, 117, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(189, 189, 189, 0.3) !important;
}

.style-girl.color-tone-neutral .section-title {
  color: #424242 !important;
}

/* 童趣模式 - 可爱色调（橙黄色系） */
.style-girl.color-tone-cute {
  --primary-color: #FFA726;
  --secondary-color: #FFD54F;
  --accent-color: #F57C00;
  --bg-gradient: linear-gradient(180deg, #FFD54F 0%, #FFCA28 50%, #FFA726 100%);
  --card-bg: rgba(255, 255, 255, 0.6);
  --card-border: rgba(255, 255, 255, 0.9);
}

.style-girl.color-tone-cute.container:not(.theme-dark) {
  background: #FFF8E1 !important;
}

.style-girl.color-tone-cute .tab-bar {
  background: linear-gradient(180deg, #FFD54F 0%, #FFCA28 50%, #FFA726 100%) !important;
}

.style-girl.color-tone-cute .tab-text {
  color: #E65100 !important;
  text-shadow: 1rpx 1rpx 2rpx rgba(255, 255, 255, 0.8) !important;
}

.style-girl.color-tone-cute .tab-text.selected {
  color: #E65100 !important;
  background: rgba(255, 255, 255, 0.5) !important;
  backdrop-filter: blur(10rpx) !important;
  -webkit-backdrop-filter: blur(10rpx) !important;
  text-shadow: 1rpx 1rpx 2rpx rgba(230, 81, 0, 0.5) !important;
}

.style-girl.color-tone-cute .task-item {
  background: linear-gradient(135deg, rgba(255, 248, 225, 0.7), rgba(255, 236, 179, 0.8)) !important;
  color: #E65100 !important;
  box-shadow:
    inset -8rpx -8rpx 20rpx rgba(255, 167, 38, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(255, 202, 40, 0.3) !important;
}

.style-girl.color-tone-cute .section-title {
  color: #E65100 !important;
}

/* ==================== 男孩色调样式 ==================== */

.style-girl.color-tone-boy .family-card {
  background: rgba(227, 242, 253, 0.6) !important;
  border-color: rgba(255, 255, 255, 0.9) !important;
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(25, 118, 210, 0.3),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(66, 165, 245, 0.2) !important;
}

.style-girl.color-tone-boy .family-name {
  color: #0D47A1 !important;
}

.style-girl.color-tone-boy .stat-tag {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB) !important;
  color: #1976D2 !important;
}

.style-girl.color-tone-boy .add-btn {
  background: linear-gradient(135deg, rgba(25, 118, 210, 0.9), rgba(66, 165, 245, 0.9)) !important;
  box-shadow:
    inset -6rpx -6rpx 15rpx rgba(255, 255, 255, 0.5),
    inset 6rpx 6rpx 15rpx rgba(13, 71, 161, 0.2),
    0 10rpx 25rpx rgba(25, 118, 210, 0.4),
    0 15rpx 35rpx rgba(66, 165, 245, 0.3) !important;
}

/* ==================== 中性色调样式 ==================== */

.style-girl.color-tone-neutral .family-card {
  background: rgba(245, 245, 245, 0.6) !important;
  border-color: rgba(255, 255, 255, 0.9) !important;
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(117, 117, 117, 0.3),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(189, 189, 189, 0.2) !important;
}

.style-girl.color-tone-neutral .family-name {
  color: #424242 !important;
}

.style-girl.color-tone-neutral .stat-tag {
  background: linear-gradient(135deg, #F5F5F5, #E0E0E0) !important;
  color: #616161 !important;
}

.style-girl.color-tone-neutral .add-btn {
  background: linear-gradient(135deg, rgba(117, 117, 117, 0.9), rgba(189, 189, 189, 0.9)) !important;
  box-shadow:
    inset -6rpx -6rpx 15rpx rgba(255, 255, 255, 0.5),
    inset 6rpx 6rpx 15rpx rgba(66, 66, 66, 0.2),
    0 10rpx 25rpx rgba(117, 117, 117, 0.4),
    0 15rpx 35rpx rgba(189, 189, 189, 0.3) !important;
}

/* ==================== 可爱色调样式 ==================== */

.style-girl.color-tone-cute .family-card {
  background: rgba(255, 248, 225, 0.6) !important;
  border-color: rgba(255, 255, 255, 0.9) !important;
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(255, 167, 38, 0.3),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(255, 202, 40, 0.2) !important;
}

.style-girl.color-tone-cute .family-name {
  color: #E65100 !important;
}

.style-girl.color-tone-cute .stat-tag {
  background: linear-gradient(135deg, #FFF8E1, #FFECB3) !important;
  color: #F57C00 !important;
}

.style-girl.color-tone-cute .add-btn {
  background: linear-gradient(135deg, rgba(255, 167, 38, 0.9), rgba(255, 202, 40, 0.9)) !important;
  box-shadow:
    inset -6rpx -6rpx 15rpx rgba(255, 255, 255, 0.5),
    inset 6rpx 6rpx 15rpx rgba(230, 81, 0, 0.2),
    0 10rpx 25rpx rgba(255, 167, 38, 0.4),
    0 15rpx 35rpx rgba(255, 202, 40, 0.3) !important;
}

/* ==================== 任务卡片色调样式 ==================== */

/* 男孩色调 - 任务卡片 */
.style-girl.color-tone-boy .task-item.daily {
  background: linear-gradient(135deg, rgba(227, 242, 253, 0.7), rgba(187, 222, 251, 0.8)) !important;
  box-shadow:
    inset -8rpx -8rpx 20rpx rgba(25, 118, 210, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(66, 165, 245, 0.3) !important;
}

.style-girl.color-tone-boy .task-item.weekly {
  background: linear-gradient(135deg, rgba(232, 245, 253, 0.7), rgba(207, 232, 252, 0.8)) !important;
  box-shadow:
    inset -8rpx -8rpx 20rpx rgba(13, 71, 161, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(100, 181, 246, 0.3) !important;
}

/* 中性色调 - 任务卡片 */
.style-girl.color-tone-neutral .task-item.daily {
  background: linear-gradient(135deg, rgba(245, 245, 245, 0.7), rgba(235, 235, 235, 0.8)) !important;
  box-shadow:
    inset -8rpx -8rpx 20rpx rgba(117, 117, 117, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(189, 189, 189, 0.3) !important;
}

.style-girl.color-tone-neutral .task-item.weekly {
  background: linear-gradient(135deg, rgba(250, 250, 250, 0.7), rgba(240, 240, 240, 0.8)) !important;
  box-shadow:
    inset -8rpx -8rpx 20rpx rgba(97, 97, 97, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(158, 158, 158, 0.3) !important;
}

/* 可爱色调 - 任务卡片 */
.style-girl.color-tone-cute .task-item.daily {
  background: linear-gradient(135deg, rgba(255, 248, 225, 0.7), rgba(255, 236, 179, 0.8)) !important;
  box-shadow:
    inset -8rpx -8rpx 20rpx rgba(255, 167, 38, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(255, 202, 40, 0.3) !important;
}

.style-girl.color-tone-cute .task-item.weekly {
  background: linear-gradient(135deg, rgba(255, 253, 231, 0.7), rgba(255, 248, 197, 0.8)) !important;
  box-shadow:
    inset -8rpx -8rpx 20rpx rgba(245, 124, 0, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(255, 193, 7, 0.3) !important;
}

/* ==================== 自定义导航栏色调样式 ==================== */

/* 男孩色调导航栏 */
.style-girl.color-tone-boy .custom-navbar {
  background: linear-gradient(180deg, #64B5F6 0%, #42A5F5 50%, #1976D2 100%) !important;
  border-bottom: 3rpx solid rgba(255, 255, 255, 0.6) !important;
}

.style-girl.color-tone-boy .navbar-title {
  color: #FFFFFF !important;
  font-weight: 900 !important;
  text-shadow: 2rpx 2rpx 4rpx rgba(13, 71, 161, 0.3) !important;
}

/* 中性色调导航栏 */
.style-girl.color-tone-neutral .custom-navbar {
  background: linear-gradient(180deg, #E0E0E0 0%, #BDBDBD 50%, #9E9E9E 100%) !important;
  border-bottom: 3rpx solid rgba(255, 255, 255, 0.6) !important;
}

.style-girl.color-tone-neutral .navbar-title {
  color: #424242 !important;
  font-weight: 900 !important;
  text-shadow: 1rpx 1rpx 2rpx rgba(255, 255, 255, 0.8) !important;
}

/* 可爱色调导航栏 */
.style-girl.color-tone-cute .custom-navbar {
  background: linear-gradient(180deg, #FFD54F 0%, #FFCA28 50%, #FFA726 100%) !important;
  border-bottom: 3rpx solid rgba(255, 255, 255, 0.6) !important;
}

.style-girl.color-tone-cute .navbar-title {
  color: #FFFFFF !important;
  font-weight: 900 !important;
  text-shadow: 2rpx 2rpx 4rpx rgba(230, 81, 0, 0.3) !important;
}

/* ==================== 设置页面色调样式 ==================== */

/* 男孩色调设置卡片 */
.style-girl.color-tone-boy .setting-item {
  background: rgba(227, 242, 253, 0.7) !important;
  border: 3rpx solid rgba(255, 255, 255, 0.8) !important;
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(25, 118, 210, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(66, 165, 245, 0.2) !important;
}

.style-girl.color-tone-boy .style-option.active {
  background: linear-gradient(135deg, #1976D2, #42A5F5) !important;
  color: #FFFFFF !important;
}

/* 中性色调设置卡片 */
.style-girl.color-tone-neutral .setting-item {
  background: rgba(245, 245, 245, 0.7) !important;
  border: 3rpx solid rgba(255, 255, 255, 0.8) !important;
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(117, 117, 117, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(189, 189, 189, 0.2) !important;
}

.style-girl.color-tone-neutral .style-option.active {
  background: linear-gradient(135deg, #757575, #9E9E9E) !important;
  color: #FFFFFF !important;
}

/* 可爱色调设置卡片 */
.style-girl.color-tone-cute .setting-item {
  background: rgba(255, 248, 225, 0.7) !important;
  border: 3rpx solid rgba(255, 255, 255, 0.8) !important;
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(255, 167, 38, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(255, 202, 40, 0.2) !important;
}

.style-girl.color-tone-cute .style-option.active {
  background: linear-gradient(135deg, #FFA726, #FFCA28) !important;
  color: #FFFFFF !important;
}

/* ==================== 文字颜色色调样式 ==================== */

/* 男孩色调文字颜色 */
.style-girl.color-tone-boy .item-label {
  color: #0D47A1 !important;
}

.style-girl.color-tone-boy .task-title,
.style-girl.color-tone-boy .task-description {
  color: #0D47A1 !important;
}

.style-girl.color-tone-boy .coin-bubble {
  background: linear-gradient(135deg, #1976D2, #42A5F5) !important;
  color: #FFFFFF !important;
}

/* 中性色调文字颜色 */
.style-girl.color-tone-neutral .item-label {
  color: #424242 !important;
}

.style-girl.color-tone-neutral .task-title,
.style-girl.color-tone-neutral .task-description {
  color: #424242 !important;
}

.style-girl.color-tone-neutral .coin-bubble {
  background: linear-gradient(135deg, #757575, #9E9E9E) !important;
  color: #FFFFFF !important;
}

/* 可爱色调文字颜色 */
.style-girl.color-tone-cute .item-label {
  color: #E65100 !important;
}

.style-girl.color-tone-cute .task-title,
.style-girl.color-tone-cute .task-description {
  color: #E65100 !important;
}

.style-girl.color-tone-cute .coin-bubble {
  background: linear-gradient(135deg, #FFA726, #FFCA28) !important;
  color: #FFFFFF !important;
}

/* ==================== 按钮色调样式 ==================== */

/* 男孩色调按钮 */
.style-girl.color-tone-boy .primary-btn,
.style-girl.color-tone-boy .action-btn.primary {
  background: linear-gradient(135deg, #1976D2, #42A5F5) !important;
  box-shadow:
    inset -4rpx -4rpx 10rpx rgba(255, 255, 255, 0.4),
    inset 4rpx 4rpx 10rpx rgba(13, 71, 161, 0.2),
    0 8rpx 20rpx rgba(25, 118, 210, 0.3) !important;
}

/* 中性色调按钮 */
.style-girl.color-tone-neutral .primary-btn,
.style-girl.color-tone-neutral .action-btn.primary {
  background: linear-gradient(135deg, #757575, #9E9E9E) !important;
  box-shadow:
    inset -4rpx -4rpx 10rpx rgba(255, 255, 255, 0.4),
    inset 4rpx 4rpx 10rpx rgba(66, 66, 66, 0.2),
    0 8rpx 20rpx rgba(117, 117, 117, 0.3) !important;
}

/* 可爱色调按钮 */
.style-girl.color-tone-cute .primary-btn,
.style-girl.color-tone-cute .action-btn.primary {
  background: linear-gradient(135deg, #FFA726, #FFCA28) !important;
  box-shadow:
    inset -4rpx -4rpx 10rpx rgba(255, 255, 255, 0.4),
    inset 4rpx 4rpx 10rpx rgba(230, 81, 0, 0.2),
    0 8rpx 20rpx rgba(255, 167, 38, 0.3) !important;
}

/* ==================== 首页容器背景色调样式 ==================== */

.style-girl.color-tone-boy .tasks-container {
  background: #E3F2FD !important;
}

.style-girl.color-tone-boy .task-item {
  background: linear-gradient(135deg, rgba(227, 242, 253, 0.7), rgba(187, 222, 251, 0.8)) !important;
  color: #0D47A1 !important;
}

.style-girl.color-tone-neutral .tasks-container {
  background: #F5F5F5 !important;
}

.style-girl.color-tone-neutral .task-item {
  background: linear-gradient(135deg, rgba(245, 245, 245, 0.7), rgba(235, 235, 235, 0.8)) !important;
  color: #424242 !important;
}

.style-girl.color-tone-cute .tasks-container {
  background: #FFF8E1 !important;
}

.style-girl.color-tone-cute .task-item {
  background: linear-gradient(135deg, rgba(255, 248, 225, 0.7), rgba(255, 236, 179, 0.8)) !important;
  color: #E65100 !important;
}

/* ==================== 弹窗色调样式 ==================== */

/* 男孩色调弹窗 */
.style-girl.color-tone-boy .modal-content {
  background: rgba(227, 242, 253, 0.95) !important;
  border-color: rgba(255, 255, 255, 0.9) !important;
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(25, 118, 210, 0.3),
    0 20rpx 50rpx rgba(66, 165, 245, 0.4) !important;
}

.style-girl.color-tone-boy .modal-title {
  color: #0D47A1 !important;
}

/* 中性色调弹窗 */
.style-girl.color-tone-neutral .modal-content {
  background: rgba(245, 245, 245, 0.95) !important;
  border-color: rgba(255, 255, 255, 0.9) !important;
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(117, 117, 117, 0.3),
    0 20rpx 50rpx rgba(189, 189, 189, 0.4) !important;
}

.style-girl.color-tone-neutral .modal-title {
  color: #424242 !important;
}

/* 可爱色调弹窗 */
.style-girl.color-tone-cute .modal-content {
  background: rgba(255, 248, 225, 0.95) !important;
  border-color: rgba(255, 255, 255, 0.9) !important;
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(255, 167, 38, 0.3),
    0 20rpx 50rpx rgba(255, 202, 40, 0.4) !important;
}

.style-girl.color-tone-cute .modal-title {
  color: #E65100 !important;
}

/* ==================== 确保 colorTone 在非 style-girl 时也能工作 ==================== */

/* 当 themeStyle 不是 girl 时，colorTone 不生效，但我们需要确保基础样式正确 */
.color-tone-boy .tasks-container {
  background: #E3F2FD !important;
}

.color-tone-neutral .tasks-container {
  background: #F5F5F5 !important;
}

.color-tone-cute .tasks-container {
  background: #FFF8E1 !important;
}

/* ==================== 强制覆盖页面容器背景色 ==================== */

/* 男孩色调 - 强制覆盖，但不覆盖深色主题 */
.style-girl.color-tone-boy:not(.theme-dark) .container,
page.style-girl.color-tone-boy:not(.theme-dark) .container {
  background: #E3F2FD !important;
}

/* 中性色调 - 强制覆盖，但不覆盖深色主题 */
.style-girl.color-tone-neutral:not(.theme-dark) .container,
page.style-girl.color-tone-neutral:not(.theme-dark) .container {
  background: #F5F5F5 !important;
}

/* 可爱色调 - 强制覆盖，但不覆盖深色主题 */
.style-girl.color-tone-cute:not(.theme-dark) .container,
page.style-girl.color-tone-cute:not(.theme-dark) .container {
  background: #FFF8E1 !important;
}

/* ==================== 完整的按钮色调样式 ==================== */

/* 男孩色调 - 所有按钮 */
.style-girl.color-tone-boy button,
.style-girl.color-tone-boy .btn,
.style-girl.color-tone-boy button.primary,
