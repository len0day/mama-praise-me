/* 确保色调选择器在童趣模式下有正确的样式 */
.style-girl .color-tone-selector {
  display: flex;
  gap: 12rpx;
  padding: 5rpx;
}

.style-girl .color-tone-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.7) !important;
  border-radius: 20rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.8) !important;
  transition: all 0.3s;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  box-shadow:
    inset -4rpx -4rpx 12rpx rgba(255, 182, 193, 0.25),
    inset 4rpx 4rpx 12rpx rgba(255, 255, 255, 0.7),
    0 6rpx 16rpx rgba(255, 105, 180, 0.2);
}

.style-girl .color-tone-option.active {
  background: rgba(255, 255, 255, 0.9) !important;
  border-color: #FF69B4 !important;
  border-width: 4rpx !important;
  box-shadow:
    inset -4rpx -4rpx 12rpx rgba(255, 182, 193, 0.35),
    inset 4rpx 4rpx 12rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(255, 20, 147, 0.4) !important;
  transform: scale(1.08);
}

.style-girl .tone-preview {
  width: 55rpx;
  height: 55rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.95) !important;
  box-shadow:
    inset -3rpx -3rpx 8rpx rgba(0, 0, 0, 0.15),
    inset 3rpx 3rpx 8rpx rgba(255, 255, 255, 0.6),
    0 4rpx 10rpx rgba(0, 0, 0, 0.2);
}

.style-girl .tone-label {
  font-size: 24rpx;
  color: #C2185B !important;
  font-weight: 700;
  text-shadow: 1rpx 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

.style-girl .color-tone-option.active .tone-label {
