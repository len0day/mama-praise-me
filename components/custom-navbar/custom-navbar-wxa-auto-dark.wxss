@media (prefers-color-scheme: dark) {
    .navbar-back, .navbar-home, .navbar-settings {
        color: rgb(17, 17, 17);
    }

    .navbar-title {
        color: rgb(17, 17, 17);
    }

    .theme-light .navbar-title {
        color: rgb(17, 17, 17);
    }

    .theme-dark .navbar-title {
        color: rgb(17, 17, 17);
    }
}
