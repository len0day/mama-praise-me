<!--components/parent-password-modal/parent-password-modal.wxml-->
<view class="modal" wx:if="{{show}}">
  <view class="modal-mask" bindtap="onCancel"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">{{isFirstTime ? '设置家长密码' : '家长验证'}}</text>
    </view>

    <view class="modal-body">
      <view class="tips" wx:if="{{isFirstTime}}">
        <text>首次使用，请设置家长密码（至少4位）</text>
      </view>
      <view class="tips" wx:else>
        <text>进入家长模式需要验证身份</text>
      </view>

      <view class="password-input-wrapper">
        <input
          class="password-input"
          type="{{showPassword ? 'text' : 'password'}}"
          value="{{password}}"
          bindinput="onPasswordInput"
          placeholder="{{isFirstTime ? '设置新密码' : '请输入家长密码'}}"
          maxlength="20"
          confirm-type="done"
          bindconfirm="onConfirm" />
        <view class="password-toggle" bindtap="togglePasswordVisibility">
          {{showPassword ? '👁️' : '👁️‍🗨️'}}
        </view>
      </view>
    </view>

    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="onCancel">取消</button>
      <button class="modal-btn confirm" bindtap="onConfirm">确认</button>
    </view>
  </view>
</view>
