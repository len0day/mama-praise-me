<!--components/parent-password-modal/parent-password-modal.wxml-->
<view class="modal" wx:if="{{show}}">
  <view class="modal-mask" bindtap="onCancel"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">
        {{isFirstTime && step === 1 ? '设置家长密码' : ''}}
        {{isFirstTime && step === 2 ? '确认家长密码' : ''}}
        {{!isFirstTime ? '家长验证' : ''}}
      </text>
    </view>

    <view class="modal-body">
      <view class="tips" wx:if="{{isFirstTime && step === 1}}">
        <text>首次使用，请设置家长密码（至少4位）</text>
      </view>
      <view class="tips" wx:elif="{{isFirstTime && step === 2}}">
        <text>请再次输入密码以确认</text>
      </view>
      <view class="tips" wx:else>
        <text>进入家长模式需要验证身份</text>
      </view>

      <!-- 第一步：输入密码 -->
      <view class="password-input-wrapper" wx:if="{{step === 1}}">
        <input
          class="password-input"
          type="{{showPassword ? 'text' : 'password'}}"
          password="{{!showPassword}}"
          value="{{password}}"
          bindinput="onPasswordInput"
          placeholder="{{isFirstTime ? '设置新密码' : '请输入家长密码'}}"
          maxlength="20"
          confirm-type="{{isFirstTime ? 'next' : 'done'}}"
          bindconfirm="onConfirm"
          focus="{{show}}" />
        <view class="password-toggle" bindtap="togglePasswordVisibility">
          {{showPassword ? '👁️' : '👁️‍🗨️'}}
        </view>
      </view>

      <!-- 第二步：确认密码（仅首次设置时） -->
      <view class="password-input-wrapper" wx:if="{{isFirstTime && step === 2}}">
        <input
          class="password-input"
          type="{{showConfirmPassword ? 'text' : 'password'}}"
          password="{{!showConfirmPassword}}"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
          placeholder="请再次输入密码"
          maxlength="20"
          confirm-type="done"
          bindconfirm="onConfirm"
          focus="{{true}}" />
        <view class="password-toggle" bindtap="toggleConfirmPasswordVisibility">
          {{showConfirmPassword ? '👁️' : '👁️‍🗨️'}}
        </view>
      </view>
    </view>

    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="onCancel">取消</button>
      <button class="modal-btn confirm" bindtap="onConfirm">
        {{isFirstTime && step === 1 ? '下一步' : '确认'}}
      </button>
    </view>
  </view>
</view>
