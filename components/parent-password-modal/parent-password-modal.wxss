/* components/parent-password-modal/parent-password-modal.wxss */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 40rpx;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  max-width: 550rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
}

.theme-dark .modal-content {
  background: #2C2C2E;
}

.modal-header {
  padding: 30rpx;
  text-align: center;
  border-bottom: 2rpx solid #E5E5E5;
}

.theme-dark .modal-header {
  border-bottom-color: #3A3A3C;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .modal-title {
  color: #FFFFFF;
}

.modal-body {
  padding: 40rpx 30rpx;
}

.tips {
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

.theme-dark .tips {
  color: #AAAAAA;
}

.password-input-wrapper {
  margin-top: 20rpx;
  position: relative;
}

.password-input {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx 70rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  font-size: 30rpx;
  background: #FAFAFA;
  color: #1A1A1A;
  text-align: center;
  height: 100rpx;
  line-height: 44rpx;
}

.password-toggle {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  cursor: pointer;
  padding: 8rpx;
  line-height: 1;
}

.theme-dark .password-input {
  background: #1C1C1E;
  border-color: #3A3A3C;
  color: #FFFFFF;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #E5E5E5;
}

.theme-dark .modal-footer {
  border-top-color: #3A3A3C;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  font-size: 28rpx;
  border: none;
  background: transparent;
}

.modal-btn.cancel {
  color: #666666;
  border-right: 2rpx solid #E5E5E5;
}

.theme-dark .modal-btn.cancel {
  color: #AAAAAA;
  border-right-color: #3A3A3C;
}

.modal-btn.confirm {
  color: #FF9800;
  font-weight: 500;
}
