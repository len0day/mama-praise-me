<view class="container {{themeClass}}">
  <custom-navbar title="{{i18n.prizes.title || '奖品商城'}}" showBack="{{false}}" />

  <!-- 需要创建家庭提示 -->
  <view class="need-family-tip" wx:if="{{needFamily}}">
    <view class="tip-icon">👨‍👩‍👧‍👦</view>
    <view class="tip-content">
      <view class="tip-title">需要加入家庭</view>
      <view class="tip-desc">奖品商城是以家庭为单位的，请先加入或创建一个家庭</view>
    </view>
    <button class="tip-btn" bindtap="goToFamily">去创建</button>
  </view>

  <!-- 当前孩子信息 -->
  <view class="child-info" wx:if="{{currentChild && !needFamily}}">
    <view class="child-avatar">
      <image wx:if="{{currentChild.avatar}}" src="{{currentChild.avatar}}" mode="aspectFill" />
      <text wx:else>{{currentChild.name.substring(0, 1)}}</text>
    </view>
    <view class="child-details">
      <view class="child-name">{{currentChild.name}} - {{currentChild.familyName || '家庭'}}</view>
      <view class="child-stats">
        <view class="stat-item" bindtap="toggleCoinHistory">
          <text class="stat-icon">🪙</text>
          <text class="stat-text">{{currentChild.familyCoins || childCoins}}</text>
          <text class="stat-arrow">{{showCoinHistory ? '▲' : '▼'}}</text>
        </view>
        <view class="stat-btn" bindtap="goToMyPrizes">
          <text class="stat-icon">🎁</text>
          <text class="stat-text">我的奖品</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 金币历史 -->
  <view class="coin-history" wx:if="{{showCoinHistory && coinRecords.length > 0}}">
    <view class="coin-history-title">最近金币记录</view>
    <view class="coin-history-list">
      <view class="coin-record-item" wx:for="{{coinRecords}}" wx:key="recordId">
        <view class="coin-record-info">
          <view class="coin-record-desc">{{item.description}}</view>
          <view class="coin-record-type">{{formatCoinType(item.type)}}</view>
        </view>
        <view class="coin-record-amount {{item.amount > 0 ? 'positive' : 'negative'}}">
          {{item.amount > 0 ? '+' : ''}}{{item.amount}}
        </view>
      </view>
    </view>
  </view>

  <!-- 分类筛选 -->
  <view class="categories">
    <view
      class="category-item {{currentCategory === item.value ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="value"
      data-category="{{item.value}}"
      bindtap="filterByCategory">
      {{item.label}}
    </view>
  </view>

  <!-- 奖品列表 -->
  <view class="prizes-list">
    <view
      class="prize-item"
      wx:for="{{prizes}}"
      wx:key="prizeId"
      wx:if="{{currentCategory === 'all' || item.category === currentCategory}}">
      <view class="prize-card {{item.affordable ? '' : 'disabled'}}">
        <view class="prize-image">
          <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" />
          <text wx:else class="placeholder-icon">🎁</text>
        </view>
        <view class="prize-info">
          <view class="prize-name">{{item.name}}</view>
          <view class="prize-desc" wx:if="{{item.description}}">{{item.description}}</view>
          <view class="prize-meta">
            <text class="prize-cost">🪙 {{item.coinCost}}</text>
            <text class="prize-stock" wx:if="{{item.stock !== -1}}">库存: {{item.stock}}</text>
            <text class="prize-stock" wx:else>不限</text>
          </view>
        </view>
        <button
          class="redeem-btn {{item.affordable ? '' : 'disabled'}}"
          data-prizeid="{{item.prizeId}}"
          bindtap="redeemPrize">
          {{item.affordable ? '兑换' : '金币不足'}}
        </button>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{prizes.length === 0 && !isLoading}}">
      <text class="empty-icon">🎁</text>
      <text class="empty-text">暂无奖品</text>
    </view>
  </view>

  <!-- 浮动管理按钮 -->
  <view class="manage-float-btn" bindtap="goToPrizeManagement">
    <text class="manage-icon">⚙️</text>
    <text class="manage-text">管理</text>
  </view>

  <!-- 兑换数量选择弹窗 -->
  <view class="modal" wx:if="{{showRedeemModal}}">
    <view class="modal-mask" catchtap="closeRedeemModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">选择兑换数量</text>
        <text class="modal-close" bindtap="closeRedeemModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="prize-summary">
          <image class="prize-thumb" wx:if="{{selectedPrize.image}}" src="{{selectedPrize.image}}" mode="aspectFill" />
          <text class="prize-thumb" wx:else>🎁</text>
          <view class="prize-summary-info">
            <view class="prize-summary-name">{{selectedPrize.name}}</view>
            <view class="prize-summary-cost">单价: 🪙 {{selectedPrize.coinCost}}</view>
            <view class="prize-summary-stock" wx:if="{{selectedPrize.stock !== -1}}">库存: {{selectedPrize.stock}}</view>
          </view>
        </view>

        <view class="quantity-selector">
          <view class="quantity-label"></view>
          <view class="quantity-summary">
            <text class="summary-label">总计：</text>
            <text class="summary-cost">🪙 {{redeemQuantity * selectedPrize.coinCost}}</text>
          </view>
          <view class="quantity-controls">
            <button class="quantity-btn" bindtap="decreaseQuantity" disabled="{{redeemQuantity <= 1}}">-</button>
            <input class="quantity-input" type="number" value="{{redeemQuantity}}" bindinput="onQuantityInput" />
            <button class="quantity-btn" bindtap="increaseQuantity">+</button>
          </view>
        </view>

        <view class="quick-quantity">
          <text class="quick-label">快捷选择：</text>
          <view class="quick-btn" data-qty="1" bindtap="quickSelectQuantity">1</view>
          <view class="quick-btn" data-qty="3" bindtap="quickSelectQuantity">3</view>
          <view class="quick-btn" data-qty="5" bindtap="quickSelectQuantity">5</view>
          <view class="quick-btn" data-qty="10" bindtap="quickSelectQuantity">10</view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="closeRedeemModal">取消</button>
        <button class="modal-btn confirm" bindtap="confirmRedeem">确认兑换</button>
      </view>
    </view>
  </view>
</view>
