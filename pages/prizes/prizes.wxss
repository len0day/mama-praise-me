/* pages/prizes/prizes.wxss */
.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 120rpx;
  overflow-x: hidden; /* 防止横向溢出 */
}

.theme-dark.container {
  background: #1C1C1E;
}

/* 需要家庭提示 */
.need-family-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  text-align: center;
}

.tip-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.tip-content {
  margin-bottom: 60rpx;
}

.tip-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.theme-dark .tip-title {
  color: #FFFFFF;
}

.tip-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.theme-dark .tip-desc {
  color: #AAAAAA;
}

.tip-btn {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  padding: 28rpx 60rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.4);
}

.tip-btn:active {
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.4);
  transform: translateY(1rpx);
}

/* 孩子信息 */
.child-info {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.theme-dark .child-info {
  background: #2C2C2E;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.child-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.child-details {
  flex: 1;
}

.child-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.theme-dark .child-name {
  color: #FFFFFF;
}

.child-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FFB74D, #FFD54F);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.stat-arrow {
  font-size: 20rpx;
  margin-left: 4rpx;
}

.stat-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.stat-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.stat-text {
  font-size: 24rpx;
}

.manage-btn {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: rgba(255, 152, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
  flex-shrink: 0;
  position: relative;
}

.manage-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #FFFFFF;
  position: relative;
  z-index: 1;
}

.theme-dark .manage-btn {
  background: rgba(255, 152, 0, 0.5);
}

/* 金币历史 */
.coin-history {
  margin: 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.theme-dark .coin-history {
  background: #2C2C2E;
}

.coin-history-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.theme-dark .coin-history-title {
  color: #FFFFFF;
}

.coin-history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.coin-record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
}

.theme-dark .coin-record-item {
  background: #1C1C1E;
}

.coin-record-info {
  flex: 1;
}

.coin-record-desc {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 6rpx;
}

.theme-dark .coin-record-desc {
  color: #FFFFFF;
}

.coin-record-type {
  font-size: 24rpx;
  color: #999999;
}

.coin-record-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.coin-record-amount.positive {
  color: #4CAF50;
}

.coin-record-amount.negative {
  color: #F44336;
}

/* 浮动管理按钮 - 右下角 */
.manage-float-btn {
  position: fixed;
  bottom: 220rpx; /* 调高一点，避免挡住最后的奖品按钮 */
  right: 40rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  padding: 20rpx 28rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.4);
  z-index: 100;
}

.manage-icon {
  font-size: 32rpx;
  line-height: 1;
}

.manage-text {
  font-size: 26rpx;
  font-weight: 500;
}

/* 分类筛选 */
.categories {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.category-item {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  background: #FAFAFA;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
  border: 2rpx solid #E5E5E5;
  transition: all 0.2s;
}

.theme-dark .category-item {
  background: #1C1C1E;
  color: #AAAAAA;
  border-color: #3A3A3C;
}

.category-item.active {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border-color: #FF9800;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
}

/* 奖品列表 */
.prizes-list {
  padding: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.prize-item {
  width: 100%;
}

.prize-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
}

.theme-dark .prize-card {
  background: #2C2C2E;
}

.prize-card.disabled {
  opacity: 0.6;
}

.prize-image {
  width: 100%;
  height: 200rpx;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.theme-dark .prize-image {
  background: #1C1C1E;
}

.prize-image image {
  width: 100%;
  height: 100%;
}

.placeholder-icon {
  font-size: 80rpx;
}

.prize-info {
  padding: 20rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.prize-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.theme-dark .prize-name {
  color: #FFFFFF;
}

.prize-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.theme-dark .prize-desc {
  color: #AAAAAA;
}

.prize-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.prize-cost {
  font-size: 28rpx;
  color: #FF9800;
  font-weight: bold;
}

.prize-stock {
  font-size: 24rpx;
  color: #999999;
}

.redeem-btn {
  margin: 20rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.redeem-btn.disabled {
  background: #E0E0E0;
  color: #999999;
}

.theme-dark .redeem-btn.disabled {
  background: #1C1C1E;
  color: #666666;
}

/* 空状态 */
.empty-state {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
}

/* 浮动管理按钮 - 右下角 */
.manage-float-btn {
  position: fixed;
  bottom: 220rpx;
  right: 40rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 152, 0, 0.3);
  z-index: 999;
}

.manage-icon {
  font-size: 28rpx;
  line-height: 1;
}

.manage-text {
  font-size: 24rpx;
  font-weight: 500;
}

/* 模态框样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 120rpx;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  animation: scaleIn 0.3s ease-out;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.theme-dark .modal-content {
  background: #2C2C2E;
}

@keyframes scaleIn {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.theme-dark .modal-content {
  background: #2C2C2E;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.theme-dark .modal-header {
  border-bottom-color: #3A3A3C;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .modal-title {
  color: #FFFFFF;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
  padding: 0 10rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #E5E5E5;
}

.theme-dark .modal-footer {
  border-top-color: #3A3A3C;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.modal-btn.cancel {
  background: #F5F5F5;
  color: #666666;
}

.theme-dark .modal-btn.cancel {
  background: #3A3A3C;
  color: #AAAAAA;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.prize-summary {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.theme-dark .prize-summary {
  background: #1C1C1E;
}

.prize-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.prize-thumb image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.prize-summary-info {
  flex: 1;
}

.prize-summary-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.theme-dark .prize-summary-name {
  color: #FFFFFF;
}

.prize-summary-cost,
.prize-summary-stock {
  font-size: 26rpx;
  color: #666666;
}

.theme-dark .prize-summary-cost,
.theme-dark .prize-summary-stock {
  color: #AAAAAA;
}

.quantity-selector {
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quantity-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  flex-shrink: 0;
}

.theme-dark .quantity-label {
  color: #FFFFFF;
}

.quantity-controls {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: auto;
}

.quantity-btn {
  width: 50rpx !important;
  height: 50rpx !important;
  min-width: 50rpx !important;
  max-width: 50rpx !important;
  border-radius: 50% !important;
  background: linear-gradient(135deg, #FF9800, #FFB74D) !important;
  border: none !important;
  font-size: 32rpx !important;
  font-weight: bold !important;
  color: #FFFFFF !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: 1 !important;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3) !important;
}

.quantity-btn::after {
  border: none !important;
}

.theme-dark .quantity-btn {
  background: linear-gradient(135deg, #FF9800, #FFB74D) !important;
  color: #FFFFFF !important;
}

.quantity-btn[disabled] {
  background: #E0E0E0 !important;
  box-shadow: none !important;
  opacity: 0.5 !important;
}

.theme-dark .quantity-btn[disabled] {
  background: #3A3A3C !important;
}

.quantity-input {
  width: 80rpx;
  height: 50rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  background: #F5F5F5;
  border-radius: 12rpx;
  border: 2rpx solid #E0E0E0;
  flex-shrink: 0;
}

.quantity-input:focus {
  border-color: #FF9800;
  background: #FFFFFF;
}

.theme-dark .quantity-input {
  background: #1C1C1E;
  color: #FFFFFF;
  border-color: #3A3A3C;
}

.theme-dark .quantity-input:focus {
  border-color: #FF9800;
  background: #2C2C2E;
}

.quantity-summary {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  background: #FFF3E0;
  border-radius: 12rpx;
}

.theme-dark .quantity-summary {
  background: #3A3A3C;
}

.summary-label {
  font-size: 26rpx;
  color: #666666;
}

.theme-dark .summary-label {
  color: #AAAAAA;
}

.summary-cost {
  font-size: 32rpx;
  color: #FF9800;
  font-weight: bold;
}

.quick-quantity {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 20rpx;
}

.quick-label {
  font-size: 26rpx;
  color: #666666;
  width: 100%;
  text-align: center;
  margin-bottom: 10rpx;
}

.theme-dark .quick-label {
  color: #AAAAAA;
}

.quick-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
  transition: all 0.2s;
}

.theme-dark .quick-btn {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
}

.quick-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 6rpx rgba(255, 152, 0, 0.3);
}
/* 少女风格 (Girl Style) */
.container.style-girl {
  background: #FFF0F5;
}

.container.style-girl {
  background: #FFF0F5;
}

.style-girl .child-info {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 100rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  padding: 20rpx 40rpx;
  margin: 30rpx 40rpx;
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  box-shadow: 
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    inset 10rpx 10rpx 25rpx rgba(255, 255, 255, 0.9),
    0 15rpx 35rpx rgba(255, 182, 193, 0.2);
}

.style-girl .child-avatar {
  background: linear-gradient(135deg, #FFB6C1, #FFC0CB);
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(255, 182, 193, 0.4);
}

.style-girl .stat-item, .style-girl .stat-btn {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 182, 193, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(255, 182, 193, 0.2);
  color: #C2185B;
  font-weight: 900;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl .child-name {
  color: #C2185B !important;
  font-weight: 900 !important;
  text-shadow: 1rpx 1rpx 0 #FFF, 2rpx 2rpx 10rpx rgba(255, 182, 193, 0.4);
}

.style-girl .stat-text {
  font-weight: 900 !important;
  font-size: 26rpx;
}

.style-girl .prizes-list {
  padding: 16rpx;
  gap: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  box-sizing: border-box;
  width: 100%;
}

.style-girl .prize-item {
  min-width: 0;
  width: 100%;
  box-sizing: border-box;
}

.style-girl .prize-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 40rpx;
  border: 4rpx solid #FFD1DC;
  overflow: visible; /* 为了看到顶部的🎀 */
  padding-top: 20rpx;
  box-sizing: border-box;
  max-width: 100%;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  animation: giftSway 5s ease-in-out infinite;
}

@keyframes giftSway {
  0%, 100% { transform: translateY(0) rotate(0); }
  50% { transform: translateY(-8rpx) rotate(1deg); }
}

.style-girl .prize-card::before {
  content: "🎀";
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 40rpx;
  z-index: 2;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.style-girl .prize-image {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto;
  border-radius: 50%;
  border: 6rpx solid #FFF0F5;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
  background: #FFF9FA;
}

.style-girl .prize-image image {
  border-radius: 50%;
}

.style-girl .prize-name {
  text-align: center;
  color: #FF69B4;
  font-size: 30rpx;
  margin-top: 10rpx;
}

.style-girl .prize-meta {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  margin-top: auto;
}

.style-girl .prize-cost {
  color: #FF1493;
  justify-content: center;
  display: flex;
}

.style-girl .redeem-btn {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border-radius: 40rpx;
  box-shadow: 0 6rpx 15rpx rgba(255, 105, 180, 0.3);
  margin: 10rpx auto 24rpx !important;
  width: 85% !important;
  font-weight: bold;
  font-size: 26rpx;
}

.style-girl .redeem-btn:active {
  transform: scale(0.95);
}

.style-girl .category-item {
  border-radius: 40rpx;
  font-weight: 900;
  color: #C2185B;
  background: rgba(255, 255, 255, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  margin-right: 15rpx;
  transition: all 0.3s;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl .category-item.active {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1) !important;
  color: #FFFFFF !important;
  box-shadow: 0 8rpx 20rpx rgba(255, 182, 193, 0.6);
  transform: scale(1.1);
  border: none;
}

/* 兑换成功动画 */
.style-girl .prize-card.celebrate {
  animation: prizeCelebrate 0.6s ease;
}

@keyframes prizeCelebrate {
  0% { transform: scale(1); }
  50% { transform: scale(1.1) rotate(5deg); }
  100% { transform: scale(1) rotate(0); }
}
@keyframes rewardFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.style-girl.theme-dark {
  background: #2D1B2D;
}

.style-girl.theme-dark .prize-card {
  background: #3A2A3A;
  border-color: #5D3A5D;
}

.style-girl.theme-dark .child-info {
  background: #3A2A3A;
  border-color: #5D3A5D;
}
.style-girl .manage-float-btn {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border-radius: 60rpx;
  padding: 24rpx 40rpx;
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(194, 24, 91, 0.3),
    0 10rpx 30rpx rgba(255, 105, 180, 0.4);
  animation: rewardFloat 4s ease-in-out infinite;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  bottom: 240rpx;
}

.style-girl .manage-btn {
  background: rgba(255, 152, 0, 0.4) !important;
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.3) !important;
  backdrop-filter: blur(10rpx);
}



.style-girl .modal-content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    0 20rpx 50rpx rgba(255, 182, 193, 0.4);
}

.style-girl .modal-title {
  color: #C2185B;
  font-weight: 900;
}

.style-girl .quick-btn {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  padding: 15rpx 25rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  color: #C2185B;
  font-weight: 600;
}

/* 管理按钮根据色调变化 */
.style-girl.color-tone-boy .manage-btn {
  background: rgba(25, 118, 210, 0.4) !important;
}

.style-girl.color-tone-neutral .manage-btn {
  background: rgba(117, 117, 117, 0.4) !important;
}

.style-girl.color-tone-cute .manage-btn {
  background: rgba(255, 167, 38, 0.4) !important;
}

