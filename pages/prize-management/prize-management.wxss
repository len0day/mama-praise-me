/* pages/prize-management/prize-management.wxss */
.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 160rpx;
}

.theme-dark.container {
  background: #1C1C1E;
}

/* 家长模式状态栏 */
.parent-mode-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.theme-dark .parent-mode-bar {
  background: #2C2C2E;
}

.mode-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mode-icon {
  font-size: 32rpx;
}

.mode-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.theme-dark .mode-text {
  color: #FFFFFF;
}

.mode-switch-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 奖品列表 */
.prizes-list {
  padding: 20rpx;
}

.prize-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.theme-dark .prize-item {
  background: #2C2C2E;
}

.prize-header {
  display: flex;
  margin-bottom: 20rpx;
}

.prize-image-small {
  width: 120rpx;
  height: 120rpx;
  border-radius: 15rpx;
  background: #F5F5F5;
  margin-right: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.theme-dark .prize-image-small {
  background: #1C1C1E;
}

.prize-image-small image {
  width: 100%;
  height: 100%;
}

.placeholder-icon {
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.prize-info {
  flex: 1;
}

.prize-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.theme-dark .prize-name {
  color: #FFFFFF;
}

.prize-meta {
  display: flex;
  gap: 20rpx;
}

.prize-cost {
  font-size: 28rpx;
  color: #FF9800;
  font-weight: bold;
}

.prize-category {
  font-size: 24rpx;
  color: #999999;
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.theme-dark .prize-category {
  background: #1C1C1E;
  color: #AAAAAA;
}

.prize-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.theme-dark .prize-desc {
  color: #AAAAAA;
}

.prize-stock {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.prize-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 16rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
}

.action-btn.edit {
  background: #E3F2FD;
  color: #2196F3;
}

.action-btn.delete {
  background: #FFEBEE;
  color: #F44336;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #F0F0F0;
  border-top-color: #FF9800;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.4);
  z-index: 100;
}

.add-icon {
  font-size: 48rpx;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1;
}

.modal-content {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 650rpx;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  overflow-y: auto;
  box-sizing: border-box;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.theme-dark .modal-content {
  background: #2C2C2E;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 48rpx;
  color: #1A1A1A;
}

.theme-dark .modal-title {
  color: #FFFFFF;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.theme-dark .form-label {
  color: #FFFFFF;
}

.form-input,
.form-textarea,
.form-picker {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 44rpx;
  height: 100rpx;
  background: #FAFAFA;
  color: #1A1A1A;
  transition: all 0.2s;
}

/* 确保placeholder可见 */
.form-input::-webkit-input-placeholder,
.form-textarea::-webkit-input-placeholder,
.form-picker::-webkit-input-placeholder {
  color: #999999;
  font-size: 28rpx;
}

.form-input::-moz-placeholder,
.form-textarea::-moz-placeholder,
.form-picker::-moz-placeholder {
  color: #999999;
  font-size: 28rpx;
}

.form-input:-ms-input-placeholder,
.form-textarea:-ms-input-placeholder,
.form-picker:-ms-input-placeholder {
  color: #999999;
  font-size: 28rpx;
}

.form-input:focus,
.form-textarea:focus,
.form-picker:focus {
  border-color: #FF9800;
  background: #FFFFFF;
  color: #1A1A1A;
}

.theme-dark .form-input,
.theme-dark .form-textarea,
.theme-dark .form-picker {
  background: #1C1C1E;
  border-color: #3A3A3C;
  color: #FFFFFF;
}

/* 深色模式placeholder */
.theme-dark .form-input::-webkit-input-placeholder,
.theme-dark .form-textarea::-webkit-input-placeholder,
.theme-dark .form-picker::-webkit-input-placeholder {
  color: #888888;
  font-size: 28rpx;
}

.theme-dark .form-input::-moz-placeholder,
.theme-dark .form-textarea::-moz-placeholder,
.theme-dark .form-picker::-moz-placeholder {
  color: #888888;
  font-size: 28rpx;
}

.theme-dark .form-input:-ms-input-placeholder,
.theme-dark .form-textarea:-ms-input-placeholder,
.theme-dark .form-picker:-ms-input-placeholder {
  color: #888888;
  font-size: 28rpx;
}

.theme-dark .form-input:focus,
.theme-dark .form-textarea:focus,
.theme-dark .form-picker:focus {
  border-color: #FF9800;
  background: #2C2C2E;
  color: #FFFFFF;
}

.form-textarea {
  min-height: 160rpx;
  resize: none;
}

.form-picker {
  min-height: 80rpx;
  display: flex;
  align-items: center;
}

/* 图片上传 */
.image-uploader-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.image-uploader-btn {
  width: 200rpx;
  height: 200rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  border-radius: 0;
  line-height: 0;
}

.image-uploader-btn::after {
  border: none;
}

.image-uploader {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #E5E5E5;
  border-radius: 16rpx;
  overflow: hidden;
  background: #FAFAFA;
  transition: all 0.2s;
}

.image-uploader:active {
  background: #F0F0F0;
}

.theme-dark .image-uploader {
  border-color: #3A3A3C;
  background: #1C1C1E;
}

.theme-dark .image-uploader:active {
  background: #2C2C2E;
}

.uploaded-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999999;
}

.theme-dark .upload-text {
  color: #666666;
}

.remove-image-btn {
  width: 200rpx;
  padding: 16rpx 20rpx;
  background: #FFF;
  border: 2rpx solid #F44336;
  color: #F44336;
  border-radius: 12rpx;
  font-size: 26rpx;
  margin: 0;
  transition: all 0.2s;
}

.remove-image-btn:active {
  background: #F44336;
  color: #FFF;
}

.theme-dark .remove-image-btn {
  background: #2C2C2E;
  border-color: #F44336;
  color: #F44336;
}

.theme-dark .remove-image-btn:active {
  background: #F44336;
  color: #FFF;
}

.upload-text {
  font-size: 24rpx;
  color: #999999;
}

.theme-dark .upload-text {
  color: #AAAAAA;
}

/* 分类选择 - 改为填充按钮 */
.category-selector {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.category-item {
  padding: 16rpx 28rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  background: #FAFAFA;
  transition: all 0.2s;
}

.category-item.active {
  border-color: #FF9800;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
}

.theme-dark .category-item {
  border-color: #3A3A3C;
  background: #1C1C1E;
  color: #AAAAAA;
}

.theme-dark .category-item.active {
  border-color: #FF9800;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
}

/* 库存选择 */
.stock-selector {
  display: flex;
  gap: 30rpx;
}

.stock-option {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333333;
  padding: 12rpx 20rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  border: 2rpx solid #E5E5E5;
  transition: all 0.2s;
}

.stock-option.active {
  border-color: #FF9800;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.theme-dark .stock-option {
  color: #FFFFFF;
  border-color: #3A3A3C;
  background: #1C1C1E;
}

.theme-dark .stock-option.active {
  border-color: #FF9800;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.stock-option radio {
  margin-right: 10rpx;
}

/* 模态框按钮 */
.modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  transition: all 0.2s;
}

.modal-btn.cancel {
  background: #F5F5F5;
  color: #666666;
}

.modal-btn.cancel:active {
  background: #E8E8E8;
}

.theme-dark .modal-btn.cancel {
  background: #3A3A3C;
  color: #AAAAAA;
}

.theme-dark .modal-btn.cancel:active {
  background: #4A4A4C;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}

.modal-btn.confirm:active {
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.3);
  transform: translateY(1rpx);
}

/* 童趣模式 (Girl Style) */
.container.style-girl {
  background: #FFF0F5;
}

.style-girl .child-info {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 100rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  padding: 20rpx 40rpx;
  margin: 30rpx 40rpx;
  backdrop-filter: blur(10px);
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    inset 10rpx 10rpx 25rpx rgba(255, 255, 255, 0.9),
    0 15rpx 35rpx rgba(255, 182, 193, 0.2);
}

.style-girl .child-avatar {
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(255, 182, 193, 0.4);
}

.style-girl .child-name {
  color: #C2185B !important;
  font-weight: 900 !important;
  text-shadow: 1rpx 1rpx 0 #FFF, 2rpx 2rpx 10rpx rgba(255, 182, 193, 0.5);
}

.style-girl .section-title {
  color: #C2185B;
  font-weight: 900;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl .prize-item {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(255, 182, 193, 0.3),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(255, 182, 193, 0.2);
  backdrop-filter: blur(10px);
}

.style-girl .prize-name {
  color: #C2185B;
  font-weight: 700;
}

.style-girl .prize-desc {
  color: #880E4F;
}

.style-girl .prize-meta {
  color: #AD1457;
}

.style-girl .add-prize-btn,
.style-girl .fab-btn {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border-radius: 50rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(194, 24, 91, 0.3),
    0 8rpx 20rpx rgba(255, 20, 147, 0.3);
  font-weight: 900;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl .modal-btn.confirm {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  font-weight: 900;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl .modal-btn.cancel {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50rpx;
  border: 3rpx solid rgba(255, 105, 180, 0.3);
  color: #C2185B;
  font-weight: 700;
}

.style-girl .modal-content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    0 20rpx 50rpx rgba(255, 182, 193, 0.4);
}

.style-girl .modal-title {
  color: #C2185B;
  font-weight: 900;
}

.style-girl .category-item {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  color: #C2185B;
  font-weight: 600;
}

.style-girl .category-item.active {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border-color: #FFFFFF;
  color: #FFFFFF;
  font-weight: 900;
}
