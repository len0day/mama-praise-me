/* 顶部操作栏 - 透明背景 */
.top-action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 32rpx;
  background: transparent;
  backdrop-filter: none;
  border-bottom: none;
}

.theme-dark .top-action-bar {
  background: transparent;
  border-bottom-color: transparent;
}

/* 左侧区域 - 登录/用户信息 */
.left-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 登录/用户信息区域 */
.login-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.1);
}

.theme-dark .login-section {
  background: rgba(30, 30, 30, 0.9);
  border-bottom-color: rgba(255, 255, 255, 0.1);
}

/* 主题按钮条 - 透明背景 */
.theme-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0;
  background: transparent;
  border-radius: 0;
  backdrop-filter: none;
  border: none;
  box-shadow: none;
}

.theme-dark .theme-bar {
  background: transparent;
  border-color: transparent;
  box-shadow: none;
}

/* 主题按钮项 - 更小的圆形 */
.theme-bar-item {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
  position: relative;
  overflow: hidden;
}

.theme-bar-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.theme-bar-item:active::before {
  opacity: 1;
}

.theme-bar-item.active {
  border-color: #FF9800;
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.4);
}

/* 主题颜色按钮 - 更小的尺寸 */
.theme-color-boy {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #64B5F6, #1976D2);
  box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.4);
  position: relative;
}

.theme-color-boy::before {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  right: 2rpx;
  bottom: 2rpx;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.6), transparent);
  border-radius: 50%;
}

.theme-color-girl {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.4);
  position: relative;
}

.theme-color-girl::before {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  right: 2rpx;
  bottom: 2rpx;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.6), transparent);
  border-radius: 50%;
}

.theme-color-cute {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD54F, #FFA726);
  box-shadow: 0 4rpx 12rpx rgba(255, 167, 38, 0.4);
  position: relative;
}

.theme-color-cute::before {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  right: 2rpx;
  bottom: 2rpx;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.6), transparent);
  border-radius: 50%;
}

.theme-color-neutral {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E0E0E0, #757575);
  box-shadow: 0 4rpx 12rpx rgba(117, 117, 117, 0.4);
  position: relative;
}

.theme-color-neutral::before {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  right: 2rpx;
  bottom: 2rpx;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.6), transparent);
  border-radius: 50%;
}

.theme-color-simple-light {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFFFFF, #F5F5F5);
  border: 2rpx solid #E0E0E0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  position: relative;
}

.theme-color-simple-light::before {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  right: 2rpx;
  bottom: 2rpx;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.8), transparent);
  border-radius: 50%;
}

.theme-color-simple-dark {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2C2C2E, #1C1C1E);
  border: 2rpx solid #3A3A3C;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
  position: relative;
}

.theme-color-simple-dark::before {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  right: 2rpx;
  bottom: 2rpx;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.3), transparent);
  border-radius: 50%;
}

/* 登录按钮 - 未登录时更大尺寸 */
.login-button-container {
  width: auto;
  display: flex;
}

.login-button {
  background: linear-gradient(135deg, #1890FF, #40A9FF);
  color: white;
  padding: 14rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
  transition: all 0.3s ease;
}

.login-button:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.3);
}

/* 用户信息区域 - 最小尺寸 */
.user-info-container {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  width: auto;
  gap: 12rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.user-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #1890FF, #40A9FF);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  font-size: 20rpx;
  color: white;
  font-weight: bold;
}

.user-details {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.user-name {
  font-size: 22rpx;
  font-weight: 500;
  color: #1A1A1A;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.theme-dark .user-name {
  color: #FFFFFF;
}

/* 退出按钮 - 最小尺寸，右移 */
.logout-button {
  background: linear-gradient(135deg, #FF4D4F, #FF7875);
  color: white;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 10rpx rgba(255, 77, 79, 0.3);
  transition: all 0.3s ease;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.logout-button:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.3);
}

/* 主题快捷切换按钮 */
.theme-quick-switch {
  position: fixed;
  bottom: 200rpx;
  right: 40rpx;
  z-index: 999;
}

.theme-quick-btn {
  width: 80rpx;
  height: 80rpx;
  background: #FF9800;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
  transition: all 0.3s ease;
}

.theme-quick-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.3);
}

.theme-icon {
  font-size: 36rpx;
}

/* 主题快捷菜单 */
.theme-quick-menu {
  position: fixed;
  bottom: 300rpx;
  right: 60rpx;
  z-index: 1000;
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.3s ease;
  pointer-events: none;
}

.theme-quick-menu.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.theme-menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.2);
  z-index: -1;
}

.theme-menu-content {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  max-width: 300rpx;
}

.theme-dark .theme-menu-content {
  background: #2C2C2E;
  color: white;
}

.theme-menu-title {
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  border-bottom: 1rpx solid #F0F0F0;
}

.theme-dark .theme-menu-title {
  border-bottom-color: #444;
}

.theme-menu-list {
  padding: 16rpx 0;
}

.theme-menu-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  transition: background 0.2s;
  gap: 16rpx;
}

.theme-dark .theme-menu-item {
  color: white;
}

.theme-menu-item:hover {
  background: #F5F5F5;
}

.theme-dark .theme-menu-item:hover {
  background: #3A3A3C;
}

.theme-menu-item.active {
  background: #FFF3E0;
}

.theme-dark .theme-menu-item.active {
  background: #3A3A3C;
}

.theme-menu-item.active::before {
  content: '✓';
  position: absolute;
  right: 24rpx;
  color: #FF9800;
  font-weight: bold;
}

.theme-emoji {
  font-size: 36rpx;
}

/* 主题网格选择器 */
.theme-menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 8rpx 0;
}

.theme-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  transition: all 0.3s ease;
  position: relative;
}

.theme-dark .theme-grid-item {
  background: #3A3A3C;
}

.theme-grid-item:active {
  transform: scale(0.95);
}

.theme-grid-item.active {
  background: #FFF3E0;
  border: 3rpx solid #FF9800;
}

.theme-dark .theme-grid-item.active {
  background: #2C2C2E;
  border-color: #FF9800;
}

.theme-grid-item.active::after {
  content: '✓';
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #FF9800;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
}

/* 主题颜色球 */
.theme-color-boy {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #64B5F6, #1976D2);
  box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.3);
}

.theme-color-girl {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.3);
}

.theme-color-cute {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD54F, #FFA726);
  box-shadow: 0 4rpx 12rpx rgba(255, 167, 38, 0.3);
}

.theme-color-neutral {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E0E0E0, #757575);
  box-shadow: 0 4rpx 12rpx rgba(117, 117, 117, 0.3);
}

.theme-color-simple-light {
  width: 60rpx;
