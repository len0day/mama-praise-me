}

.theme-grid-item text {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

.theme-dark .theme-grid-item text {
  color: #FFFFFF;
}

/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 120rpx;
}

/* 深色主题背景 - 使用多重选择器确保最高优先级 */
view.container.theme-dark,
.theme-dark.container,
.container.theme-dark {
  background: #1C1C1E !important;
  min-height: 100vh !important;
}

/* 深色主题下的基础样式 */
.theme-dark .coins-value {
  color: #FFB74D;
}

.theme-dark .family-name {
  color: #999999;
}

.theme-dark .available-coins .coins-label {
  color: #AAAAAA;
}

/* 全局加载状态 */
.global-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #F0F0F0;
  border-top-color: #FF9800;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.theme-dark .loading-spinner {
  border-color: #3A3A3C;
  border-top-color: #FFB74D;
}

.style-girl .loading-spinner {
  border-color: #FFE4E1;
  border-top-color: #FF69B4;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
}

.theme-dark .loading-text {
  color: #666666;
}

.style-girl .loading-text {
  color: #FF69B4;
  font-weight: 700;
}

/* 孩子信息 */
.child-info {
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  background: #FFFFFF;
  margin: 0 20rpx 20rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.theme-dark .child-info {
  background: #2C2C2E;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

/* 顶部信息行 */
.child-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 左侧可用金币 */
.available-coins {
  display: flex;
  align-items: center;
}

.coins-label {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.coins-value {
  font-size: 40rpx;
  color: #FF9800;
  font-weight: bold;
  margin-left: 8rpx;
}

.theme-dark .coins-label {
  color: #AAAAAA;
}

/* 右侧区域：头像、家庭信息、管理按钮 */
.right-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 小头像 */
.child-avatar-small {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.child-avatar-small image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* 家庭信息 */
.family-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.family-name {
  font-size: 22rpx;
  color: #999999;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.child-name {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.theme-dark .child-name {
  color: #AAAAAA;
}

.dropdown-arrow {
  font-size: 18rpx;
}

.home-family-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.1;
  z-index: 0;
  pointer-events: none;
}

.child-header, .right-section, .coin-stats-container {
  position: relative;
  z-index: 1;
}

/* 金币统计容器 */
.coin-stats-container {
  margin-top: 8rpx;
}

/* 统计范围选择器 */
.stats-range-selector {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 12rpx;
  padding: 0 10rpx;
}

.range-item {
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
  color: #666666;
  font-weight: 500;
  transition: all 0.3s;
  border: none;
}

.range-item.active {
  background: #FF9800;
  color: #FFFFFF;
  font-weight: 600;
}

/* 深色主题 */
.theme-dark .range-item {
  background: #3A3A3C;
  color: #AAAAAA;
}

.theme-dark .range-item.active {
  background: #FF9800;
  color: #FFFFFF;
}

/* 日历容器 */
.calendar-container {
  margin-bottom: 16rpx;
}

.calendar-scroll {
  width: 100%;
  height: 120rpx;  /* 统一高度 */
}

.calendar-list {
  display: flex;
  flex-direction: row !important;  /* 统一横向布局 */
  width: max-content;
  height: 100%;
  align-items: center;
  padding: 8rpx 0;
}

/* 统一的卡片样式 */
.calendar-item {
  flex-shrink: 0;
  width: 90rpx;
  height: 90rpx;
  margin: 0 6rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #FFFFFF, #F5F5F5);
  display: flex;
  flex-direction: column;  /* 默认竖向布局 */
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  transition: all 0.3s;
  border: 1rpx solid #E0E0E0;
  box-shadow:
    0 4rpx 8rpx rgba(0, 0, 0, 0.08),
    0 2rpx 4rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
}

/* 卡片高光效果 */
.calendar-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0) 100%);
  border-radius: 16rpx 16rpx 0 0;
  pointer-events: none;
}

.calendar-item.selected {
  /* 选中状态：更立体更有层次 */
  background: linear-gradient(145deg, #FFF3E0, #FFE0B2);
  border: 2rpx solid #FFB74D;
  box-shadow:
    0 8rpx 16rpx rgba(255, 152, 0, 0.25),
    0 4rpx 8rpx rgba(255, 152, 0, 0.15),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.9),
    inset 0 -2rpx 4rpx rgba(255, 152, 0, 0.1);
  transform: translateY(-2rpx);
}

.calendar-item.selected .calendar-main,
.calendar-item.selected .calendar-sub {
  color: #E65100;  /* 深橙色，更有对比度 */
  font-weight: bold;
}

/* 年份模式的特殊样式：横向布局 */
.calendar-item.year-item {
  flex-direction: row !important;
  width: 120rpx;  /* 宽度增加 */
  height: 60rpx;   /* 高度减小 */
  gap: 8rpx;
}

.calendar-item.year-item .calendar-main {
  font-size: 24rpx;  /* 字体小一些 */
}

.calendar-item.year-item .calendar-sub {
  font-size: 18rpx;  /* 字体小一些 */
}

.calendar-item {
  flex-shrink: 0;
  width: 90rpx;
  height: 90rpx;
  margin: 0 6rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.calendar-list[style*="column"] .calendar-item {
  margin: 4rpx 6rpx;
}

.calendar-item.selected {
  /* 半透明磨砂背景 */
  background: rgba(255, 152, 0, 0.25);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 152, 0, 0.5);
