/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 120rpx;
}

.container.theme-dark {
  background: #1C1C1E;
}

/* 孩子信息 */
.child-info {
  position: relative;
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.theme-dark .child-info {
  background: #2C2C2E;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.child-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.child-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.home-family-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.1;
  z-index: 0;
  pointer-events: none;
}

.child-avatar, .child-details, .task-manage-btn {
  position: relative;
  z-index: 1;
}

.child-details {
  flex: 1;
}

.child-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.child-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.child-name.with-arrow {
  position: relative;
  padding-right: 4rpx;
}

.theme-dark .child-name {
  color: #FFFFFF;
}

.child-coins {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  color: #FF9800;
  font-weight: bold;
}

.coin-icon {
  margin-right: 8rpx;
}

.task-manage-btn {
  width: 100rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
  position: relative;
}

.task-manage-btn::before {
  content: '';
  position: absolute;
  top: 10%;
  left: 20%;
  width: 30%;
  height: 30%;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  filter: blur(4rpx);
}

.task-manage-btn .manage-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  position: relative;
  z-index: 1;
}

.theme-dark .task-manage-btn {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
}

/* 无孩子提示 */
.no-child {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.no-child-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.no-child-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 60rpx;
}

.add-child-btn {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
}

/* 任务容器 */
.tasks-container {
  padding: 20rpx;
  padding-bottom: 240rpx; /* 增加底部间距 */
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.style-girl .section-title {
  color: #C2185B;
  font-weight: 900;
  font-size: 40rpx;
  text-shadow: 1rpx 1rpx 0 #FFF, 2rpx 2rpx 15rpx rgba(255, 182, 193, 0.4);
  margin-top: 20rpx;
}

.theme-dark .section-title {
  color: #FFFFFF;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}

/* 任务列表 */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 任务筛选栏 */
.task-filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-item {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.3s;
}

.theme-dark .filter-item {
  background: #3A3A3C;
  color: #999999;
}

.filter-item.active {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  font-weight: 500;
}

/* 少女风格下的筛选按钮 */
.style-girl .filter-item {
  border-radius: 40rpx;
  font-weight: 900;
  color: #C2185B;
  background: rgba(255, 255, 255, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  margin-right: 15rpx;
  transition: all 0.3s;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl .filter-item.active {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(255, 182, 193, 0.6);
  transform: scale(1.1);
}

.task-item {
  position: relative;
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12), 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.theme-dark .task-item {
  background: #2C2C2E;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4), 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
  border-color: rgba(255, 255, 255, 0.05);
}

/* 基础结构适配（默认风格） */
.task-info-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.task-info-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center; /* 垂直居中奖励信息 */
  gap: 12rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.task-header-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.theme-dark .task-item.is-challenge {
  background: linear-gradient(135deg, #2D1F1F, #2C2C2E);
  box-shadow: 0 8rpx 24rpx rgba(255, 87, 34, 0.3), 0 2rpx 6rpx rgba(255, 87, 34, 0.15);
  border-color: rgba(255, 87, 34, 0.3);
}

/* 挑战任务添加微妙的装饰效果 */
.task-item.is-challenge::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 87, 34, 0.03), transparent);
  border-radius: 20rpx;
  pointer-events: none;
}

/* 挑战任务装饰元素 */
.challenge-decoration {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  opacity: 0.3;
}

.decoration-icon {
  font-size: 32rpx;
  animation: twinkle 2s ease-in-out infinite;
}

@keyframes twinkle {
  0%, 100% {
    opacity: 0.3;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(1.1);
  }
}

/* 任务类型标签 */
.task-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  z-index: 1;
}

/* 内联任务类型标签（替换图标） */
.task-badge-inline {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-right: 12rpx;
}

.task-badge-inline.daily {
  background: linear-gradient(135deg, #4CAF50, #81C784);
  color: #FFFFFF;
}

.task-badge-inline.weekly {
  background: linear-gradient(135deg, #2196F3, #64B5F6);
  color: #FFFFFF;
}

.task-badge-inline.monthly {
  background: linear-gradient(135deg, #9C27B0, #BA68C8);
  color: #FFFFFF;
}

.task-badge-inline.challenge {
  background: linear-gradient(135deg, #FF5722, #FF8A65);
  color: #FFFFFF;
}

.task-badge-inline.upcoming {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.task-badge-inline.penalty {
  background: linear-gradient(135deg, #E53935, #EF5350);
  color: #FFFFFF;
}

.task-badge-inline.default {
  background: #E0E0E0;
  color: #666666;
}

.theme-dark .task-badge-inline.default {
  background: #4A4A4C;
  color: #999999;
}

.task-badge.daily {
  background: linear-gradient(135deg, #4CAF50, #81C784);
  color: #FFFFFF;
}

.task-badge.weekly {
  background: linear-gradient(135deg, #2196F3, #64B5F6);
  color: #FFFFFF;
}

.task-badge.monthly {
  background: linear-gradient(135deg, #9C27B0, #BA68C8);
  color: #FFFFFF;
}

.task-badge.challenge {
  background: linear-gradient(135deg, #FF5722, #FF8A65);
  color: #FFFFFF;
}

.task-badge.upcoming {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.task-badge.default {
  background: #E0E0E0;
  color: #666666;
}

.theme-dark .task-badge.default {
  background: #4A4A4C;
  color: #999999;
}

.task-item.completed {
  opacity: 0.6 !important;
  background: #F5F5F5 !important;
  box-shadow: none !important;
}

.theme-dark .task-item.completed {
  background: #1C1C1E;
}

.task-item.pending {
  opacity: 0.6;
  border: 2rpx solid #FF9800;
  background: #FFF3E0;
}

.theme-dark .task-item.pending {
  background: #3A3A3C;
}

.task-status-top {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #FF9800;
  background: rgba(255, 152, 0, 0.1);
  font-weight: 500;
  z-index: 10;
}

.theme-dark .task-status-top {
  color: #FFB74D;
}

.task-content {
  flex: 1;
}

.task-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.task-type {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .task-title {
  color: #FFFFFF;
}

.task-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.theme-dark .task-desc {
  color: #AAAAAA;
}

.task-status-info {
  font-size: 24rpx;
  color: #FF9800;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.theme-dark .task-status-info {
  color: #FFB74D;
}

.task-reward {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #FF9800;
  font-weight: bold;
}

.task-status {
  font-size: 48rpx;
  margin-left: 20rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 家庭选择器样式 */
.child-name {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dropdown-arrow {
  font-size: 24rpx;
  color: #FF9800;
  transition: transform 0.3s;
}

.picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
}

.picker-content {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  animation: fadeIn 0.3s ease-out;
  overflow: hidden;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.theme-dark .picker-content {
  background: #2C2C2E;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.theme-dark .picker-header {
  border-bottom-color: #3A3A3C;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .picker-title {
  color: #FFFFFF;
}

.picker-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.picker-list {
  flex: 1;
  overflow-y: auto;
  padding: 10rpx 0;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.theme-dark .picker-item {
  border-bottom-color: #3A3A3C;
}

.picker-item:active {
  background: #F5F5F5;
}

.theme-dark .picker-item:active {
  background: #3A3A3C;
}

.picker-item-name {
  font-size: 32rpx;
  color: #333333;
}

.theme-dark .picker-item-name {
  color: #FFFFFF;
}

.picker-role-badge.admin {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.picker-role-badge.creator {
  background: linear-gradient(135deg, #E53935, #EF5350);
  color: #FFFFFF;
}

.picker-role-badge.member {
  background: #EEEEEE;
  color: #666666;
}

.theme-dark .picker-role-badge.member {
  background: #3A3A3C;
  color: #AAAAAA;
}

.picker-item-check {
  font-size: 36rpx;
  color: #FF9800;
  font-weight: bold;
}
/* 少女风格 (Girl Style) */
.container.style-girl {
  background: #FFF0F5;
}

.style-girl .child-info {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 100rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  padding: 20rpx 40rpx;
  margin: 30rpx 40rpx;
  backdrop-filter: blur(10px);
  /* 3D 胶囊效果 */
  box-shadow: 
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    inset 10rpx 10rpx 25rpx rgba(255, 255, 255, 0.9),
    0 15rpx 35rpx rgba(255, 182, 193, 0.2);
}

.style-girl .child-avatar {
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(255, 182, 193, 0.4);
}

.style-girl .child-name {
  color: #C2185B !important;
  font-weight: 900 !important;
  /* 气球字体感：极简圆润 */
  text-shadow: 1rpx 1rpx 0 #FFF, 2rpx 2rpx 10rpx rgba(255, 182, 193, 0.5);
}

.style-girl .task-manage-btn {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 
    inset -5rpx -5rpx 15rpx rgba(194, 24, 91, 0.3),
    0 8rpx 20rpx rgba(255, 20, 147, 0.3);
  animation: rewardFloat 4s ease-in-out infinite;
}

.style-girl .task-manage-btn text {
  font-size: 36rpx;
}

.style-girl .task-list {
  padding: 40rpx 40rpx 100rpx;
  display: flex;
  flex-direction: column;
  gap: 60rpx;
}

.style-girl .task-item {
  position: relative;
  width: 90%;
  margin: 0 auto 60rpx;
  border-radius: 120rpx 100rpx 120rpx 80rpx; /* 不规则圆形，更像气球 */
  padding: 30rpx 50rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  color: #C2185B;
  /* 3D 立体感阴影：内发光 + 深色外阴影 */
  box-shadow: 
    inset -10rpx -10rpx 30rpx rgba(255, 182, 193, 0.4),
    inset 15rpx 15rpx 40rpx rgba(255, 255, 255, 0.9),
    0 15rpx 40rpx rgba(255, 182, 193, 0.2);
  
  animation: balloonDrift3D 10s ease-in-out infinite;
  display: flex;
  flex-direction: row; /* 水平排列标题与右侧图标 */
  align-items: center;
  justify-content: space-between;
  overflow: visible;
  min-height: 160rpx;
  backdrop-filter: blur(12px);
  margin-bottom: 40rpx;
}

.style-girl .task-info-left {
  flex: 1;
  text-align: left;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

.style-girl .task-info-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-left: 20rpx;
  animation: rewardFloat 5s ease-in-out infinite;
}

.style-girl .task-status {
  font-size: 40rpx;
  margin-top: 5rpx;
}

.style-girl .task-item.daily { background: rgba(255, 240, 245, 0.5); }
.style-girl .task-item.weekly { background: rgba(253, 245, 255, 0.5); }
.style-girl .task-item.monthly { background: rgba(240, 248, 255, 0.5); }
.style-girl .task-item.penalty { background: rgba(255, 245, 230, 0.5); }

.style-girl .task-content {
  flex: 1;
  text-align: left;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.style-girl .task-title {
  font-size: 32rpx;
  color: #C2185B;
  font-weight: bold;
  max-width: 320rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 8rpx;
}

.style-girl .task-desc {
  font-size: 24rpx;
  color: #880E4F;
  opacity: 0.8;
  max-width: 320rpx;
  display: block;
}

/* 气球内的胶囊状态 */
.style-girl .task-status-top {
  position: relative;
  top: auto;
  right: auto;
  background: rgba(255, 255, 255, 0.8); /* 白色半透明背景，衬托彩色文字 */
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: bold;
  white-space: nowrap;
  box-shadow: 0 4rpx 10rpx rgba(255, 182, 193, 0.2);
  animation: capsuleFloat 4s ease-in-out infinite;
  
  /* 彩色文字 */
  background-image: linear-gradient(to right, #FF1493, #FF8C00, #9370DB);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  border: 1rpx solid rgba(255, 182, 193, 0.3);
}

.style-girl .task-reward {
  margin-top: 10rpx;
  background: #FFFFFF;
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%; /* 圆球形 */
  border: 4rpx solid #FFD1DC;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 
    inset -4rpx -4rpx 10rpx rgba(255, 182, 193, 0.4),
    0 10rpx 20rpx rgba(255, 182, 193, 0.3);
  animation: rewardFloat 3s ease-in-out infinite;
  padding: 0;
}

.style-girl .task-reward::after {
  content: "";
  position: absolute;
  bottom: -15rpx;
  left: 50%;
  width: 2rpx;
  height: 15rpx;
  background: #FFD1DC;
  transform: translateX(-50%);
}

.style-girl .task-reward text {
  font-weight: 800 !important;
  font-size: 24rpx !important; /* 字体稍微变小，适配圆球 */
  background: linear-gradient(to right, #FF1493, #FF8C00, #9370DB);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: block;
  line-height: 1;
}

.style-girl .coin-icon {
  font-size: 22rpx; /* 图标变小 */
  margin-bottom: 2rpx;
}

@keyframes rewardFloat {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-10rpx) scale(1.05); }
}

.style-girl .task-reward text {
  color: #FFFFFF !important;
  font-weight: bold;
}

.style-girl .task-badge-inline {
  display: none; /* 风格化后隐藏原本的标签 */
}

/* 3D 气球大幅度全方位漂移 */
@keyframes balloonDrift3D {
  0%, 100% { transform: translate(0, 0) scale(1) rotate(0); }
  25% { transform: translate(30rpx, -40rpx) scale(1.02) rotate(3deg); }
  50% { transform: translate(-20rpx, -70rpx) scale(0.98) rotate(-2deg); }
  75% { transform: translate(-30rpx, -30rpx) scale(1.01) rotate(2deg); }
}

@keyframes capsuleFloat {
  0%, 100% { transform: translateY(0) rotate(0); }
  50% { transform: translateY(-10rpx) rotate(5deg); }
}

/* 让不同的气球飘动节奏不一 */
.style-girl .task-item:nth-child(odd) { animation-name: balloonDrift3D; animation-delay: -1s; animation-duration: 11s; }
.style-girl .task-item:nth-child(2) { animation-name: balloonDrift3D; animation-delay: -3s; animation-duration: 13s; }
.style-girl .task-item:nth-child(4) { animation-name: balloonDrift3D; animation-delay: -7s; animation-duration: 12s; }

/* 气球新生/重生动画 */
.style-girl .task-item.spawning {
  animation: balloonSpawn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards !important;
}

@keyframes balloonSpawn {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.1); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

/* 少女风格下已完成任务的特殊处理 */
.style-girl .task-item.completed {
  opacity: 0.5;
  background: rgba(255, 255, 255, 0.4) !important;
  border: 4rpx dashed #C2185B;
  box-shadow: none;
  animation: none; /* 已完成的气球不再飘动，像落地的气球或静止状态 */
  transform: translateY(10rpx);
}

.style-girl .task-item.completed::after {
  height: 20rpx; /* 绳子变短 */
  bottom: -20rpx;
}

/* 气球点击/完成动画 */
.style-girl .task-item.popping {
  animation: balloonPop 0.4s forwards !important;
}

@keyframes balloonPop {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.3) rotate(5deg); opacity: 0.8; }
  100% { transform: scale(3); opacity: 0; }
}

.style-girl .theme-dark.container {
  background: #2D1B22; /* 更柔和的暗粉紫色 */
}

.style-girl .theme-dark .task-item {
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.3);
}
