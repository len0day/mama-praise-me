/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 120rpx;
}

.container.theme-dark {
  background: #1C1C1E;
}

/* 孩子信息 */
.child-info {
  position: relative;
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.theme-dark .child-info {
  background: #2C2C2E;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.child-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.child-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.home-family-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.1;
  z-index: 0;
  pointer-events: none;
}

.child-avatar, .child-details, .task-manage-btn {
  position: relative;
  z-index: 1;
}

.child-details {
  flex: 1;
}

.child-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.child-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.child-name.with-arrow {
  position: relative;
  padding-right: 4rpx;
}

.theme-dark .child-name {
  color: #FFFFFF;
}

.child-coins {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  color: #FF9800;
  font-weight: bold;
}

.coin-icon {
  margin-right: 8rpx;
}

.task-manage-btn {
  font-size: 48rpx;
  padding: 10rpx;
}

/* 无孩子提示 */
.no-child {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.no-child-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.no-child-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 60rpx;
}

.add-child-btn {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
}

/* 任务容器 */
.tasks-container {
  padding: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.theme-dark .section-title {
  color: #FFFFFF;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}

/* 任务列表 */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 任务筛选栏 */
.task-filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-item {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.3s;
}

.theme-dark .filter-item {
  background: #3A3A3C;
  color: #999999;
}

.filter-item.active {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  font-weight: 500;
}

.task-item {
  position: relative;
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12), 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.theme-dark .task-item {
  background: #2C2C2E;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4), 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
  border-color: rgba(255, 255, 255, 0.05);
}

/* 挑战任务卡片的特殊样式 */
.task-item.is-challenge {
  background: linear-gradient(135deg, #FFF5F2, #FFFFFF);
  box-shadow: 0 8rpx 24rpx rgba(255, 87, 34, 0.15), 0 2rpx 6rpx rgba(255, 87, 34, 0.08);
  border: 2rpx solid rgba(255, 87, 34, 0.2);
}

.theme-dark .task-item.is-challenge {
  background: linear-gradient(135deg, #2D1F1F, #2C2C2E);
  box-shadow: 0 8rpx 24rpx rgba(255, 87, 34, 0.3), 0 2rpx 6rpx rgba(255, 87, 34, 0.15);
  border-color: rgba(255, 87, 34, 0.3);
}

/* 挑战任务添加微妙的装饰效果 */
.task-item.is-challenge::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 87, 34, 0.03), transparent);
  border-radius: 20rpx;
  pointer-events: none;
}

/* 挑战任务装饰元素 */
.challenge-decoration {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  opacity: 0.3;
}

.decoration-icon {
  font-size: 32rpx;
  animation: twinkle 2s ease-in-out infinite;
}

@keyframes twinkle {
  0%, 100% {
    opacity: 0.3;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(1.1);
  }
}

/* 任务类型标签 */
.task-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  z-index: 1;
}

/* 内联任务类型标签（替换图标） */
.task-badge-inline {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-right: 12rpx;
}

.task-badge-inline.daily {
  background: linear-gradient(135deg, #4CAF50, #81C784);
  color: #FFFFFF;
}

.task-badge-inline.weekly {
  background: linear-gradient(135deg, #2196F3, #64B5F6);
  color: #FFFFFF;
}

.task-badge-inline.monthly {
  background: linear-gradient(135deg, #9C27B0, #BA68C8);
  color: #FFFFFF;
}

.task-badge-inline.challenge {
  background: linear-gradient(135deg, #FF5722, #FF8A65);
  color: #FFFFFF;
}

.task-badge-inline.upcoming {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.task-badge-inline.penalty {
  background: linear-gradient(135deg, #E53935, #EF5350);
  color: #FFFFFF;
}

.task-badge-inline.default {
  background: #E0E0E0;
  color: #666666;
}

.theme-dark .task-badge-inline.default {
  background: #4A4A4C;
  color: #999999;
}

.task-badge.daily {
  background: linear-gradient(135deg, #4CAF50, #81C784);
  color: #FFFFFF;
}

.task-badge.weekly {
  background: linear-gradient(135deg, #2196F3, #64B5F6);
  color: #FFFFFF;
}

.task-badge.monthly {
  background: linear-gradient(135deg, #9C27B0, #BA68C8);
  color: #FFFFFF;
}

.task-badge.challenge {
  background: linear-gradient(135deg, #FF5722, #FF8A65);
  color: #FFFFFF;
}

.task-badge.upcoming {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.task-badge.default {
  background: #E0E0E0;
  color: #666666;
}

.theme-dark .task-badge.default {
  background: #4A4A4C;
  color: #999999;
}

.task-item.completed {
  opacity: 0.6;
  background: #F5F5F5;
}

.theme-dark .task-item.completed {
  background: #1C1C1E;
}

.task-item.pending {
  opacity: 0.6;
  border: 2rpx solid #FF9800;
  background: #FFF3E0;
}

.theme-dark .task-item.pending {
  background: #3A3A3C;
}

/* 右上角状态信息 */
.task-status-top {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #FF9800;
  font-weight: 500;
  z-index: 1;
}

.theme-dark .task-status-top {
  color: #FFB74D;
}

.task-content {
  flex: 1;
}

.task-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.task-type {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .task-title {
  color: #FFFFFF;
}

.task-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.theme-dark .task-desc {
  color: #AAAAAA;
}

.task-status-info {
  font-size: 24rpx;
  color: #FF9800;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.theme-dark .task-status-info {
  color: #FFB74D;
}

.task-reward {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #FF9800;
  font-weight: bold;
}

.task-status {
  font-size: 48rpx;
  margin-left: 20rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 家庭选择器样式 */
.child-name {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dropdown-arrow {
  font-size: 24rpx;
  color: #FF9800;
  transition: transform 0.3s;
}

.picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
}

.picker-content {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  animation: fadeIn 0.3s ease-out;
  overflow: hidden;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.theme-dark .picker-content {
  background: #2C2C2E;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.theme-dark .picker-header {
  border-bottom-color: #3A3A3C;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .picker-title {
  color: #FFFFFF;
}

.picker-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.picker-list {
  flex: 1;
  overflow-y: auto;
  padding: 10rpx 0;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.theme-dark .picker-item {
  border-bottom-color: #3A3A3C;
}

.picker-item:active {
  background: #F5F5F5;
}

.theme-dark .picker-item:active {
  background: #3A3A3C;
}

.picker-item-name {
  font-size: 32rpx;
  color: #333333;
}

.theme-dark .picker-item-name {
  color: #FFFFFF;
}

.picker-role-badge.admin {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.picker-role-badge.creator {
  background: linear-gradient(135deg, #E53935, #EF5350);
  color: #FFFFFF;
}

.picker-role-badge.member {
  background: #EEEEEE;
  color: #666666;
}

.theme-dark .picker-role-badge.member {
  background: #3A3A3C;
  color: #AAAAAA;
}

.picker-item-check {
  font-size: 36rpx;
  color: #FF9800;
  font-weight: bold;
}
