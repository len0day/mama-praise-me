}

.style-girl .task-item.penalty {
  background: linear-gradient(135deg, rgba(255, 245, 230, 0.7), rgba(255, 235, 220, 0.8));
  box-shadow:
    inset -8rpx -8rpx 20rpx rgba(255, 87, 34, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(255, 150, 100, 0.3);
  border-radius: 50rpx;
}

.style-girl .task-item[data-task-type="custom"] {
  background: linear-gradient(135deg, rgba(255, 250, 240, 0.7), rgba(255, 245, 230, 0.8));
  box-shadow:
    inset -8rpx -8rpx 20rpx rgba(255, 193, 7, 0.2),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(255, 200, 100, 0.3);
  border-radius: 50rpx;
}

.style-girl .task-content {
  flex: 1;
  text-align: left;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.style-girl .task-title {
  font-size: 26rpx;
  color: #C2185B;
  font-weight: bold;
  max-width: 100%;
  white-space: normal; /* 允许换行 */
  overflow: visible;
  line-height: 1.3;
  margin-bottom: 5rpx;
  flex-shrink: 1; /* 允许标题收缩 */
}

.style-girl .task-desc {
  font-size: 20rpx;
  color: #880E4F;
  opacity: 0.8;
  max-width: 100%;
  margin-top: 6rpx;
  line-height: 1.4;
  white-space: normal;
  overflow: visible;
  display: -webkit-box;
  -webkit-line-clamp: 3; /* 增加到3行 */
  -webkit-box-orient: vertical;
  font-weight: 400;
}

/* 气球内的胶囊状态 */
.style-girl .task-status-top {
  position: relative;
  top: auto;
  right: auto;
  background: rgba(255, 255, 255, 0.8); /* 白色半透明背景，衬托彩色文字 */
  padding: 4rpx 10rpx;
  border-radius: 18rpx;
  font-size: 20rpx;
  font-weight: bold;
  white-space: nowrap;
  box-shadow: 0 4rpx 10rpx rgba(255, 182, 193, 0.2);
  animation: capsuleFloat 4s ease-in-out infinite;
  
  /* 彩色文字 */
  background-image: linear-gradient(to right, #FF1493, #FF8C00, #9370DB);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  border: 1rpx solid rgba(255, 182, 193, 0.3);
}

.style-girl .task-reward {
  margin-top: 6rpx;
  background: rgba(255, 255, 255, 0.85); /* 半透明背景 */
  width: 55rpx;
  height: 55rpx;
  border-radius: 50%; /* 圆球形 */
  border: 2rpx solid rgba(255, 209, 220, 0.6); /* 半透明边框 */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0; /* 金币圆球不收缩 */
  position: relative;
  z-index: 1; /* 金币层级较低 */
  box-shadow:
    inset -4rpx -4rpx 10rpx rgba(255, 182, 193, 0.4),
    0 10rpx 20rpx rgba(255, 182, 193, 0.3);
  animation: rewardFloat 3s ease-in-out infinite;
  padding: 0;
}

.style-girl .task-reward::after {
  content: "";
  position: absolute;
  bottom: -15rpx;
  left: 50%;
  width: 2rpx;
  height: 15rpx;
  background: #FFD1DC;
  transform: translateX(-50%);
}

.style-girl .task-reward text {
  font-weight: 800 !important;
  font-size: 22rpx !important; /* 字体更大 */
  background: linear-gradient(to right, #FF1493, #FF8C00, #9370DB);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: block;
  line-height: 1;
}

.style-girl .coin-icon {
  font-size: 22rpx; /* 图标变小 */
  margin-bottom: 2rpx;
}

@keyframes rewardFloat {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-10rpx) scale(1.05); }
}

.style-girl .task-reward text {
  color: #FFFFFF !important;
  font-weight: bold;
}

.style-girl .task-badge-inline {
  display: none; /* 风格化后隐藏原本的标签 */
}

/* 倒计时和过期胶囊在童趣模式下仍然显示 */
.style-girl .task-badge-inline.countdown,
.style-girl .task-badge-inline.expired {
  display: inline-block;
}

/* 3D 气球大幅度全方位漂移 */
@keyframes balloonDrift3D {
  0%, 100% { transform: translate(0, 0) scale(1) rotate(0); }
  25% { transform: translate(10rpx, -30rpx) scale(1.02) rotate(3deg); }
  50% { transform: translate(-8rpx, -50rpx) scale(0.98) rotate(-2deg); }
  75% { transform: translate(-10rpx, -20rpx) scale(1.01) rotate(2deg); }
}

@keyframes capsuleFloat {
  0%, 100% { transform: translateY(0) rotate(0); }
  50% { transform: translateY(-10rpx) rotate(5deg); }
}

/* 让不同的气球飘动节奏不一 */
.style-girl .task-item:not(.no-float):nth-child(odd) { animation-name: balloonDrift3D; animation-delay: -1s; animation-duration: 11s; }
.style-girl .task-item:not(.no-float):nth-child(2) { animation-name: balloonDrift3D; animation-delay: -3s; animation-duration: 13s; }
.style-girl .task-item:not(.no-float):nth-child(4) { animation-name: balloonDrift3D; animation-delay: -7s; animation-duration: 12s; }

/* 气球新生/重生动画 */
.style-girl .task-item.spawning {
  animation: balloonSpawn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards !important;
}

@keyframes balloonSpawn {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.1); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

/* 少女风格下已完成任务的特殊处理 */
.style-girl .task-item.completed {
  opacity: 0.5;
  background: rgba(255, 255, 255, 0.4) !important;
  border: 4rpx dashed #C2185B;
  box-shadow: none;
  animation: none; /* 已完成的气球不再飘动，像落地的气球或静止状态 */
  transform: translateY(10rpx);
}

.style-girl .task-item.completed::after {
  height: 20rpx; /* 绳子变短 */
  bottom: -20rpx;
}

/* 气球点击/完成动画 */
.style-girl .task-item.popping {
  animation: balloonPop 0.4s forwards !important;
}

@keyframes balloonPop {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.3) rotate(5deg); opacity: 0.8; }
  100% { transform: scale(3); opacity: 0; }
}


/* 童趣模式下的容器底部安全间距 */
.style-girl .container {
  padding-bottom: 100rpx; /* 增加整体容器的底部间距 */
}

.style-girl .theme-dark .task-item {
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.3);
}

.style-girl .modal-content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    0 20rpx 50rpx rgba(255, 182, 193, 0.4);
}

.style-girl .modal-title {
  color: #C2185B;
  font-weight: 900;
}

/* 标题行容器 */
.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-bottom: 12rpx;
  padding: 8rpx 32rpx;
  min-height: 50rpx;
  overflow: hidden;
}

/* 自定义开关 - 立体小巧版 */
.custom-switch {
  position: relative;
  width: 56rpx;
  height: 28rpx;
  background: linear-gradient(145deg, #E0E0E0, #C5C5C5);
  border-radius: 14rpx;
  box-shadow:
    inset 2rpx 2rpx 4rpx rgba(255, 255, 255, 0.5),
    inset -2rpx -2rpx 4rpx rgba(0, 0, 0, 0.1),
    2rpx 2rpx 6rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s;
  flex-shrink: 0;
  cursor: pointer;
}

.custom-switch.checked {
  background: linear-gradient(145deg, #FF69B4, #FF1493);
  box-shadow:
    inset 2rpx 2rpx 4rpx rgba(255, 255, 255, 0.4),
    inset -2rpx -2rpx 4rpx rgba(0, 0, 0, 0.2),
    2rpx 2rpx 8rpx rgba(255, 20, 147, 0.3);
}

.switch-icon {
  position: absolute;
  left: 4rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 14rpx;
  line-height: 1;
  z-index: 1;
  transition: opacity 0.3s;
}

.custom-switch.checked .switch-icon {
  opacity: 0;
}

.switch-thumb {
  position: absolute;
  left: 2rpx;
  top: 2rpx;
  width: 24rpx;
  height: 24rpx;
  background: linear-gradient(145deg, #FFFFFF, #F0F0F0);
  border-radius: 50%;
  box-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
  transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-switch.checked .switch-thumb {
  left: 30rpx;
  background: linear-gradient(145deg, #FFFFFF, #FFE4E1);
}

.custom-switch.checked .switch-thumb::after {
  content: '🎈';
  font-size: 12rpx;
  line-height: 1;
}

.toggle-switch::after {
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

/* 飘动动画控制 */
.style-girl .task-item:not(.no-float) {
  animation: balloonFloat 6s ease-in-out infinite;
}

.style-girl .task-item.no-float {
  animation: none;
}
