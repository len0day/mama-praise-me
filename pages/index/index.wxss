/* 任务进度条 */
.task-progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 32rpx 16rpx 32rpx;
}

.progress-bar-container {
  flex: 1;
  height: 16rpx;
  background: linear-gradient(145deg, #F0F0F0, #E0E0E0);
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
  box-shadow:
    inset 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1),
    inset -1rpx -1rpx 2rpx rgba(255, 255, 255, 0.7),
    0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.theme-dark .progress-bar-container {
  background: linear-gradient(145deg, #3A3A3C, #2A2A2C);
  box-shadow:
    inset 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3),
    inset -1rpx -1rpx 2rpx rgba(255, 255, 255, 0.05);
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF9800, #FFB74D, #FFA726);
  border-radius: 8rpx;
  transition: width 0.6s cubic-bezier(0.4, 0.0, 0.2, 1);
  position: relative;
  overflow: hidden;
  box-shadow:
    0 0 10rpx rgba(255, 152, 0, 0.5),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
}

/* 进度条动画效果 */
.progress-bar-fill::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.4),
    transparent
  );
  animation: shimmer 2.5s infinite;
}

@keyframes shimmer {
  0% {
    left: -100%;
  }
  100% {
    left: 100%;
  }
}

/* 进度条光晕效果 */
.progress-bar-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(
    ellipse at center,
    rgba(255, 255, 255, 0.3) 0%,
    transparent 70%
  );
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 0.3;
  }
  50% {
    opacity: 0.6;
  }
}

/* 倒计时状态闪动效果 */
@keyframes countdownFlash {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.12);
  }
}

