<!--pages/index/index.wxml-->
<view class="container {{themeClass}} {{isFunTheme ? 'style-girl' : ''}} color-tone-{{colorTone}}" style="background: {{themeStyle === 'simple-dark' ? '#1C1C1E' : '#FFF8E1'}};">
  <!-- 自定义导航栏 -->
  <custom-navbar title="首页" showBack="{{false}}" />

  <!-- 顶部操作栏 -->
  <view class="top-action-bar" wx:if="{{!isLoading}}">
    <!-- 左侧：登录/用户信息 -->
    <view class="left-section">
      <!-- 未登录：显示登录按钮 -->
      <view wx:if="{{!userInfo}}" class="login-button-container">
        <view class="login-button" bindtap="showLoginModal">
          <text class="login-text">登录</text>
        </view>
      </view>

      <!-- 已登录：显示用户信息和退出按钮 -->
      <view wx:else class="user-info-container">
        <view class="user-info">
          <view class="user-avatar">
            <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
            <text wx:else class="avatar-placeholder">{{userInfo.nickName ? userInfo.nickName.substring(0, 1) : '用'}}</text>
          </view>
          <view class="user-details">
            <view class="user-name">{{userInfo.nickName || '用户'}}</view>
          </view>
        </view>
        <view class="logout-button" bindtap="handleLogout">
          <text class="logout-text">退出</text>
        </view>
      </view>
    </view>

    <!-- 右侧：主题切换按钮 -->
    <view class="right-section">
      <view class="theme-bar">
        <view
          class="theme-bar-item {{themeStyle === 'boy' ? 'active' : ''}}"
          data-theme="boy"
          bindtap="quickSwitchTheme">
          <view class="theme-color-boy"></view>
        </view>
        <view
          class="theme-bar-item {{themeStyle === 'girl' ? 'active' : ''}}"
          data-theme="girl"
          bindtap="quickSwitchTheme">
          <view class="theme-color-girl"></view>
        </view>
        <view
          class="theme-bar-item {{themeStyle === 'cute' ? 'active' : ''}}"
          data-theme="cute"
          bindtap="quickSwitchTheme">
          <view class="theme-color-cute"></view>
        </view>
        <view
          class="theme-bar-item {{themeStyle === 'neutral' ? 'active' : ''}}"
          data-theme="neutral"
          bindtap="quickSwitchTheme">
          <view class="theme-color-neutral"></view>
        </view>
        <view
          class="theme-bar-item {{themeStyle === 'simple-light' ? 'active' : ''}}"
          data-theme="simple-light"
          bindtap="quickSwitchTheme">
          <view class="theme-color-simple-light"></view>
        </view>
        <view
          class="theme-bar-item {{themeStyle === 'simple-dark' ? 'active' : ''}}"
          data-theme="simple-dark"
          bindtap="quickSwitchTheme">
          <view class="theme-color-simple-dark"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 全局加载状态 -->
  <view class="global-loading" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">{{i18n.common.loading || '加载中...'}}</text>
  </view>

  <!-- 当前孩子信息 -->
  <view class="child-info" wx:if="{{currentChild && !isLoading}}">
    <!-- 家庭背景图 -->
    <image
      wx:if="{{currentFamily && currentFamily.avatar}}"
      src="{{currentFamily.avatar}}"
      mode="aspectFill"
      class="home-family-bg"
    />

    <!-- 顶部信息行 -->
    <view class="child-header">
      <!-- 左侧：可用金币 -->
      <view class="available-coins">
        <text class="coins-label">可用金币：</text>
        <text class="coins-value">{{currentChild.familyCoins || 0}}</text>
      </view>

      <!-- 右侧：家庭、名字、头像 -->
      <view class="right-section">
        <view class="family-info">
          <view class="family-name" bindtap="showFamilyPickerUI">
            {{currentChild.familyName || '家庭'}}
            <text class="dropdown-arrow">▼</text>
          </view>
          <view class="child-name {{currentFamilyChildren.length > 1 ? 'with-arrow' : ''}}" bindtap="onChildNameTap">
            {{currentChild.name}}
            <text class="dropdown-arrow" wx:if="{{currentFamilyChildren.length > 1}}">▼</text>
          </view>
        </view>
        <view class="child-avatar-small">
          <image wx:if="{{currentChild.avatar}}" src="{{currentChild.avatar}}" mode="aspectFill" />
          <text wx:else>{{currentChild.name.substring(0, 1)}}</text>
        </view>
      </view>
    </view>

    <!-- 金币统计 -->
    <view class="coin-stats-container">
      <!-- 统计范围选择器 -->
      <view class="stats-range-selector">
        <view
          wx:for="{{statsRangeOptions}}"
          wx:key="*this"
          class="range-item {{statsRange === item ? 'active' : ''}}"
          data-range="{{item}}"
          bindtap="onStatsRangeChange">
          <text wx:if="{{item === 'today'}}">当天</text>
          <text wx:elif="{{item === 'month'}}">当月</text>
          <text wx:elif="{{item === 'year'}}">本年</text>
          <text wx:elif="{{item === 'all'}}">全部</text>
        </view>
      </view>

      <!-- 日历选择器 -->
      <view class="calendar-container" wx:if="{{calendarItems.length > 0}}">
        <scroll-view
          class="calendar-scroll"
          scroll-x="{{true}}"
          scroll-into-view="{{selectedCalendarId}}"
          scroll-with-animation>
          <view class="calendar-list">
            <view
              wx:for="{{calendarItems}}"
              wx:key="id"
              id="{{item.id}}"
              class="calendar-item {{item.isSelected ? 'selected' : ''}} {{item.isYearItem ? 'year-item' : ''}}"
              data-item="{{item}}"
              bindtap="onCalendarItemSelect">
              <view class="calendar-main">{{item.main}}</view>
              <view class="calendar-sub" wx:if="{{item.sub}}">{{item.sub}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- 统计数据 -->
      <view class="coin-stats">
        <view class="stat-item">
          <text class="stat-label">兑换次数</text>
          <text class="stat-value">{{coinStats.redeemCount || 0}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">消耗金币</text>
          <text class="stat-value">{{coinStats.spentCoins || 0}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">完成任务</text>
          <text class="stat-value">{{coinStats.earnCount || 0}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">获得金币</text>
          <text class="stat-value">{{coinStats.earnedCoins || 0}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">扣减金币</text>
          <text class="stat-value">{{coinStats.penaltyCoins || 0}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 家庭选择弹窗 -->
  <view class="picker-modal" wx:if="{{showFamilyPicker}}" catchtap="hideFamilyPicker">
    <view class="picker-content" style="top: {{pickerTop}}px;" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择家庭</text>
        <text class="picker-close" bindtap="hideFamilyPicker">✕</text>
      </view>
      <view class="picker-list">
        <view
          class="picker-item"
          wx:for="{{allFamilies}}"
          wx:key="familyId"
          bindtap="selectFamily"
          data-familyid="{{item.familyId}}">
          <view class="picker-item-info" style="display: flex; align-items: center; gap: 12rpx;">
            <view class="picker-item-name">{{item.name}}</view>
            <view class="picker-role-badge {{item.isCreator ? 'creator' : item.role}}" style="padding: 4rpx 12rpx; border-radius: 8rpx; font-size: 20rpx; font-weight: 500;">
              {{item.isCreator ? '创建者' : (item.role === 'admin' ? '管理员' : '成员')}}
            </view>
          </view>
          <view class="picker-item-check" wx:if="{{currentFamilyId === item.familyId}}">✓</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 儿童选择弹窗 -->
  <view class="picker-modal" wx:if="{{showChildPicker}}" catchtap="hideChildPicker">
    <view class="picker-content" style="top: {{childPickerTop}}px;" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择儿童</text>
        <text class="picker-close" bindtap="hideChildPicker">✕</text>
      </view>
      <view class="picker-list">
        <view
          class="picker-item"
          wx:for="{{currentFamilyChildren}}"
          wx:key="childId"
          bindtap="selectChild"
          data-childid="{{item.childId}}">
          <view class="picker-item-name">{{item.name}}</view>
          <view class="picker-item-check" wx:if="{{currentChild.childId === item.childId}}">✓</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 无家庭提示 -->
  <view class="no-child" wx:if="{{needFamily}}">
    <view class="no-child-icon">🏠</view>
    <view class="no-child-text">请点击下方按钮开始创建或加入已有家庭</view>
    <view class="action-buttons">
      <button class="action-btn secondary" bindtap="showJoinFamilyModal">
        <text class="btn-icon">🔗</text>
        <text class="btn-text">加入家庭</text>
      </button>
      <button class="action-btn primary" bindtap="showCreateFamilyModal">
        <text class="btn-icon">➕</text>
        <text class="btn-text">创建家庭</text>
      </button>
    </view>
    <button class="start-wizard-btn" bindtap="startWizard">
      <text class="start-wizard-icon">🎯</text>
      <text class="start-wizard-text">启动向导</text>
    </button>
  </view>

  <!-- 无孩子提示 -->
  <view class="no-child" wx:if="{{!currentChild && !isLoading && !needFamily}}">
    <view class="no-child-icon">👶</view>
    <view class="no-child-text">
      <text wx:if="{{currentFamily}}">{{currentFamily.name}} 暂无孩子，请先添加</text>
      <text wx:else>{{i18n.children.noChildren || '暂无孩子，请先添加'}}</text>
    </view>
    <button class="add-child-btn" bindtap="goToAddChild">{{i18n.children.addChild || '添加孩子'}}</button>
  </view>

  <!-- 今日任务列表 -->
  <view class="tasks-container {{taskListClass}}" wx:if="{{currentChild}}">
    <!-- 标题、分类筛选和飘动开关在同一行 -->
    <view class="section-title-row">
      <view class="section-title">{{i18n.tasks.todayTasks || '今日任务'}}</view>

      <!-- 任务分类筛选 -->
      <view class="task-filter-bar-inline">
        <view
          wx:for="{{availableFilters}}"
          wx:key="*this"
          wx:if="{{item !== 'penalty'}}"
          class="filter-item {{currentFilter === item ? 'active' : ''}}"
          data-filter="{{item}}"
          bindtap="onFilterChange">
          <text wx:if="{{item === 'all'}}">全部</text>
          <text wx:elif="{{item === 'normal'}}">常规</text>
          <text wx:elif="{{item === 'activity'}}">活动</text>
          <text wx:elif="{{item === 'daily'}}">每日</text>
          <text wx:elif="{{item === 'weekly'}}">每周</text>
          <text wx:elif="{{item === 'monthly'}}">每月</text>
        </view>
        <view
          class="filter-item penalty-filter {{currentFilter === 'penalty' ? 'active' : ''}}"
          data-filter="penalty"
          bindtap="onFilterChange">
          惩罚
        </view>
      </view>

      <!-- 童趣模式飘动效果开关 -->
      <view
        wx:if="{{isFunTheme}}"
        class="custom-switch {{enableFloatAnimation ? 'checked' : ''}}"
        bindtap="onFloatAnimationToggle"
      >
        <view class="switch-icon">🎈</view>
        <view class="switch-thumb"></view>
      </view>
    </view>

    <!-- 任务进度条 -->
    <view class="task-progress-row">
      <view class="progress-bar-container">
        <view class="progress-bar-fill" style="width: {{taskProgress.percentage}}%;"></view>
      </view>
      <view class="progress-text">{{taskProgress.completed}}/{{taskProgress.total}}</view>
    </view>

    <!-- 加载中 -->
    <view class="loading" wx:if="{{isLoading}}">
      <text>{{i18n.common.loading || '加载中...'}}</text>
    </view>

    <!-- 任务列表 -->
    <view class="task-list {{taskListClass}}" wx:if="{{!isLoading}}">
      <!-- 任务项（包括未完成和已完成） -->
      <view
        class="task-item {{item.taskClass}} {{item.categoryClass}} {{item.taskType}} {{animatingTaskId === item.taskId ? 'popping' : ''}} {{spawningTaskId === item.taskId ? 'spawning' : ''}} {{item.completed ? 'no-float' : ''}} {{!enableFloatAnimation ? 'no-float' : ''}}"
        wx:for="{{tasks}}"
        wx:for-item="item"
        wx:key="taskId"
        data-taskid="{{item.taskId}}"
        bindtap="{{item.canComplete !== false ? 'completeTask' : ''}}">
        <!-- 挑战任务装饰元素 -->
        <view class="challenge-decoration" wx:if="{{item.badgeType === 'challenge' || item.badgeType === 'upcoming'}}">
          <text class="decoration-icon">⭐</text>
        </view>

        <view class="task-info-left">
          <view class="task-header-row">
            <!-- 已完成胶囊 -->
            <view class="completed-badge" wx:if="{{item.completed}}">已完成</view>
            <!-- 已过期胶囊 -->
            <view class="completed-badge expired" wx:if="{{item.taskStatus && item.taskStatus.status === 'expired'}}">已过期</view>
            <!-- 任务类型胶囊 -->
            <view class="task-badge-inline {{item.badgeType}}" wx:if="{{item.categoryClass !== 'normal' && item.badgeType !== 'countdown' && item.badgeType !== 'expired' && !(item.taskStatus && item.taskStatus.status === 'expired')}}">{{item.badgeText}}</view>
            <view class="task-title">{{item.title}}</view>
          </view>
          <view class="task-desc" wx:if="{{item.description}}">{{item.description}}</view>
          <!-- 气球内的胶囊状态（过期时不显示，因为已在头部显示"已过期"） -->
          <view class="task-status-top {{item.taskStatus.countdown && item.taskStatus.status !== 'expired' ? 'countdown-flash' : ''}}" wx:if="{{item.categoryClass !== 'normal' && item.taskStatus && item.taskStatus.statusText && !(item.taskStatus && item.taskStatus.status === 'expired')}}">
            {{item.taskStatus.statusText}}
          </view>
        </view>

        <view class="task-info-right">
          <!-- 已完成任务也显示金币 -->
          <view class="task-reward" wx:if="{{item.taskType === 'penalty_child'}}" style="color: #E53935; opacity: 0.5;">
            <text class="coin-icon">🪙</text>
            <text>-{{item.coinReward}}</text>
          </view>
          <view class="task-reward" wx:elif="{{item.taskType === 'penalty_parent'}}" style="color: #4CAF50; opacity: 0.5;">
            <text class="coin-icon">🪙</text>
            <text>+{{item.coinReward}}</text>
          </view>
          <view class="task-reward" wx:else style="opacity: 0.5;">
            <text class="coin-icon">🪙</text>
            <text>+{{item.coinReward}}</text>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{tasks.length === 0}}">
        <text>{{i18n.common.noData || '暂无数据'}}</text>
      </view>
    </view>
  </view>

  <!-- 创建家庭弹窗 -->
  <view class="modal" wx:if="{{showCreateFamilyModal}}">
    <view class="modal-mask" catchtap="closeFamilyModals"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">创建家庭</text>
      </view>
      <view class="modal-body">
        <view class="form-group">
          <view class="form-label">家庭名称</view>
          <input
            class="form-input"
            value="{{familyFormData.familyName}}"
            data-field="familyName"
            bindinput="onFamilyInputChange"
            placeholder="请输入家庭名称"
            focus="{{showCreateFamilyModal}}"
          />
        </view>
        <view class="form-group">
          <view class="form-label">您的身份</view>
          <input
            class="form-input"
            value="{{familyFormData.creatorNickname}}"
            data-field="creatorNickname"
            bindinput="onFamilyInputChange"
            placeholder="例如：妈妈、爸爸、外婆"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="closeFamilyModals">取消</button>
        <button class="modal-btn confirm" bindtap="createFamily">创建</button>
      </view>
    </view>
  </view>

  <!-- 加入家庭弹窗 -->
  <view class="modal" wx:if="{{showJoinFamilyModal}}">
    <view class="modal-mask" catchtap="closeFamilyModals"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">加入家庭</text>
      </view>
      <view class="modal-body">
        <view class="form-group">
          <view class="form-label">邀请码</view>
          <input
            class="form-input"
            value="{{familyFormData.inviteCode}}"
            data-field="inviteCode"
            bindinput="onFamilyInputChange"
            style="text-transform: uppercase;"
            placeholder="请输入6位邀请码"
            maxlength="6"
          />
        </view>
        <view class="form-group">
          <view class="form-label">昵称</view>
          <input
            class="form-input"
            value="{{familyFormData.nickname}}"
            data-field="nickname"
            bindinput="onFamilyInputChange"
            placeholder="请输入您在家庭中的昵称"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="closeFamilyModals">取消</button>
        <button class="modal-btn confirm" bindtap="joinFamily">加入</button>
      </view>
    </view>
  </view>

  <!-- 创建第一个儿童弹窗 -->
  <view class="modal" wx:if="{{showCreateChildModal}}">
    <view class="modal-mask" catchtap="closeCreateChildModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">创建第一个孩子</text>
      </view>
      <view class="modal-body">
        <view class="form-group">
          <view class="form-label">孩子姓名 *</view>
          <input
            class="form-input"
            value="{{childFormData.name}}"
            data-field="name"
            bindinput="onChildInputChange"
            placeholder="请输入孩子姓名"
            focus="{{showCreateChildModal}}"
          />
        </view>
        <view class="form-group">
          <view class="form-label">性别</view>
          <view class="gender-selector">
            <view
              class="gender-option {{childFormData.gender === 'male' ? 'selected' : ''}}"
              data-gender="male"
              bindtap="selectGender">
              <text class="gender-icon">👦</text>
              <text class="gender-text">男孩</text>
            </view>
            <view
              class="gender-option {{childFormData.gender === 'female' ? 'selected' : ''}}"
              data-gender="female"
              bindtap="selectGender">
              <text class="gender-icon">👧</text>
              <text class="gender-text">女孩</text>
            </view>
          </view>
        </view>
        <view class="form-group">
          <view class="form-label">年龄</view>
          <input
            class="form-input"
            type="number"
            value="{{childFormData.age}}"
            data-field="age"
            bindinput="onChildInputChange"
            placeholder="请输入年龄"
          />
        </view>
        <view class="form-group">
          <view class="form-label">初始金币</view>
          <input
            class="form-input"
            type="number"
            value="{{childFormData.initialCoins}}"
            data-field="initialCoins"
            bindinput="onChildInputChange"
            placeholder="请输入初始金币数量"
          />
          <view class="form-hint">孩子在该家庭中的初始金币数量</view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="closeCreateChildModal">取消</button>
        <button class="modal-btn confirm" bindtap="createFirstChild">创建</button>
      </view>
    </view>
  </view>

  <!-- 首次使用流程 - 创建家庭对话框 -->
  <view class="create-family-modal" wx:if="{{showCreateFamilyInput}}">
    <view class="modal-mask" bindtap="onCancelCreateFamily"></view>
    <view class="modal-content" catchtap="doNothing">
      <view class="modal-header">
        <text class="modal-title">{{i18n.firstTimeFlow.createFamily || '创建家庭'}}</text>
        <text class="modal-close" bindtap="onCancelCreateFamily">×</text>
      </view>
      <view class="modal-body">
        <text class="input-label">{{i18n.firstTimeFlow.inputFamilyName || '请输入家庭名称'}}</text>
        <input
          class="family-name-input"
          type="text"
          placeholder="{{i18n.firstTimeFlow.familyNamePlaceholder || '我的家庭'}}"
          value="{{familyNameInput}}"
          bindinput="onFamilyNameInput"
          catchtap="doNothing"
        />
        <text class="input-label" style="margin-top: 20rpx;">{{i18n.firstTimeFlow.inputCreatorNickname || '您的身份'}}</text>
        <input
          class="family-name-input"
          type="text"
          placeholder="{{i18n.firstTimeFlow.creatorNicknamePlaceholder || '例如：妈妈、爸爸、外婆'}}"
          value="{{creatorNicknameInput}}"
          bindinput="onCreatorNicknameInput"
          catchtap="doNothing"
        />
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="onCancelCreateFamily">{{i18n.common.cancel || '取消'}}</button>
        <button class="modal-btn confirm" bindtap="onCreateFamily">{{i18n.family.create || '创建'}}</button>
      </view>
    </view>
  </view>

  <!-- 首次使用流程 - 创建儿童对话框 -->
  <view class="create-child-modal" wx:if="{{showCreateChildInput}}">
    <view class="modal-mask" bindtap="onCancelCreateChild"></view>
    <view class="modal-content" catchtap="doNothing">
      <view class="modal-header">
        <text class="modal-title">{{i18n.firstTimeFlow.createChild || '创建儿童'}}</text>
        <text class="modal-close" bindtap="onCancelCreateChild">×</text>
      </view>
      <view class="modal-body">
        <text class="input-label">{{i18n.firstTimeFlow.inputChildName || '请输入儿童姓名'}}</text>
        <input
          class="child-name-input"
          type="text"
          placeholder="{{i18n.firstTimeFlow.childNamePlaceholder || '宝宝'}}"
          value="{{childNameInput}}"
          bindinput="onChildNameInput"
          catchtap="doNothing"
        />

        <text class="input-label" style="margin-top: 20rpx;">{{i18n.firstTimeFlow.childGender || '性别'}}</text>
        <view class="gender-selector">
          <view
            class="gender-option {{childGenderInput === 'male' ? 'selected' : ''}}"
            bindtap="onSelectMaleGender">
            <text class="gender-icon">👦</text>
            <text class="gender-text">男孩</text>
          </view>
          <view
            class="gender-option {{childGenderInput === 'female' ? 'selected' : ''}}"
            bindtap="onSelectFemaleGender">
            <text class="gender-icon">👧</text>
            <text class="gender-text">女孩</text>
          </view>
        </view>

        <text class="input-label" style="margin-top: 20rpx;">{{i18n.firstTimeFlow.childAge || '年龄'}}</text>
        <input
          class="child-name-input"
          type="number"
          placeholder="{{i18n.firstTimeFlow.childAgePlaceholder || '请输入年龄'}}"
          value="{{childAgeInput}}"
          bindinput="onChildAgeInput"
          catchtap="doNothing"
        />

        <text class="input-label" style="margin-top: 20rpx;">{{i18n.firstTimeFlow.initialCoins || '初始金币'}}</text>
        <input
          class="child-name-input"
          type="number"
          placeholder="{{i18n.firstTimeFlow.initialCoinsPlaceholder || '请输入初始金币数'}}"
          value="{{childCoinsInput}}"
          bindinput="onChildCoinsInput"
          catchtap="doNothing"
        />

        <view class="avatar-section">
          <text class="input-label">{{i18n.firstTimeFlow.avatarOptional || '头像（可选）'}}</text>

          <!-- 当前选中头像预览 -->
          <view class="current-avatar-preview" wx:if="{{childAvatarInput}}">
            <view class="avatar-display-large">
              <image wx:if="{{childAvatarInput.indexOf('http') === 0 || childAvatarInput.indexOf('cloud://') === 0 || childAvatarInput.indexOf('wxfile://') === 0}}" src="{{childAvatarInput}}" mode="aspectFill"></image>
              <text wx:else class="avatar-emoji-large">{{childAvatarInput}}</text>
            </view>
          </view>

          <!-- 预设头像选择 -->
          <view class="form-label-small">选择预设头像</view>
          <view class="preset-avatars-grid">
            <view
              class="preset-avatar-item {{childAvatarInput === item ? 'selected' : ''}}"
              wx:for="{{['👦', '👧', '🧒', '👶', '🧑', '🐱', '🐶', '🐰', '🦊', '🐻']}}"
              wx:key="*this"
              bindtap="onSelectPresetAvatar"
              data-avatar="{{item}}">
              <text class="preset-avatar-text">{{item}}</text>
            </view>
          </view>

          <!-- 上传自定义头像 -->
          <view class="form-label-small">或上传自定义头像</view>
          <button class="upload-avatar-btn" bindtap="onChooseChildAvatar">
            <text class="upload-icon">📷</text>
            <text>从相册选择</text>
          </button>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="onCancelCreateChild">{{i18n.common.cancel || '取消'}}</button>
        <button class="modal-btn confirm" bindtap="onCreateChild">{{i18n.common.confirm || '创建'}}</button>
      </view>
    </view>
  </view>

  <!-- 首次使用流程 - 加入家庭对话框 -->
  <view class="join-family-modal" wx:if="{{showJoinFamilyInput}}">
    <view class="modal-mask" bindtap="onCancelJoinFamily"></view>
    <view class="modal-content" catchtap="doNothing">
      <view class="modal-header">
        <text class="modal-title">{{i18n.firstTimeFlow.joinFamily || '加入家庭'}}</text>
        <text class="modal-close" bindtap="onCancelJoinFamily">×</text>
      </view>
      <view class="modal-body">
        <text class="input-label">{{i18n.firstTimeFlow.inputInviteCode || '请输入6位邀请码'}}</text>
        <input
          class="invite-code-input"
          type="text"
          maxlength="6"
          placeholder="{{i18n.firstTimeFlow.inviteCodePlaceholder || 'XXXXXX'}}"
          value="{{inviteCodeInput}}"
          bindinput="onInviteCodeInput"
          catchtap="doNothing"
        />
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="onCancelJoinFamily">{{i18n.common.cancel || '取消'}}</button>
        <button class="modal-btn confirm" bindtap="onJoinFamily">{{i18n.family.join || '加入'}}</button>
      </view>
    </view>
  </view>
</view>
