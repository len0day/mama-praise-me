<!--pages/tasks/tasks.wxml-->
<view class="container {{themeClass}}">
  <custom-navbar title="{{i18n.tasks.title || '任务管理'}}" showBack="{{true}}" />

  <!-- 家长模式状态栏 -->
  <view class="parent-mode-bar">
    <view class="mode-info">
      <text class="mode-icon">{{isParentMode ? '🔓' : '🔒'}}</text>
      <text class="mode-text">{{isParentMode ? '当前模式：家长模式' : '当前模式：儿童模式'}}</text>
    </view>
    <button class="mode-switch-btn" bindtap="toggleParentMode">
      {{isParentMode ? '退出家长模式' : '进入家长模式'}}
    </button>
  </view>

  <!-- 无家庭提示 -->
  <view class="empty-state" wx:if="{{!currentFamily}}">
    <text class="empty-icon">🏠</text>
    <text class="empty-text">需要先加入或创建一个家庭</text>
    <button class="action-btn" bindtap="goToFamily">去添加家庭</button>
  </view>

  <!-- 无儿童提示 -->
  <view class="empty-state" wx:elif="{{!currentChild}}">
    <text class="empty-icon">👶</text>
    <text class="empty-text">需要先添加儿童</text>
    <button class="action-btn" bindtap="goToAddChild">去添加儿童</button>
  </view>

  <!-- 当前家庭和儿童信息 -->
  <view class="current-info" wx:if="{{currentFamily && currentChild}}">
    <view class="info-item" bindtap="showFamilyPicker">
      <text class="info-label">家庭：</text>
      <view class="info-value-with-arrow">
        <text class="info-value">{{currentFamily.name}}</text>
        <text class="dropdown-arrow">▼</text>
      </view>
    </view>
    <view class="info-item {{currentFamilyChildren.length > 1 ? 'with-arrow' : ''}}" bindtap="currentFamilyChildren.length > 1 ? showChildPicker : ''">
      <text class="info-label">儿童：</text>
      <view class="info-value-with-arrow" wx:if="{{currentFamilyChildren.length > 1}}">
        <text class="info-value">{{currentChild.name}}</text>
        <text class="dropdown-arrow">▼</text>
      </view>
      <text class="info-value" wx:else>{{currentChild.name}}</text>
    </view>
  </view>

  <!-- 家庭选择弹窗 -->
  <view class="picker-modal" wx:if="{{showFamilyPicker}}" catchtap="hideFamilyPicker">
    <view class="picker-content" style="top: {{pickerTop}}px;" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择家庭</text>
        <text class="picker-close" bindtap="hideFamilyPicker">✕</text>
      </view>
      <view class="picker-list">
        <view
          class="picker-item"
          wx:for="{{allFamilies}}"
          wx:key="familyId"
          bindtap="selectFamily"
          data-familyid="{{item.familyId}}">
          <view class="picker-item-info" style="display: flex; align-items: center; gap: 12rpx;">
            <view class="picker-item-name">{{item.name}}</view>
            <view class="picker-role-badge {{item.isCreator ? 'creator' : item.role}}" style="padding: 4rpx 12rpx; border-radius: 8rpx; font-size: 20rpx; font-weight: 500;">
              {{item.isCreator ? '创建者' : (item.role === 'admin' ? '管理员' : '成员')}}
            </view>
          </view>
          <view class="picker-item-check" wx:if="{{currentFamilyId === item.familyId}}">✓</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 儿童选择弹窗 -->
  <view class="picker-modal" wx:if="{{showChildPicker}}" catchtap="hideChildPicker">
    <view class="picker-content" style="top: {{childPickerTop}}px;" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择儿童</text>
        <text class="picker-close" bindtap="hideChildPicker">✕</text>
      </view>
      <view class="picker-list">
        <view
          class="picker-item"
          wx:for="{{currentFamilyChildren}}"
          wx:key="childId"
          bindtap="selectChild"
          data-childid="{{item.childId}}">
          <view class="picker-item-name">{{item.name}}</view>
          <view class="picker-item-check" wx:if="{{currentChild.childId === item.childId}}">✓</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 任务列表 -->
  <view class="tasks-list">
    <view
      class="task-item"
      wx:for="{{tasks}}"
      wx:key="taskId">
      <view class="task-header">
        <view class="task-type-badge">{{item.taskTypeBadge}}</view>
        <view class="task-title">{{item.title}}</view>
        <view class="task-reward" wx:if="{{item.taskType === 'penalty_child'}}" style="color: #E53935;">🪙 -{{item.coinReward}}</view>
        <view class="task-reward" wx:elif="{{item.taskType === 'penalty_parent'}}" style="color: #4CAF50;">🪙 +{{item.coinReward}}</view>
        <view class="task-reward" wx:else>🪙 +{{item.coinReward}}</view>
      </view>
      <view class="task-desc" wx:if="{{item.description}}">{{item.description}}</view>
      <view class="task-meta">
        <text class="meta-item">{{getTaskTypeText(item.taskType)}}</text>
        <text class="meta-item" wx:if="{{item.taskType === 'weekly'}}">
          {{item.weekStart}} ~ {{item.weekEnd}}
        </text>
        <text class="meta-item" wx:if="{{item.taskType === 'monthly'}}">
          {{item.monthStart}} ~ {{item.monthEnd}}
        </text>
      </view>
      <view class="task-actions">
        <button class="action-btn edit" data-taskid="{{item.taskId}}" bindtap="editTask">
          {{i18n.common.edit || '编辑'}}
        </button>
        <button class="action-btn delete" data-taskid="{{item.taskId}}" bindtap="deleteTask">
          {{i18n.common.delete || '删除'}}
        </button>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{tasks.length === 0 && !isLoading}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">{{i18n.common.noData || '暂无任务'}}</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="showAddModal">
    <text class="add-icon">+</text>
    <text class="add-text">{{i18n.tasks.addTask || '添加任务'}}</text>
  </view>

  <!-- 添加/编辑模态框 -->
  <view class="modal" wx:if="{{showAddModal}}">
    <view class="modal-mask" catchtap="closeModal"></view>
    <scroll-view class="modal-content" scroll-y catchtap="stopPropagation">
      <view class="modal-title">
        {{editingTask ? i18n.tasks.editTask : i18n.tasks.addTask}}
      </view>

      <!-- 任务名称 -->
      <view class="form-group">
        <view class="form-label">{{i18n.tasks.taskName || '任务名称'}} *</view>
        <input
          class="form-input"
          value="{{formData.title}}"
          data-field="title"
          bindinput="onInputChange"
          placeholder="请输入任务名称" />
      </view>

      <!-- 任务描述 -->
      <view class="form-group">
        <view class="form-label">{{i18n.tasks.taskDesc || '任务描述'}}</view>
        <textarea
          class="form-textarea"
          value="{{formData.description}}"
          data-field="description"
          bindinput="onInputChange"
          placeholder="请输入任务描述（可选）" />
      </view>

      <!-- 金币奖励（惩罚任务显示为扣除/增加） -->
      <view class="form-group">
        <view class="form-label">
          <text wx:if="{{formData.taskType === 'penalty_child'}}">扣除金币 (输入正数)</text>
          <text wx:elif="{{formData.taskType === 'penalty_parent'}}">增加金币 (输入正数)</text>
          <text wx:else>{{i18n.tasks.coinReward || '金币奖励'}}</text>
        </view>
        <input
          class="form-input"
          type="number"
          value="{{formData.coinReward}}"
          data-field="coinReward"
          bindinput="onInputChange"
          placeholder="请输入金币数量" />
      </view>

      <!-- 任务类型 -->
      <view class="form-group">
        <view class="form-label">{{i18n.tasks.taskType || '任务类型'}}</view>
        <picker mode="selector" range="{{taskTypeOptions}}" value="{{taskTypeIndex}}" bindchange="onTaskTypeChange">
          <view class="form-picker">
            {{taskTypeOptions[taskTypeIndex]}}
          </view>
        </picker>
      </view>

      <!-- 惩罚任务提示 -->
      <view class="form-group" wx:if="{{formData.taskType === 'penalty_parent' || formData.taskType === 'penalty_child'}}">
        <view class="form-tip" style="font-size: 26rpx; color: #E53935; padding: 16rpx; background: #FFF5F5; border-radius: 8rpx;">
          <text wx:if="{{formData.taskType === 'penalty_parent'}}">💡 惩罚家长：执行后小孩金币增加（奖励小孩）</text>
          <text wx:else>⚠️ 惩罚小孩：执行后小孩金币减少</text>
          <view style="margin-top: 8rpx; font-size: 24rpx; color: #999;">惩罚任务无次数限制，可无限执行，且只能由家庭创建者操作</view>
        </view>
      </view>

      <!-- 每日/每周/每月任务：可完成次数 -->
      <view class="form-group" wx:if="{{(formData.taskType === 'daily' || formData.taskType === 'weekly' || formData.taskType === 'monthly')}}">
        <view class="form-label">本期可完成次数（可选）</view>
        <input
          class="form-input"
          type="number"
          value="{{formData.maxCompletions}}"
          data-field="maxCompletions"
          bindinput="onInputChange"
          placeholder="留空表示只能完成1次" />
        <view class="form-tip" style="margin-top: 8rpx; font-size: 24rpx; color: #999;">
          设置后可在这期内多次完成任务
        </view>
      </view>

      <!-- 每周任务：日期范围 -->
      <view class="form-group" wx:if="{{formData.taskType === 'weekly'}}">
        <view class="form-label">{{i18n.tasks.weekStart || '开始周'}}</view>
        <picker mode="date" value="{{formData.weekStart}}" data-field="weekStart" bindchange="onDateChange">
          <view class="form-picker">{{formData.weekStart}}</view>
        </picker>

        <view class="form-label" style="margin-top: 20rpx;">{{i18n.tasks.weekEnd || '结束周'}}</view>
        <picker mode="date" value="{{formData.weekEnd}}" data-field="weekEnd" bindchange="onDateChange">
          <view class="form-picker">{{formData.weekEnd}}</view>
        </picker>
      </view>

      <!-- 每月任务：月份范围 -->
      <view class="form-group" wx:if="{{formData.taskType === 'monthly'}}">
        <view class="form-label">{{i18n.tasks.monthStart || '开始月'}}</view>
        <picker mode="date" fields="month" value="{{formData.monthStart}}" data-field="monthStart" bindchange="onDateChange">
          <view class="form-picker">{{formData.monthStart}}</view>
        </picker>

        <view class="form-label" style="margin-top: 20rpx;">{{i18n.tasks.monthEnd || '结束月'}}</view>
        <picker mode="date" fields="month" value="{{formData.monthEnd}}" data-field="monthEnd" bindchange="onDateChange">
          <view class="form-picker">{{formData.monthEnd}}</view>
        </picker>
      </view>

      <!-- 自定义任务：次数和时间范围 -->
      <view class="form-group" wx:if="{{formData.taskType === 'custom'}}">
        <view class="form-label">最大完成次数（可选）</view>
        <input
          class="form-input"
          type="number"
          value="{{formData.maxCompletions}}"
          data-field="maxCompletions"
          bindinput="onInputChange"
          placeholder="留空表示可无限次完成" />

        <view class="form-label" style="margin-top: 20rpx;">开始日期（可选）</view>
        <picker mode="date" value="{{formData.startDate}}" data-field="startDate" bindchange="onDateChange">
          <view class="form-picker">{{formData.startDate || '未设置'}}</view>
        </picker>

        <view class="form-label" style="margin-top: 20rpx;">结束日期（可选）</view>
        <picker mode="date" value="{{formData.endDate}}" data-field="endDate" bindchange="onDateChange">
          <view class="form-picker">{{formData.endDate || '未设置'}}</view>
        </picker>

        <view class="form-tip" style="margin-top: 16rpx; font-size: 24rpx; color: #999;">
          不设置时间则为无限期任务，不设置次数则可反复完成
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="closeModal">{{i18n.common.cancel || '取消'}}</button>
        <button class="modal-btn confirm" bindtap="saveTask">{{i18n.common.save || '保存'}}</button>
      </view>
    </scroll-view>
  </view>

  <!-- 家长密码弹窗 -->
  <parent-password-modal
    show="{{showPasswordModal}}"
    isFirstTime="{{isFirstTime}}"
    bindsuccess="onPasswordSuccess"
    bindcancel="onPasswordCancel"
    bindclose="onPasswordClose" />
</view>
