/* pages/tasks/tasks.wxss */

/* 重置所有按钮的默认样式 */
button {
  margin: 0;
  padding: 0;
  line-height: inherit;
  background: none;
  border: none;
  font-size: inherit;
  min-width: 0;
  min-height: 0;
}

button::after {
  border: none;
}

.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 160rpx;
}

.theme-dark.container {
  background: #1C1C1E;
}

/* 童趣模式容器 */
.style-girl.container {
  background: #FFF0F5; /* 粉色背景 */
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 160rpx;
  margin-bottom: 40rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 60rpx;
  line-height: 1.6;
}

.theme-dark .empty-text {
  color: #AAAAAA;
}

/* 通用操作按钮 - 小尺寸 */
.action-btn {
  padding: 8rpx 16rpx !important;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx !important;
  font-size: 20rpx !important;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.2);
  line-height: 1.2 !important;
  height: auto !important;
  min-width: 0 !important;
  min-height: 0 !important;
  width: auto !important;
}

.action-btn::after {
  border: none;
}

/* 童趣模式下的操作按钮 */
.style-girl .action-btn {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1) !important;
  box-shadow:
    inset -4rpx -4rpx 12rpx rgba(194, 24, 91, 0.3),
    0 10rpx 25rpx rgba(255, 105, 180, 0.4);
}

/* 任务操作按钮区域 */
.task-actions {
  display: flex;
  flex-direction: row;
  gap: 6rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: flex-end;
}

.task-actions .action-btn {
  padding: 8rpx !important;
  border-radius: 8rpx !important;
  font-size: 24rpx !important;
  min-width: 44rpx !important;
  width: 44rpx !important;
  height: 44rpx !important;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.task-actions .action-btn::after {
  border: none;
}

.task-actions .action-btn.edit {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  color: #1976D2;
  box-shadow: 0 2rpx 6rpx rgba(33, 150, 243, 0.2);
}

.task-actions .action-btn.delete {
  background: linear-gradient(135deg, #FFEBEE, #FFCDD2);
  color: #F44336;
  box-shadow: 0 2rpx 6rpx rgba(244, 67, 54, 0.2);
}

.task-actions .action-btn:active {
  transform: scale(0.95);
}

/* 童趣模式下的操作按钮 */
.style-girl .action-btn {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1) !important;
  box-shadow:
    inset -4rpx -4rpx 12rpx rgba(194, 24, 91, 0.3),
    0 10rpx 25rpx rgba(255, 105, 180, 0.4);
}

/* 当前信息栏 */
.current-info {
  display: flex;
  gap: 24rpx;
  padding: 14rpx 20rpx;
  background: #FFFFFF;
  margin: 16rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.theme-dark .current-info {
  background: #2C2C2E;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
}

.info-item.with-arrow {
  cursor: pointer;
}

.info-label {
  color: #666666;
  font-weight: 500;
  font-size: 24rpx;
}

.theme-dark .info-label {
  color: #AAAAAA;
}

.info-value {
  color: #FF9800;
  font-weight: bold;
  font-size: 26rpx;
}

/* 家长模式状态栏 */
.parent-mode-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 20rpx;
  background: #FFFFFF;
  margin: 16rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.mode-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.theme-dark .parent-mode-bar {
  background: #2C2C2E;
}

/* 童趣模式下的家长模式卡片 */
.style-girl .parent-mode-bar {
  background: rgba(255, 255, 255, 0.75);
  border-radius: 20rpx;
  box-shadow:
    inset -4rpx -4rpx 12rpx rgba(255, 182, 193, 0.25),
    inset 6rpx 6rpx 16rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(255, 182, 193, 0.15);
  backdrop-filter: blur(10px);
  border: 2rpx solid rgba(255, 255, 255, 0.85);
}

/* 男孩主题色调 */
.style-girl.color-tone-boy .parent-mode-bar {
  background: rgba(227, 242, 253, 0.6) !important;
  box-shadow:
    inset -4rpx -4rpx 12rpx rgba(25, 118, 210, 0.2),
    inset 6rpx 6rpx 16rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(66, 165, 245, 0.15) !important;
}

/* 中性主题色调 */
.style-girl.color-tone-neutral .parent-mode-bar {
  background: rgba(245, 245, 245, 0.6) !important;
  box-shadow:
    inset -4rpx -4rpx 12rpx rgba(117, 117, 117, 0.2),
    inset 6rpx 6rpx 16rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(189, 189, 189, 0.15) !important;
}

/* 可爱主题色调 */
.style-girl.color-tone-cute .parent-mode-bar {
  background: rgba(255, 248, 225, 0.6) !important;
  box-shadow:
    inset -4rpx -4rpx 12rpx rgba(255, 167, 38, 0.2),
    inset 6rpx 6rpx 16rpx rgba(255, 255, 255, 0.9),
    0 8rpx 20rpx rgba(255, 167, 38, 0.15) !important;
}

.mode-icon {
  font-size: 32rpx;
}

.mode-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.theme-dark .mode-text {
  color: #FFFFFF;
}

/* 童趣模式下模式文字颜色 */
.style-girl.color-tone-boy .mode-text {
  color: #0D47A1;
}

.style-girl.color-tone-neutral .mode-text {
  color: #37474F;
}

.style-girl.color-tone-cute .mode-text,
.style-girl.color-tone-girl .mode-text {
  color: #880E4F;
}

.mode-switch-btn {
  padding: 12rpx 24rpx !important;
  background: linear-gradient(135deg, #FF9800, #FFB74D) !important;
  color: #FFFFFF !important;
  border: none !important;
  border-radius: 20rpx !important;
  font-size: 24rpx !important;
  font-weight: 500;
  line-height: 1.2 !important;
  height: auto !important;
  width: auto !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  flex-shrink: 0 !important;
  margin: 0 !important;
}

.mode-switch-btn::after {
  border: none !important;
}

.mode-switch-btn:active {
  opacity: 0.8;
}

/* 任务列表 */
.tasks-list {
  padding: 12rpx 12rpx 0 12rpx;
}

.task-item {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 10rpx 14rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 任务内容区域布局 */
.task-content {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 8rpx;
}

.task-left {
  flex: 1;
  min-width: 0;
  padding-top: 2rpx;
}

.task-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  flex-shrink: 0;
  padding-top: 2rpx;
}

.theme-dark .task-item {
  background: #2C2C2E;
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.3);
}

/* 童趣模式下的任务卡片 */
.style-girl .task-item {
  background: rgba(255, 255, 255, 0.7); /* 半透明白色 */
  border-radius: 30rpx; /* 更圆润 */
  padding: 25rpx;
  margin-bottom: 25rpx;
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(255, 182, 193, 0.3),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(255, 182, 193, 0.2);
  backdrop-filter: blur(10px);
  border: 3rpx solid rgba(255, 255, 255, 0.8);
}

.task-header {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
  gap: 8rpx;
  flex-wrap: wrap;
}

.task-type-badge {
  font-size: 22rpx;
  flex-shrink: 0;
}

.task-title {
  flex: 1;
  font-size: 24rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.3;
}

/* 童趣模式下的标题 */
.style-girl .task-title {
  color: #C2185B;
  font-weight: 900;
  font-size: 30rpx;
}

.theme-dark .task-title {
  color: #FFFFFF;
}

.task-reward {
  font-size: 26rpx;
  color: #FF9800;
  font-weight: bold;
  flex-shrink: 0;
}

.task-desc {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 2rpx;
  line-height: 1.3;
}

.theme-dark .task-desc {
  color: #AAAAAA;
}

.task-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 4rpx;
  align-items: center;
}

.meta-item {
  font-size: 20rpx;
  color: #666666;
  background: linear-gradient(135deg, #FFF8F0, #FFF0E6);
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(255, 152, 0, 0.15);
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

/* 每日任务 - 蓝色 */
.meta-item.type-daily {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB) !important;
  color: #1976D2 !important;
  border-color: rgba(33, 150, 243, 0.3) !important;
}

/* 每周任务 - 绿色 */
.meta-item.type-weekly {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9) !important;
  color: #388E3C !important;
  border-color: rgba(76, 175, 80, 0.3) !important;
}

/* 每月任务 - 紫色 */
.meta-item.type-monthly {
  background: linear-gradient(135deg, #F3E5F5, #E1BEE7) !important;
  color: #7B1FA2 !important;
  border-color: rgba(156, 39, 176, 0.3) !important;
}

/* 自定义任务 - 橙色 */
.meta-item.type-custom {
  background: linear-gradient(135deg, #FFF8F0, #FFF0E6) !important;
  color: #F57C00 !important;
  border-color: rgba(255, 152, 0, 0.3) !important;
}

/* 惩罚家长 - 青色 */
.meta-item.type-penalty-parent {
  background: linear-gradient(135deg, #E0F7FA, #B2EBF2) !important;
  color: #0097A7 !important;
  border-color: rgba(0, 151, 167, 0.3) !important;
}

/* 惩罚小孩 - 红色 */
.meta-item.type-penalty-child {
  background: linear-gradient(135deg, #FFEBEE, #FFCDD2) !important;
  color: #D32F2F !important;
  border-color: rgba(244, 67, 54, 0.3) !important;
}

/* 已失效标签 - 灰色 */
.meta-item.expired-badge {
  background: linear-gradient(135deg, #ECEFF1, #CFD8DC) !important;
  color: #78909C !important;
  border-color: rgba(120, 144, 156, 0.3) !important;
}

/* 日期时间标签 - 现在与类型标签在同一行 */
.datetime-item {
  font-size: 18rpx;
  color: #888888;
  background: transparent;
  padding: 0;
  margin: -4rpx 0 -2rpx 0;
  border-radius: 0;
  border: none;
  font-weight: 400;
  letter-spacing: 0.2rpx;
  line-height: 1.2;
}

.theme-dark .meta-item {
  background: linear-gradient(135deg, #2C2C2E, #1C1C1E);
  color: #AAAAAA;
  border-color: rgba(255, 255, 255, 0.1);
}

.theme-dark .datetime-item {
  background: transparent;
  color: #999999;
  border: none;
}

.task-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
}

/* 添加按钮 - 缩小版本 */
.add-btn {
  position: fixed;
  bottom: 180rpx;
  right: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.85), rgba(255, 183, 77, 0.85));
  color: #FFFFFF;
  padding: 14rpx 24rpx;
  border-radius: 35rpx;
  box-shadow:
    inset -4rpx -4rpx 10rpx rgba(255, 255, 255, 0.4),
    inset 4rpx 4rpx 10rpx rgba(0, 0, 0, 0.1),
    0 8rpx 20rpx rgba(255, 152, 0, 0.3),
    0 10rpx 24rpx rgba(255, 152, 0, 0.2);
  backdrop-filter: blur(8px);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  z-index: 100;
}

/* 童趣模式下的添加按钮 */
.style-girl .add-btn {
  background: linear-gradient(135deg, rgba(255, 105, 180, 0.9), rgba(255, 182, 193, 0.9));
  box-shadow:
    inset -6rpx -6rpx 15rpx rgba(255, 255, 255, 0.5),
    inset 6rpx 6rpx 15rpx rgba(194, 24, 91, 0.2),
    0 10rpx 25rpx rgba(255, 105, 180, 0.4),
    0 15rpx 35rpx rgba(255, 182, 193, 0.3);
  border: 3rpx solid rgba(255, 255, 255, 0.6);
  padding: 14rpx 24rpx !important;
  border-radius: 35rpx !important;
}

.add-icon {
  font-size: 32rpx;
  line-height: 1;
}

.add-text {
  font-size: 18rpx;
  margin-top: 6rpx;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1;
}

.modal-content {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 650rpx;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  overflow-y: auto;
  box-sizing: border-box;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.theme-dark .modal-content {
  background: #2C2C2E;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 48rpx;
  color: #1A1A1A;
}

.theme-dark .modal-title {
  color: #FFFFFF;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.theme-dark .form-label {
  color: #FFFFFF;
}

.form-input,
.form-textarea,
.form-picker {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx 20rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.5;
  min-height: 88rpx;
  background: #FAFAFA;
  color: #1A1A1A;
  transition: all 0.2s;
}

/* 确保placeholder可见 */
.form-input::-webkit-input-placeholder,
.form-textarea::-webkit-input-placeholder,
.form-picker::-webkit-input-placeholder {
  color: #999999;
  font-size: 28rpx;
}

.form-input::-moz-placeholder,
.form-textarea::-moz-placeholder,
.form-picker::-moz-placeholder {
  color: #999999;
  font-size: 28rpx;
}

.form-input:-ms-input-placeholder,
.form-textarea:-ms-input-placeholder,
.form-picker:-ms-input-placeholder {
  color: #999999;
  font-size: 28rpx;
}

.form-input:focus,
.form-textarea:focus,
.form-picker:focus {
  border-color: #FF9800;
  background: #FFFFFF;
  color: #1A1A1A;
}

.theme-dark .form-input,
.theme-dark .form-textarea,
.theme-dark .form-picker {
  background: #1C1C1E;
  border-color: #3A3A3C;
  color: #FFFFFF;
}

/* 深色模式placeholder */
.theme-dark .form-input::-webkit-input-placeholder,
.theme-dark .form-textarea::-webkit-input-placeholder,
.theme-dark .form-picker::-webkit-input-placeholder {
  color: #888888;
  font-size: 28rpx;
}

.theme-dark .form-input::-moz-placeholder,
.theme-dark .form-textarea::-moz-placeholder,
.theme-dark .form-picker::-moz-placeholder {
  color: #888888;
  font-size: 28rpx;
}

.theme-dark .form-input:-ms-input-placeholder,
.theme-dark .form-textarea:-ms-input-placeholder,
.theme-dark .form-picker:-ms-input-placeholder {
  color: #888888;
  font-size: 28rpx;
}

.theme-dark .form-input:focus,
.theme-dark .form-textarea:focus,
.theme-dark .form-picker:focus {
  border-color: #FF9800;
  background: #2C2C2E;
  color: #FFFFFF;
}

.form-textarea {
  min-height: 160rpx;
  resize: none;
}

.form-picker {
  min-height: 80rpx;
  display: flex;
  align-items: center;
}

.radio-group {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.radio-item {
  padding: 10rpx 20rpx !important;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx !important;
  font-size: 24rpx !important;
  color: #666666;
  background: #FAFAFA;
  transition: all 0.2s;
  line-height: 1.2 !important;
}

.radio-item.active {
  border-color: #FF9800;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
}

.theme-dark .radio-item {
  border-color: #3A3A3C;
  background: #1C1C1E;
  color: #AAAAAA;
}

.theme-dark .radio-item.active {
  border-color: #FF9800;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.modal-btn {
  flex: 1;
  padding: 16rpx !important;
  border-radius: 12rpx !important;
  font-size: 24rpx !important;
  font-weight: 500;
  border: none;
  transition: all 0.2s;
  line-height: 1.2 !important;
  height: auto !important;
  min-width: 0 !important;
  min-height: 0 !important;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background: #F5F5F5;
  color: #666666;
}

.modal-btn.cancel:active {
  background: #E8E8E8;
}

.theme-dark .modal-btn.cancel {
  background: #3A3A3C;
  color: #AAAAAA;
}

.theme-dark .modal-btn.cancel:active {
  background: #4A4A4C;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}

.modal-btn.confirm:active {
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.3);
  transform: translateY(1rpx);
}

/* 家庭选择器样式 */
.info-value-with-arrow {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dropdown-arrow {
  font-size: 22rpx;
  color: #FF9800;
  transition: transform 0.3s;
}

.picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
}

.picker-content {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  animation: fadeIn 0.3s ease-out;
  overflow: hidden;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.theme-dark .picker-content {
  background: #2C2C2E;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.theme-dark .picker-header {
  border-bottom-color: #3A3A3C;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .picker-title {
  color: #FFFFFF;
}

.picker-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.picker-list {
  flex: 1;
  overflow-y: auto;
  padding: 10rpx 0;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.theme-dark .picker-item {
  border-bottom-color: #3A3A3C;
}

.picker-item:active {
  background: #F5F5F5;
}

.theme-dark .picker-item:active {
  background: #3A3A3C;
}

.picker-item-name {
  font-size: 32rpx;
  color: #333333;
}

.theme-dark .picker-item-name {
  color: #FFFFFF;
}

.picker-role-badge.admin {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.picker-role-badge.creator {
  background: linear-gradient(135deg, #E53935, #EF5350);
  color: #FFFFFF;
}

.picker-role-badge.member {
  background: #EEEEEE;
  color: #666666;
}

.theme-dark .picker-role-badge.member {
  background: #3A3A3C;
  color: #AAAAAA;
}

.picker-item-check {
  font-size: 36rpx;
  color: #FF9800;
  font-weight: bold;
}

/* 童趣模式 (Girl Style) */
.container.style-girl {
  background: #FFF0F5;
}

.style-girl .child-info {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 100rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  padding: 20rpx 40rpx;
  margin: 30rpx 40rpx;
  backdrop-filter: blur(10px);
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    inset 10rpx 10rpx 25rpx rgba(255, 255, 255, 0.9),
    0 15rpx 35rpx rgba(255, 182, 193, 0.2);
}

.style-girl .child-avatar {
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(255, 182, 193, 0.4);
}

.style-girl .child-name {
  color: #C2185B !important;
  font-weight: 900 !important;
  text-shadow: 1rpx 1rpx 0 #FFF, 2rpx 2rpx 10rpx rgba(255, 182, 193, 0.5);
}

.style-girl .section-title {
  color: #C2185B;
  font-weight: 900;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl .task-item {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  padding: 35rpx;
  margin-bottom: 25rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(255, 182, 193, 0.3),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(255, 182, 193, 0.2);
  backdrop-filter: blur(10px);
}

.style-girl .task-title {
  color: #C2185B;
  font-weight: 700;
}

.style-girl .task-desc {
  color: #880E4F;
}

.style-girl .task-meta {
  color: #AD1457;
}

.style-girl .meta-item {
  background: linear-gradient(135deg, #FFF5F7, #FCE4EC);
  color: #C2185B;
  border-color: rgba(240, 98, 146, 0.2);
  font-weight: 700;
  text-shadow: 0.5rpx 0.5rpx 0 #FFF;
}

.style-girl .datetime-item {
  background: transparent;
  color: #AD1457;
  border: none;
  font-weight: 500;
}

.style-girl .add-task-btn {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border-radius: 50rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(194, 24, 91, 0.3),
    0 8rpx 20rpx rgba(255, 20, 147, 0.3);
  font-weight: 900;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl .fab-btn {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(194, 24, 91, 0.3),
    0 8rpx 20rpx rgba(255, 20, 147, 0.3);
}

.style-girl .info-item {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 18rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 0;
  border: 2rpx solid rgba(255, 255, 255, 0.7);
}

.style-girl .info-label {
  color: #C2185B;
  font-weight: 700;
  font-size: 22rpx;
}

.style-girl .info-value {
  color: #880E4F;
  font-weight: 600;
  font-size: 24rpx;
}

.style-girl .modal-content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    0 20rpx 50rpx rgba(255, 182, 193, 0.4);
}

.style-girl .modal-title {
  color: #C2185B;
  font-weight: 900;
}

.style-girl .radio-item {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  padding: 10rpx 20rpx !important;
  border: 2rpx solid rgba(255, 255, 255, 0.7);
}

.style-girl .radio-item.active {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border-color: #FFFFFF;
  color: #FFFFFF;
}

/* 时间选择器行 */
.time-selector-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.form-picker-time,
.form-picker-second {
  flex: 1;
  padding: 20rpx 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  background: #FAFAFA;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.theme-dark .form-picker-time,
.theme-dark .form-picker-second {
  border-color: #3A3A3C;
  background: #1C1C1E;
  color: #FFF;
}

.style-girl .modal-btn.cancel {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 25rpx !important;
  border: 2rpx solid rgba(255, 105, 180, 0.3);
  color: #C2185B;
  font-weight: 700;
  padding: 20rpx !important;
}

/* 男孩色调主题 */
.color-tone-boy .meta-item {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  color: #1976D2;
  border-color: rgba(25, 118, 210, 0.2);
}

.color-tone-boy .datetime-item {
  background: transparent;
  color: #1565C0;
  border: none;
}

/* 中性色调主题 */
.color-tone-neutral .meta-item {
  background: linear-gradient(135deg, #ECEFF1, #CFD8DC);
  color: #546E7A;
  border-color: rgba(84, 110, 122, 0.2);
}

.color-tone-neutral .datetime-item {
  background: transparent;
  color: #607D8B;
  border: none;
}

/* 可爱色调主题 */
.color-tone-cute .meta-item {
  background: linear-gradient(135deg, #FCE4EC, #F8BBD0);
  color: #EC407A;
  border-color: rgba(236, 64, 122, 0.2);
}

.color-tone-cute .datetime-item {
  background: transparent;
  color: #D81B60;
  border: none;
}


/* 任务页面头部 - 分类和搜索 */
.tasks-header {
  padding: 12rpx 20rpx;
  padding-bottom: 8rpx;
}

/* 分类筛选 */
.task-categories {
  display: flex;
  gap: 8rpx;
  margin-bottom: 8rpx;
  overflow-x: auto;
  padding-bottom: 4rpx;
}

.task-categories::-webkit-scrollbar {
  display: none;
}

.category-item {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #666666;
  font-weight: 500;
  transition: all 0.3s;
  border: 1rpx solid transparent;
}

.category-item.active {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border-color: #FF9800;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.25);
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 6rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 20rpx;
  padding: 10rpx 18rpx;
  position: relative;
}

.search-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.search-input {
  flex: 1;
  font-size: 24rpx;
  color: #333333;
  height: 32rpx;
  line-height: 32rpx;
}

.clear-icon {
  font-size: 24rpx;
  color: #999999;
  padding: 6rpx;
  margin-left: 6rpx;
}

/* 深色主题 */
.theme-dark .category-item {
  background: #2C2C2E;
  color: #AAAAAA;
}

.theme-dark .category-item.active {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.theme-dark .search-input-wrapper {
  background: #2C2C2E;
}

.theme-dark .search-input {
  color: #FFFFFF;
}

.theme-dark .clear-icon {
  color: #666666;
}

/* 女孩主题 */
.style-girl .category-item {
  background: rgba(255, 255, 255, 0.6);
  color: #C2185B;
  border: 1rpx solid rgba(240, 98, 146, 0.2);
  border-radius: 18rpx;
  font-weight: 700;
}

.style-girl .category-item.active {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  color: #FFFFFF;
  box-shadow: 0 4rpx 10rpx rgba(255, 105, 180, 0.35);
}

.style-girl .search-input-wrapper {
  background: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(240, 98, 146, 0.15);
}

/* 男孩主题 */
.color-tone-boy .category-item {
  background: #E3F2FD;
  color: #1976D2;
}

.color-tone-boy .category-item.active {
  background: linear-gradient(135deg, #2196F3, #64B5F6);
  box-shadow: 0 2rpx 8rpx rgba(33, 150, 243, 0.25);
}

.color-tone-boy .search-input-wrapper {
  background: #E3F2FD;
}

