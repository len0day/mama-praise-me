/* pages/family-list/family-list.wxss */
.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 40rpx;
}

.theme-dark.container {
  background: #1C1C1E;
}

/* 家庭列表部分 */
.families-section {
  padding: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .section-title {
  color: #FFFFFF;
}

.sub-section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
  margin-bottom: 16rpx;
  padding: 0 10rpx;
}

.theme-dark .sub-section-title {
  color: #999999;
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.add-icon {
  font-size: 28rpx;
  font-weight: bold;
}

.families-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 家庭卡片 */
.family-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.theme-dark .family-card {
  background: #2C2C2E;
}

/* 当前选中的家庭 */
.family-card.current {
  border-color: #FF9800;
  box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.15);
  background: linear-gradient(to bottom, #FFFFFF, #FFF9F0);
}

.theme-dark .family-card.current {
  background: linear-gradient(to bottom, #2C2C2E, #322F2A);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.family-card.current .family-icon {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
}

.family-main {
  display: flex;
  align-items: center;
  padding: 44rpx 36rpx;
}

.family-icon {
  width: 100rpx;
  height: 100rpx;
  font-size: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
  flex-shrink: 0;
  overflow: hidden;
}

.family-img {
  width: 100%;
  height: 100%;
}

.theme-dark .family-icon {
  background: #3A3A3C;
}

.family-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.family-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.family-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333 !important;
  line-height: 1.2;
}

.theme-dark .family-name {
  color: #FFFFFF !important;
}

.family-meta {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.invite-code-text {
  font-size: 24rpx;
  color: #FF9800;
  font-weight: 500;
  margin-top: 4rpx;
}

.family-stats-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.family-stats {
  font-size: 24rpx;
  color: #999999;
}

.family-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.stats-tags {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-left: auto;
}

.stats-row {
  display: flex;
  flex-direction: row;
  gap: 6rpx;
  justify-content: flex-end;
}

.stat-tag {
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
}

.stat-tag.task {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  color: #1976D2;
}

.stat-tag.prize {
  background: linear-gradient(135deg, #F3E5F5, #E1BEE7);
  color: #7B1FA2;
}

.stat-tag.child {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  color: #388E3C;
}

.stat-tag.parent {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  color: #FF9800;
}

.theme-dark .stat-tag.task {
  background: linear-gradient(135deg, #2A3A4A, #3A4A5A);
  color: #64B5F6;
}

.theme-dark .stat-tag.prize {
  background: linear-gradient(135deg, #3A2A4A, #4A3A5A);
  color: #BA68C8;
}

.theme-dark .stat-tag.child {
  background: linear-gradient(135deg, #2A4A3A, #3A5A4A);
  color: #81C784;
}

.theme-dark .stat-tag.parent {
  background: linear-gradient(135deg, #4A3A2A, #5A4A3A);
  color: #FFB74D;
}

.admin-badge {
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  white-space: nowrap;
}

.admin-badge.creator {
  background: #FF3B30 !important;
}

.expand-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F5F5;
}

.theme-dark .expand-btn {
  background: #3A3A3C;
}

.expand-icon {
  font-size: 20rpx;
  color: #666666;
  transition: transform 0.3s;
}

.expand-icon.expanded {
  transform: rotate(180deg);
}

.detail-btn {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F5F5;
  border: 1rpx solid #E0E0E0;
}

.theme-dark .detail-btn {
  background: #3A3A3C;
  border-color: #4A4A4C;
}

.detail-icon {
  font-size: 24rpx;
  color: #666666;
  font-weight: normal;
  line-height: 1;
  transform: rotate(90deg);
}

.theme-dark .detail-icon {
  color: #AAAAAA;
}

.role-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.role-badge.member {
  background: #E5E5E5;
  color: #666666;
}

.theme-dark .role-badge.member {
  background: #3A3A3C;
  color: #AAAAAA;
}

.family-check {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4CAF50, #81C784);
  border-radius: 50%;
}

.check-icon {
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: bold;
}

.check-icon {
  font-size: 40rpx;
  color: #4CAF50;
  font-weight: bold;
}

/* 家庭详情（折叠内容） */
.family-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease-out;
}

.family-detail.expanded {
  max-height: 1000rpx;
  transition: max-height 0.3s ease-in;
}

.admin-section {
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.theme-dark .admin-section {
  border-bottom-color: #2C2C2E;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.detail-icon {
  font-size: 32rpx;
  width: 50rpx;
  text-align: center;
}

.detail-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-title {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.theme-dark .detail-title {
  color: #FFFFFF;
}

.detail-value {
  font-size: 24rpx;
  color: #666666;
}

.theme-dark .detail-value {
  color: #AAAAAA;
}

.detail-arrow {
  font-size: 24rpx;
  color: #999999;
}

.children-section {
  padding: 16rpx 20rpx;
}

.detail-header {
  margin-bottom: 12rpx;
}

/* 无家庭状态 */
.no-family-section {
  padding: 60rpx 40rpx;
  min-height: calc(100vh - 200rpx);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.empty-icon {
  font-size: 150rpx;
  margin-bottom: 40rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.theme-dark .empty-text {
  color: #FFFFFF;
}

.empty-tips {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  line-height: 1.6;
}

.theme-dark .empty-tips {
  color: #AAAAAA;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}

.action-btn.secondary {
  background: #FFFFFF;
  color: #FF9800;
  border: 2rpx solid #FF9800;
}

.theme-dark .action-btn.secondary {
  background: #2C2C2E;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 32rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1;
}

.modal-content {
  position: relative;
  width: 100%;
  max-width: 550rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  z-index: 2;
  overflow: hidden;
}

.theme-dark .modal-content {
  background: #2C2C2E;
}

.modal-header {
  padding: 30rpx;
  text-align: center;
  border-bottom: 2rpx solid #E5E5E5;
}

.theme-dark .modal-header {
  border-bottom-color: #3A3A3C;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .modal-title {
  color: #FFFFFF;
}

.modal-body {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.theme-dark .form-label {
  color: #AAAAAA;
}

.form-input {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 44rpx;
  height: 100rpx;
  background: #FAFAFA;
  color: #1A1A1A;
  transition: border-color 0.3s ease, background-color 0.3s ease, box-shadow 0.3s ease;
}

.form-input:focus {
  border-color: #FF9800;
  background: #FFFFFF;
  box-shadow: 0 0 0 4rpx rgba(255, 152, 0, 0.1);
}

.theme-dark .form-input {
  background: #1C1C1E;
  border-color: #3A3A3C;
  color: #FFFFFF;
}

.theme-dark .form-input:focus {
  background: #2C2C2E;
  border-color: #FF9800;
  box-shadow: 0 0 0 4rpx rgba(255, 152, 0, 0.2);
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #E5E5E5;
}

.theme-dark .modal-footer {
  border-top-color: #3A3A3C;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  font-size: 28rpx;
  border: none;
  background: transparent;
}

.modal-btn.cancel {
  color: #666666;
  border-right: 2rpx solid #E5E5E5;
}

.theme-dark .modal-btn.cancel {
  color: #AAAAAA;
  border-right-color: #3A3A3C;
}

.modal-btn.confirm {
  color: #FF9800;
  font-weight: 500;
}


/* 管理员部分 */
.admin-section {
  padding: 20rpx;
}

.action-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.theme-dark .action-list {
  background: #2C2C2E;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.theme-dark .action-item {
  border-bottom-color: #3A3A3C;
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.action-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.theme-dark .action-text {
  color: #FFFFFF;
}

.action-tips {
  font-size: 24rpx;
  color: #999999;
}

.action-arrow {
  font-size: 32rpx;
  color: #999999;
}

/* 儿童部分 */
.children-section {
  padding: 20rpx;
}

.child-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.theme-dark .child-list {
  background: #2C2C2E;
}

.child-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.theme-dark .child-item {
  border-bottom-color: #3A3A3C;
}

.child-item:last-child {
  border-bottom: none;
}

.child-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.child-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.child-info {
  flex: 1;
}

.child-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.theme-dark .child-name {
  color: #FFFFFF;
}

.child-coins {
  font-size: 24rpx;
  color: #FF9800;
  margin-top: 4rpx;
}

.child-actions {
  display: flex;
}

.child-action-btn {
  padding: 8rpx 16rpx;
  background: #F5F5F5;
  color: #666666;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.theme-dark .child-action-btn {
  background: #3A3A3C;
  color: #AAAAAA;
}

/* 分配儿童弹窗 */
.modal-content.large {
  max-width: 650rpx;
}

.modal-content.small {
  max-width: 450rpx;
}

.modal-body.scrollable {
  max-height: 70vh;
  overflow-y: auto;
}

.assign-children-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.assign-child-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
}

.theme-dark .assign-child-item {
  background: #1C1C1E;
}

.assign-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #FFFFFF;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.empty-children {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  text-align: center;
}

.empty-children .empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-children .empty-text {
  color: #999999;
  font-size: 26rpx;
  margin-bottom: 30rpx;
}

.go-add-child-btn-small {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}

.go-add-child-btn-small:active {
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.3);
  transform: translateY(1rpx);
}

/* 邀请码弹窗 */
.invite-code-display {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.invite-code {
  font-size: 64rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 8rpx;
}

.invite-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.invite-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  border: none;
}

.theme-dark .invite-action-btn {
  background: #1C1C1E;
  color: #FFFFFF;
}

/* 底部操作按钮 */
.bottom-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.action-btn.secondary {
  background: #FFFFFF;
  color: #FF9800;
  border: 2rpx solid #FF9800;
}

.theme-dark .action-btn.secondary {
  background: #2C2C2E;
}

.action-btn .btn-icon {
  font-size: 28rpx;
}

.action-btn .btn-text {
  font-size: 28rpx;
}

/* 分配儿童弹窗 */
.child-display {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.theme-dark .child-display {
  background: #2C2C2E;
}

.child-avatar-small {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.child-name-small {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.theme-dark .child-name-small {
  color: #FFFFFF;
}

.form-hint {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
  line-height: 1.4;
}

.theme-dark .form-hint {
  color: #666666;
}

/* 成员信息部分 */
.member-info-section {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.member-info-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.theme-dark .member-info-card {
  background: #2C2C2E;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
}

.member-avatar-wrapper {
  position: relative;
  flex-shrink: 0;
}

.member-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #F5F5F5;
}

.theme-dark .member-avatar {
  background: #3A3A3C;
}

.member-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-text {
  font-size: 48rpx;
}

.avatar-edit-hint {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.7);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

.member-details {
