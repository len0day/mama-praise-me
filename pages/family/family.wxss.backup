/* pages/family/family.wxss */
/* 临时修复文件 - 完全重写输入框样式 */

.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 40rpx;
}

.theme-dark.container {
  background: #1C1C1E;
}

/* 简化的输入框样式 - 最高优先级 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.theme-dark .form-label {
  color: #AAAAAA;
}

/* 强制重写的输入框样式 */
.input-wrapper {
  width: 100% !important;
  box-sizing: border-box !important;
  border: 2rpx solid #E5E5E5 !important;
  border-radius: 12rpx !important;
  background: #FAFAFA !important;
  padding: 20rpx 20rpx !important;
  min-height: 80rpx !important;
}

.theme-dark .input-wrapper {
  background: #1C1C1E !important;
  border-color: #3A3A3C !important;
}

.form-input {
  width: 100% !important;
  font-size: 28rpx !important;
  color: #1A1A1A !important;
  line-height: 40rpx !important;
  height: 40rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  background: transparent !important;
}

.theme-dark .form-input {
  color: #FFFFFF !important;
}

.input-placeholder {
  color: #999999 !important;
  font-size: 26rpx !important;
}

.theme-dark .input-placeholder {
  color: #888888 !important;
}

/* 模态框基础样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1;
}

.modal-content {
  position: relative;
  width: 100%;
  max-width: 600rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  z-index: 2;
  overflow: hidden;
}

.theme-dark .modal-content {
  background: #2C2C2E;
}

.modal-header {
  padding: 30rpx;
  border-bottom: 2rpx solid #E5E5E5;
}

.theme-dark .modal-header {
  border-bottom-color: #3A3A3C;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .modal-title {
  color: #FFFFFF;
}

.modal-body {
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #E5E5E5;
}

.theme-dark .modal-footer {
  border-top-color: #3A3A3C;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  font-size: 28rpx;
  border: none;
  background: transparent;
}

.modal-btn.cancel {
  color: #666666;
  border-right: 2rpx solid #E5E5E5;
}

.theme-dark .modal-btn.cancel {
  color: #AAAAAA;
  border-right-color: #3A3A3C;
}

.modal-btn.confirm {
  color: #FF9800;
  font-weight: 500;
}

/* 快速身份选择 */
.quick-identity-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.identity-option {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
}

.theme-dark .identity-option {
  background: #1C1C1E;
  color: #AAAAAA;
}
