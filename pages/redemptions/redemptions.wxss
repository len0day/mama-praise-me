/* pages/redemptions/redemptions.wxss - 已兑换奖品仓库 */
.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 40rpx;
}

.theme-dark.container {
  background: #1C1C1E;
}

/* 孩子信息 */
.child-info {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.theme-dark .child-info {
  background: #2C2C2E;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.child-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.child-details {
  flex: 1;
}

.child-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.theme-dark .child-name {
  color: #FFFFFF;
}

.child-stats {
  font-size: 26rpx;
  color: #666666;
}

.theme-dark .child-stats {
  color: #AAAAAA;
}

/* 无孩子提示 */
.no-child-tip {
  text-align: center;
  padding: 40rpx 20rpx;
  color: #999999;
  font-size: 28rpx;
}

/* 奖品容器 */
.prizes-container {
  padding: 20rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}

/* 奖品列表 */
.prizes-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.prize-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.theme-dark .prize-item {
  background: #2C2C2E;
}

.prize-item.used {
  opacity: 0.6;
}

.prize-card {
  display: flex;
  padding: 16rpx 20rpx;
  gap: 16rpx;
  align-items: center;
}

/* 奖品图片 */
.prize-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.theme-dark .prize-image {
  background: #1C1C1E;
}

.prize-image image {
  width: 100%;
  height: 100%;
}

.placeholder-icon {
  font-size: 40rpx;
}

/* 使用状态 */
.use-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
}
.prize-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  padding: 0 8rpx;
}

.prize-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  line-height: 1.4;
  word-wrap: break-word;
  word-break: break-all;
}

.theme-dark .prize-name {
  color: #FFFFFF;
}

.prize-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
  flex-shrink: 0;
}

.coin-cost {
  color: #FF9800;
  font-weight: 500;
}

.redeem-time {
  flex-shrink: 0;
}

/* 使用状态和按钮行 */
.status-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

/* 使用状态 */
.use-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  flex: 1;
}

.use-status.pending {
  color: #FF9800;
}

.use-status.ready {
  color: #4CAF50;
}

.use-status .status-icon {
  font-size: 24rpx;
}

.use-status .status-text {
  font-weight: 500;
}

.use-time {
  font-size: 20rpx;
  color: #999999;
  margin-left: auto;
}

/* 使用按钮（小尺寸） */
.use-btn-mini {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.4;
  margin: 0;
  box-shadow: 0 2rpx 6rpx rgba(255, 152, 0, 0.2);
  white-space: nowrap;
  height: auto;
  min-width: 60rpx;
}

.use-btn-mini:active {
  box-shadow: 0 1rpx 3rpx rgba(255, 152, 0, 0.2);
  transform: scale(0.98);
}

/* 使用按钮（内联样式） */
.use-btn-inline {
  flex-shrink: 0;
  padding: 0;
  background: linear-gradient(180deg, #FFB74D 0%, #FF9800 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 56rpx;
  margin: 0;
  margin-left: auto;
  box-shadow:
    0 3rpx 0 #E65100,
    0 4rpx 8rpx rgba(255, 152, 0, 0.3);
  white-space: nowrap;
  width: 72rpx;
  height: 56rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  top: 0;
  transition: all 0.1s;
  /* 重置微信小程序默认样式 */
  box-sizing: border-box;
}

.use-btn-inline::after {
  border: none;
}

.use-btn-inline:active {
  box-shadow:
    0 2rpx 0 #E65100,
    0 3rpx 6rpx rgba(255, 152, 0, 0.3);
  top: 2rpx;
}

/* 使用按钮（原样式，保留备用） */
.use-btn {
  flex-shrink: 0;
  align-self: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.4;
  margin: 0;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
  white-space: nowrap;
}

.use-btn:active {
  box-shadow: 0 1rpx 4rpx rgba(255, 152, 0, 0.2);
  transform: scale(0.98);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
}
