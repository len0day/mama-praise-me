/* pages/redemptions/redemptions.wxss - 已兑换奖品仓库 */
.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 40rpx;
}

.theme-dark.container {
  background: #1C1C1E;
}

/* 孩子信息 */
.child-info {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.theme-dark .child-info {
  background: #2C2C2E;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.child-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.child-details {
  flex: 1;
}

.child-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.theme-dark .child-name {
  color: #FFFFFF;
}

.child-stats {
  font-size: 26rpx;
  color: #666666;
}

.theme-dark .child-stats {
  color: #AAAAAA;
}

/* 无孩子提示 */
.no-child-tip {
  text-align: center;
  padding: 40rpx 20rpx;
  color: #999999;
  font-size: 28rpx;
}

/* 奖品容器 */
.prizes-container {
  padding: 20rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}

/* 奖品列表 */
.prizes-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.prize-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.theme-dark .prize-item {
  background: #2C2C2E;
}

.prize-item.used {
  opacity: 0.6;
}

.prize-card {
  display: flex;
  padding: 16rpx 20rpx;
  gap: 16rpx;
  align-items: center;
}

/* 奖品图片 */
.prize-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.theme-dark .prize-image {
  background: #1C1C1E;
}

.prize-image image {
  width: 100%;
  height: 100%;
}

.placeholder-icon {
  font-size: 40rpx;
}

/* 使用状态 */
.use-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
}
.prize-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  padding: 0 8rpx;
}

.prize-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  line-height: 1.4;
  word-wrap: break-word;
  word-break: break-all;
}

.theme-dark .prize-name {
  color: #FFFFFF;
}

.prize-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
  flex-shrink: 0;
}

.coin-cost {
  color: #FF9800;
  font-weight: 500;
}

.redeem-time {
  flex-shrink: 0;
}

/* 使用状态和按钮行 */
.status-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

/* 使用状态 */
.use-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  flex: 1;
}

.use-status.pending {
  color: #FF9800;
}

.use-status.ready {
  color: #4CAF50;
}

.use-status .status-icon {
  font-size: 24rpx;
}

.use-status .status-text {
  font-weight: 500;
}

.use-time {
  font-size: 20rpx;
  color: #999999;
  margin-left: auto;
}

/* 使用按钮（小尺寸） */
.use-btn-mini {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.4;
  margin: 0;
  box-shadow: 0 2rpx 6rpx rgba(255, 152, 0, 0.2);
  white-space: nowrap;
  height: auto;
  min-width: 60rpx;
}

.use-btn-mini:active {
  box-shadow: 0 1rpx 3rpx rgba(255, 152, 0, 0.2);
  transform: scale(0.98);
}

/* 使用按钮（内联样式） */
.use-btn-inline {
  flex-shrink: 0;
  padding: 0;
  background: linear-gradient(180deg, #FFB74D 0%, #FF9800 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 56rpx;
  margin: 0;
  margin-left: auto;
  box-shadow:
    0 3rpx 0 #E65100,
    0 4rpx 8rpx rgba(255, 152, 0, 0.3);
  white-space: nowrap;
  width: 72rpx;
  height: 56rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  top: 0;
  transition: all 0.1s;
  /* 重置微信小程序默认样式 */
  box-sizing: border-box;
}

.use-btn-inline::after {
  border: none;
}

.use-btn-inline:active {
  box-shadow:
    0 2rpx 0 #E65100,
    0 3rpx 6rpx rgba(255, 152, 0, 0.3);
  top: 2rpx;
}

/* 使用按钮（原样式，保留备用） */
.use-btn {
  flex-shrink: 0;
  align-self: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.4;
  margin: 0;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
  white-space: nowrap;
}

.use-btn:active {
  box-shadow: 0 1rpx 4rpx rgba(255, 152, 0, 0.2);
  transform: scale(0.98);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
}

/* 剩余数量显示 */
.remaining-quantity {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  background: #FFF3E0;
  border-radius: 12rpx;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.theme-dark .remaining-quantity {
  background: #3A3A3C;
}

.quantity-label {
  color: #666666;
  margin-right: 4rpx;
}

.theme-dark .quantity-label {
  color: #AAAAAA;
}

.quantity-value {
  color: #FF9800;
  font-weight: bold;
  font-size: 26rpx;
}

.quantity-slash {
  color: #999999;
  margin: 0 4rpx;
}

.quantity-total {
  color: #666666;
}

.theme-dark .quantity-total {
  color: #AAAAAA;
}

/* 模态框样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

.theme-dark .modal-content {
  background: #2C2C2E;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.theme-dark .modal-header {
  border-bottom-color: #3A3A3C;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .modal-title {
  color: #FFFFFF;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
  padding: 0 10rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #E5E5E5;
}

.theme-dark .modal-footer {
  border-top-color: #3A3A3C;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.modal-btn.cancel {
  background: #F5F5F5;
  color: #666666;
}

.theme-dark .modal-btn.cancel {
  background: #3A3A3C;
  color: #AAAAAA;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
}

.prize-summary {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.theme-dark .prize-summary {
  background: #1C1C1E;
}

.prize-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.prize-thumb image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.prize-summary-info {
  flex: 1;
}

.prize-summary-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.theme-dark .prize-summary-name {
  color: #FFFFFF;
}

.prize-summary-quantity {
  font-size: 26rpx;
  color: #666666;
}

.theme-dark .prize-summary-quantity {
  color: #AAAAAA;
}

.quantity-selector {
  margin-bottom: 30rpx;
}

.quantity-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.theme-dark .quantity-label {
  color: #FFFFFF;
}

.quantity-controls {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.quantity-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F5F5F5;
  border: none;
  font-size: 48rpx;
  color: #333333;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}

.theme-dark .quantity-btn {
  background: #3A3A3C;
  color: #FFFFFF;
}

.quantity-btn[disabled] {
  opacity: 0.3;
}

.quantity-input {
  flex: 1;
  height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  background: #F5F5F5;
  border-radius: 16rpx;
  border: none;
}

.theme-dark .quantity-input {
  background: #1C1C1E;
  color: #FFFFFF;
}

.quick-quantity {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.quick-label {
  font-size: 26rpx;
  color: #666666;
}

.theme-dark .quick-label {
  color: #AAAAAA;
}

.quick-btn {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #333333;
}

.theme-dark .quick-btn {
  background: #3A3A3C;
  color: #FFFFFF;
}

.use-status.used {
  color: #999999;
}

/* 使用历史按钮 */
.history-btn-inline {
  flex-shrink: 0;
  padding: 0;
  background: linear-gradient(180deg, #4CAF50 0%, #45A049 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 48rpx;
  margin: 0;
  box-shadow:
    0 3rpx 0 #2E7D32,
    0 4rpx 8rpx rgba(76, 175, 80, 0.3);
  white-space: nowrap;
  width: 60rpx;
  height: 48rpx;
  min-width: 60rpx;
  max-width: 60rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  top: 0;
  transition: all 0.1s;
}

.history-btn-inline::after {
  border: none;
}

.history-btn-inline:active {
  box-shadow:
    0 2rpx 0 #2E7D32,
    0 3rpx 6rpx rgba(76, 175, 80, 0.3);
  top: 2rpx;
}

/* 使用历史弹窗 */
.history-modal {
  max-height: 70vh;
}

.history-prize-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.theme-dark .history-prize-info {
  background: #1C1C1E;
}

.history-prize-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.history-prize-image image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.history-prize-details {
  flex: 1;
}

.history-prize-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.theme-dark .history-prize-name {
  color: #FFFFFF;
}

.history-prize-summary {
  font-size: 24rpx;
  color: #666666;
  display: flex;
  gap: 20rpx;
}

.theme-dark .history-prize-summary {
  color: #AAAAAA;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.theme-dark .history-title {
  color: #FFFFFF;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  border-left: 4rpx solid #FF9800;
}

.theme-dark .history-item {
  background: #1C1C1E;
}

.history-item-left {
  flex: 1;
}

.history-quantity {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 6rpx;
}

.theme-dark .history-quantity {
  color: #FFFFFF;
}

.history-time {
  font-size: 22rpx;
  color: #999999;
}

.history-item-right {
  flex-shrink: 0;
}

.history-remaining {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 500;
}

.history-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.history-empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.history-empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 童趣模式 (Girl Style) */
.container.style-girl {
  background: #FFF0F5;
}

.style-girl .child-info {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 100rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  padding: 20rpx 40rpx;
  margin: 30rpx 40rpx;
  backdrop-filter: blur(10px);
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    inset 10rpx 10rpx 25rpx rgba(255, 255, 255, 0.9),
    0 15rpx 35rpx rgba(255, 182, 193, 0.2);
}

.style-girl .child-avatar {
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(255, 182, 193, 0.4);
}

.style-girl .child-name {
  color: #C2185B !important;
  font-weight: 900 !important;
  text-shadow: 1rpx 1rpx 0 #FFF, 2rpx 2rpx 10rpx rgba(255, 182, 193, 0.5);
}

.style-girl .redemption-item {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  padding: 35rpx;
  margin-bottom: 25rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(255, 182, 193, 0.3),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(255, 182, 193, 0.2);
  backdrop-filter: blur(10px);
}

.style-girl .redemption-prize-name {
  color: #C2185B;
  font-weight: 700;
}

.style-girl .redemption-child-name {
  color: #880E4F;
}

.style-girl .redemption-coin-cost {
  color: #FF69B4;
  font-weight: 700;
}

.style-girl .redemption-date {
  color: #AD1457;
}

.style-girl .confirm-btn {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border-radius: 50rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(194, 24, 91, 0.3),
    0 8rpx 20rpx rgba(255, 20, 147, 0.3);
  font-weight: 900;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl .cancel-btn {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50rpx;
  border: 3rpx solid rgba(255, 105, 180, 0.3);
  color: #C2185B;
  font-weight: 700;
}

.style-girl .prize-card {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  padding: 35rpx;
  margin-bottom: 25rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(255, 182, 193, 0.3),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(255, 182, 193, 0.2);
  backdrop-filter: blur(10px);
}

.style-girl .prize-image {
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(255, 182, 193, 0.4);
  border-radius: 20rpx;
}

.style-girl .prize-name {
  color: #C2185B;
  font-weight: 700;
}

.style-girl .prize-desc {
  color: #880E4F;
}

.style-girl .prize-cost {
  color: #FF69B4;
  font-weight: 700;
}

.style-girl .modal-content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    0 20rpx 50rpx rgba(255, 182, 193, 0.4);
}

.style-girl .modal-title {
  color: #C2185B;
  font-weight: 900;
}
