/* pages/settings/settings.wxss */
.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 40rpx;
}

.theme-dark.container {
  background: #1C1C1E;
}

/* 家长模式状态栏 */
.parent-mode-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.theme-dark .parent-mode-bar {
  background: #2C2C2E;
}

.mode-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mode-icon {
  font-size: 32rpx;
}

.mode-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.theme-dark .mode-text {
  color: #FFFFFF;
}

.mode-switch-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border: none;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.mode-switch-btn:active {
  opacity: 0.8;
}

/* 孩子卡片 */
.child-card {
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.theme-dark .child-card {
  background: #2C2C2E;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.child-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.child-info {
  flex: 1;
}

.child-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.theme-dark .child-name {
  color: #FFFFFF;
}

.child-stats {
  display: flex;
  gap: 10rpx;
  font-size: 26rpx;
  color: #666666;
}

.theme-dark .child-stats {
  color: #AAAAAA;
}

.stat-item {
  display: flex;
  align-items: center;
}

.stat-divider {
  margin: 0 5rpx;
}

/* 无孩子提示 */
.no-child-tip {
  text-align: center;
  padding: 40rpx 20rpx;
  color: #999999;
  font-size: 28rpx;
}

/* 设置区域 */
.settings-section {
  padding: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666666;
  margin-bottom: 15rpx;
  padding-left: 10rpx;
}

.theme-dark .section-title {
  color: #AAAAAA;
}

.setting-item {
  background: #FFFFFF;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.theme-dark .setting-item {
  background: #2C2C2E;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.item-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.item-label {
  font-size: 30rpx;
  color: #333333;
}

.theme-dark .item-label {
  color: #FFFFFF;
}

.item-arrow {
  font-size: 40rpx;
  color: #999999;
}

.item-arrow {
  font-size: 32rpx;
  color: #999999;
}

.item-label-group {
  display: flex;
  flex-direction: column;
}

.item-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 主题选择器 */
.theme-selector {
  display: flex;
  gap: 15rpx;
}

.theme-option {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.theme-dark .theme-option {
  background: #1C1C1E;
  color: #AAAAAA;
}

.theme-option.active {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border-color: #FF9800;
}

/* 语言选择器 */
.lang-selector {
  display: flex;
  gap: 15rpx;
}

.lang-option {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.theme-dark .lang-option {
  background: #1C1C1E;
  color: #AAAAAA;
}

.lang-option.active {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border-color: #FF9800;
}

/* 退出登录按钮 */
.logout-btn {
  background: #FFFFFF;
  border-radius: 15rpx;
  padding: 30rpx;
  margin: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.theme-dark .logout-btn {
  background: #2C2C2E;
}

.logout-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.logout-text {
  font-size: 30rpx;
  color: #F44336;
  font-weight: bold;
}

/* 用户信息卡片 */
.login-tip-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  margin: 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid #FF9800;
}

.tip-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF9800;
  margin-bottom: 6rpx;
}

.tip-desc {
  font-size: 24rpx;
  color: #666666;
}

.user-info-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.theme-dark .user-info-card {
  background: #2C2C2E;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 6rpx;
}

.theme-dark .user-name {
  color: #FFFFFF;
}

.user-openid {
  font-size: 24rpx;
  color: #4CAF50;
}

.logout-btn-small {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  color: #F44336;
  border: none;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.theme-dark .logout-btn-small {
  background: #1C1C1E;
}

.logout-item {
  margin-top: 20rpx;
}

/* 修改密码弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9998;
}

.modal-content {
  position: relative;
  width: 80%;
  max-width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 9999;
}

.theme-dark .modal-content {
  background: #2C2C2E;
}

.modal-header {
  padding: 40rpx 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #E5E5E5;
}

.theme-dark .modal-header {
  border-bottom-color: #3A3A3C;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .modal-title {
  color: #FFFFFF;
}

.modal-body {
  padding: 40rpx 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.theme-dark .form-label {
  color: #FFFFFF;
}

.password-input-wrapper {
  position: relative;
}

.form-input {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx 60rpx 28rpx 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  font-size: 30rpx;
  background: #FAFAFA;
  color: #1A1A1A;
  height: 100rpx;
  line-height: 44rpx;
}

.theme-dark .form-input {
  background: #1C1C1E;
  border-color: #3A3A3C;
  color: #FFFFFF;
}

.password-toggle-small {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  cursor: pointer;
  padding: 8rpx;
  line-height: 1;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #E5E5E5;
}

.theme-dark .modal-footer {
  border-top-color: #3A3A3C;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  font-size: 28rpx;
  border: none;
  background: transparent;
}

.modal-btn.cancel {
  color: #666666;
  border-right: 1rpx solid #E5E5E5;
}

.theme-dark .modal-btn.cancel {
  color: #AAAAAA;
  border-right-color: #3A3A3C;
}

.modal-btn.confirm {
  color: #FF9800;
  font-weight: 500;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx;
  color: #999999;
  font-size: 24rpx;
}
