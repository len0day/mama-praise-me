/* pages/settings/settings.wxss */
.container {
  min-height: 100vh;
  background: #FFF8E1;
  padding-bottom: 40rpx;
}

.theme-dark.container {
  background: #1C1C1E !important;
}

page.theme-dark {
  background: #1C1C1E !important;
}



/* 设置区域 */
.settings-section {
  padding: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666666;
  margin-bottom: 15rpx;
  padding-left: 10rpx;
}

.theme-dark .section-title {
  color: #AAAAAA;
}

.setting-item {
  background: #FFFFFF;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.theme-dark .setting-item {
  background: #2C2C2E !important;
}

/* 简约深色主题的容器背景 */
.theme-dark.container {
  background: #1C1C1E !important;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.item-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.item-label {
  font-size: 30rpx;
  color: #333333;
}

.theme-dark .item-label {
  color: #FFFFFF;
}

.item-arrow {
  font-size: 40rpx;
  color: #999999;
}

.item-arrow {
  font-size: 32rpx;
  color: #999999;
}

.item-label-group {
  display: flex;
  flex-direction: column;
}

.item-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 主题选择器 */
.theme-selector {
  display: flex;
  gap: 15rpx;
}

.theme-option {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.theme-dark .theme-option, .theme-dark .style-option {
  background: #3A3A3C;
  color: #AAAAAA;
}

.theme-option.active, .style-option.active {
  background: #FF9800;
  color: #FFFFFF;
  border-color: #FF9800;
}

.theme-dark .theme-option.active, .theme-dark .style-option.active {
  background: #FF9800;
  color: #FFFFFF;
  border-color: #FF9800;
}

/* 风格选择器 */
.style-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  max-width: 290rpx;
  justify-content: flex-end;
}

/* 第一行选项：中性、男孩、女孩、可爱 */
.style-selector .style-option:nth-child(1),
.style-selector .style-option:nth-child(2),
.style-selector .style-option:nth-child(3),
.style-selector .style-option:nth-child(4) {
  width: 60rpx;
}

/* 第二行选项：简约浅色、简约深色 */
.style-selector .style-option:nth-child(5),
.style-selector .style-option:nth-child(6) {
  width: 70rpx;
  margin-top: 8rpx;
}

/* 第二行的两个选项间距更小 */
.style-selector .style-option:nth-child(6) {
  margin-left: -4rpx;
}

.style-option {
  padding: 6rpx 8rpx;
  background: #F5F5F5;
  border-radius: 14rpx;
  font-size: 20rpx;
  color: #666666;
  border: 2rpx solid transparent;
  text-align: center;
  line-height: 1.2;
}

/* 色调选择器 */
.color-tone-selector {
  display: flex;
  gap: 15rpx;
}

.color-tone-option {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

/* 语言选择器 */
.lang-selector {
  display: flex;
  gap: 15rpx;
}

.lang-option {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.theme-dark .lang-option {
  background: #1C1C1E;
  color: #AAAAAA;
}

.lang-option.active {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFFFFF;
  border-color: #FF9800;
}

.theme-dark .color-tone-option {
  background: #1C1C1E;
  color: #AAAAAA;
}

.color-tone-option.active {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1) !important;
  color: #666666 !important;
  font-weight: 600 !important;
  border-color: #FF69B4 !important;
}

.theme-dark .color-tone-option.active {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1) !important;
  color: #AAAAAA !important;
  font-weight: 600 !important;
  border-color: #FF69B4 !important;
}



/* 修改密码弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9998;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  position: relative;
  width: 80%;
  max-width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 9999;
}

.theme-dark .modal-content {
  background: #2C2C2E;
}

.modal-header {
  padding: 40rpx 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #E5E5E5;
}

.theme-dark .modal-header {
  border-bottom-color: #3A3A3C;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .modal-title {
  color: #FFFFFF;
}

.modal-body {
  padding: 40rpx 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.theme-dark .form-label {
  color: #FFFFFF;
}

.password-input-wrapper {
  position: relative;
}

.form-input {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx 60rpx 28rpx 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  font-size: 30rpx;
  background: #FAFAFA;
  color: #1A1A1A;
  height: 100rpx;
  line-height: 44rpx;
}

.theme-dark .form-input {
  background: #1C1C1E;
  border-color: #3A3A3C;
  color: #FFFFFF;
}

.password-toggle-small {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  cursor: pointer;
  padding: 8rpx;
  line-height: 1;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #E5E5E5;
}

.theme-dark .modal-footer {
  border-top-color: #3A3A3C;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  font-size: 28rpx;
  border: none;
  background: transparent;
}

.modal-btn.cancel {
  color: #666666;
  border-right: 1rpx solid #E5E5E5;
}

.theme-dark .modal-btn.cancel {
  color: #AAAAAA;
  border-right-color: #3A3A3C;
}

.modal-btn.confirm {
  color: #FF9800;
  font-weight: 500;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx;
  color: #999999;
  font-size: 24rpx;
}

/* 用户信息卡片 */
/* 统一账号卡片布局 */
.user-info-card {
  padding: 32rpx;
  margin: 10rpx 20rpx 30rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  position: relative;
  background: #FFFFFF;
}

.theme-dark .user-info-card {
  background: #2C2C2E;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

/* 未登录状态：表现得像个主操作按钮 */
.user-info-card.logged-out {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  box-shadow: 0 8rpx 20rpx rgba(255, 152, 0, 0.2);
}

.user-info-card.logged-out .user-avatar-placeholder {
  background: rgba(255, 255, 255, 0.2);
}

.user-info-card.logged-out .user-name {
  color: #FFFFFF;
}

.user-info-card.logged-out .meta-item {
  color: rgba(255, 255, 255, 0.85);
}

.user-info-card.logged-out .item-arrow {
  color: #FFFFFF;
  font-size: 40rpx;
}

/* 已登录状态：质感平滑 */
.user-info-card.logged-in {
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.theme-dark .user-info-card.logged-in {
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.user-avatar-wrapper {
  position: relative;
  flex-shrink: 0;
}

.user-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  background: #F5F5F5;
}

.user-avatar-placeholder {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-text {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: #FF9800;
  color: #FFFFFF;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.theme-dark .avatar-edit-badge {
  border-color: #2C2C2E;
}

.style-girl .avatar-edit-badge {
  border: none !important;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.theme-dark .user-name {
  color: #FFFFFF;
}

.edit-nickname-btn {
  font-size: 30rpx;
  opacity: 0.6;
}

.user-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 26rpx;
  color: #999999;
}

.status-cloud {
  color: #4CAF50;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.status-cloud::before {
  content: "•";
  font-size: 40rpx;
}

.status-local {
  color: #FF9800;
}

.logout-btn-small {
  margin: 0 !important;
  padding: 10rpx 20rpx !important;
  background: #F8F8F8 !important;
  color: #999 !important;
  font-size: 22rpx !important;
  font-weight: normal !important;
  border-radius: 10rpx !important;
  width: auto !important;
  min-height: auto !important;
}

.theme-dark .logout-btn-small {
  background: #1C1C1E !important;
  color: #666 !important;
}

.small-mode-btn {
  margin: 0 !important;
  padding: 12rpx 32rpx !important;
  font-size: 24rpx !important;
  line-height: 1 !important;
  min-height: auto !important;
  width: auto !important;
  border-radius: 30rpx !important;
  font-weight: 500 !important;
}

.small-mode-btn.enter {
  background: linear-gradient(135deg, #FF9800, #FFB74D) !important;
  color: #FFFFFF !important;
  box-shadow: 0 4rpx 10rpx rgba(255, 152, 0, 0.2);
}

.small-mode-btn.exit {
  background: #F5F5F5 !important;
  color: #666666 !important;
}

.theme-dark .small-mode-btn.exit {
  background: #1C1C1E !important;
  color: #AAAAAA !important;
}

/* 童趣模式 (Girl Style) */
.container.style-girl {
  background: #FFF0F5;
}

.style-girl .section-title {
  color: #C2185B;
  font-weight: 900;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl .setting-item {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  padding: 35rpx;
  margin-bottom: 20rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(255, 182, 193, 0.3),
    inset 8rpx 8rpx 20rpx rgba(255, 255, 255, 0.9),
    0 10rpx 25rpx rgba(255, 182, 193, 0.2);
  backdrop-filter: blur(10px);
}

.style-girl.theme-dark .setting-item {
  background: rgba(58, 42, 58, 0.6);
  border-color: rgba(93, 58, 93, 0.9);
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(194, 24, 91, 0.3),
    inset 8rpx 8rpx 20rpx rgba(93, 58, 93, 0.9),
    0 10rpx 25rpx rgba(255, 20, 147, 0.2);
}

.style-girl .item-icon {
  color: #FF69B4;
}

.style-girl .item-label {
  color: #C2185B;
  font-weight: 700;
}

.style-girl .item-value {
  color: #880E4F;
  font-weight: 600;
}

.style-girl .switch {
  transform: scale(1.1);
}

.style-girl .logout-btn {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border-radius: 50rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  box-shadow:
    inset -5rpx -5rpx 15rpx rgba(194, 24, 91, 0.3),
    0 8rpx 20rpx rgba(255, 20, 147, 0.3);
  font-weight: 900;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl.theme-dark .logout-btn {
  background: linear-gradient(135deg, #C2185B, #880E4F);
  border-color: rgba(255, 105, 180, 0.3);
}

.style-girl .user-info-card {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 100rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  padding: 20rpx 40rpx;
  margin: 30rpx 40rpx;
  backdrop-filter: blur(10px);
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    inset 10rpx 10rpx 25rpx rgba(255, 255, 255, 0.9),
    0 15rpx 35rpx rgba(255, 182, 193, 0.2);
}

.style-girl .user-avatar-wrapper {
  background: transparent !important;
  box-shadow: 0 4rpx 15rpx rgba(255, 182, 193, 0.4);
}

.style-girl .user-avatar-wrapper image.user-avatar {
  border: none !important;
  background: transparent !important;
}

.style-girl .user-avatar {
  border: none !important;
  background: transparent !important;
}

.style-girl .user-avatar-placeholder {
  border: none !important;
  background: transparent !important;
}

.style-girl .user-avatar-placeholder {
  border: none !important;
  background: transparent !important;
}

.style-girl .user-name {
  color: #C2185B !important;
  font-weight: 900 !important;
  text-shadow: 1rpx 1rpx 0 #FFF, 2rpx 2rpx 10rpx rgba(255, 182, 193, 0.5);
}

.style-girl .user-meta {
  color: #880E4F;
}

.style-girl .small-mode-btn.enter {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  font-weight: 900;
  text-shadow: 1rpx 1rpx 0 #FFF;
}

.style-girl .small-mode-btn.exit {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50rpx;
  border: 3rpx solid rgba(255, 105, 180, 0.3);
  color: #C2185B;
  font-weight: 700;
}

.style-girl .modal-content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    inset -5rpx -5rpx 20rpx rgba(255, 182, 193, 0.3),
    0 20rpx 50rpx rgba(255, 182, 193, 0.4);
}

.style-girl .modal-title {
  color: #C2185B;
  font-weight: 900;
}

