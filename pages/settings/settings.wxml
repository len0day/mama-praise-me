<!--pages/settings/settings.wxml-->
<view class="container {{themeClass}}">
  <custom-navbar title="{{i18n.settings.title || '设置'}}" showBack="{{false}}" />

  <!-- 家长模式状态栏 -->
  <view class="parent-mode-bar">
    <view class="mode-info">
      <text class="mode-icon">{{isParentMode ? '🔓' : '🔒'}}</text>
      <text class="mode-text">{{isParentMode ? '当前模式：家长模式' : '当前模式：儿童模式'}}</text>
    </view>
    <button class="mode-switch-btn" bindtap="toggleParentMode">
      {{isParentMode ? '退出家长模式' : '进入家长模式'}}
    </button>
  </view>

  <!-- 当前孩子信息 -->
  <view class="child-card" wx:if="{{currentChild}}">
    <view class="child-avatar">
      <image wx:if="{{currentChild.avatar}}" src="{{currentChild.avatar}}" mode="aspectFill" />
      <text wx:else>{{currentChild.name.substring(0, 1)}}</text>
    </view>
    <view class="child-info">
      <view class="child-name">{{currentChild.name}}</view>
      <view class="child-stats">
        <text class="stat-item">🪙 {{stats.totalCoins || 0}}</text>
        <text class="stat-divider">·</text>
        <text class="stat-item">✅ {{stats.completedTasks || 0}}</text>
        <text class="stat-divider">·</text>
        <text class="stat-item">🎁 {{stats.redeemedPrizes || 0}}</text>
      </view>
    </view>
  </view>

  <!-- 无孩子提示 -->
  <view class="no-child-tip" wx:if="{{!currentChild}}">
    <text>{{i18n.common.noChild || '请先添加孩子以查看统计'}}</text>
  </view>

  <!-- 设置选项 -->
  <view class="settings-section">
    <!-- 数据统计 -->
    <view class="section-title">{{i18n.settings.dataStatistics || '数据统计'}}</view>

    <view class="setting-item" bindtap="goToChildren">
      <view class="item-left">
        <text class="item-icon">👶</text>
        <view class="item-label-group">
          <text class="item-label">{{i18n.settings.childManagement || '孩子管理'}}</text>
          <text class="item-desc" wx:if="{{currentChild}}">当前：{{currentChild.name}}</text>
        </view>
      </view>
      <view class="item-arrow">›</view>
    </view>

    <!-- 系统设置 -->
    <view class="section-title" style="margin-top: 40rpx;">{{i18n.settings.systemSettings || '系统设置'}}</view>

    <!-- 主题切换 -->
    <view class="setting-item">
      <view class="item-left">
        <text class="item-icon">🎨</text>
        <text class="item-label">{{i18n.settings.theme || '主题'}}</text>
      </view>
      <view class="theme-selector">
        <view
          class="theme-option {{settings.theme === 'light' ? 'active' : ''}}"
          data-theme="light"
          bindtap="switchTheme">
          {{i18n.settings.lightTheme || '浅色'}}
        </view>
        <view
          class="theme-option {{settings.theme === 'dark' ? 'active' : ''}}"
          data-theme="dark"
          bindtap="switchTheme">
          {{i18n.settings.darkTheme || '深色'}}
        </view>
        <view
          class="theme-option {{settings.theme === 'system' ? 'active' : ''}}"
          data-theme="system"
          bindtap="switchTheme">
          {{i18n.settings.systemTheme || '跟随系统'}}
        </view>
      </view>
    </view>

    <!-- 语言切换 -->
    <view class="setting-item">
      <view class="item-left">
        <text class="item-icon">🌐</text>
        <text class="item-label">{{i18n.settings.language || '语言'}}</text>
      </view>
      <view class="lang-selector">
        <view
          class="lang-option {{settings.locale === 'zh-CN' ? 'active' : ''}}"
          data-locale="zh-CN"
          bindtap="switchLanguage">
          简
        </view>
        <view
          class="lang-option {{settings.locale === 'zh-TW' ? 'active' : ''}}"
          data-locale="zh-TW"
          bindtap="switchLanguage">
          繁
        </view>
        <view
          class="lang-option {{settings.locale === 'en' ? 'active' : ''}}"
          data-locale="en"
          bindtap="switchLanguage">
          EN
        </view>
      </view>
    </view>

    <!-- 用户信息 -->
    <view class="section-title" style="margin-top: 40rpx;">{{i18n.settings.account || '账号'}}</view>

    <!-- 未登录状态 -->
    <view class="login-tip-card" wx:if="{{!isLoggedIn}}">
      <view class="tip-icon">☁️</view>
      <view class="tip-content">
        <view class="tip-title">未登录状态</view>
        <view class="tip-desc">数据仅保存在本地，无法使用家庭功能</view>
      </view>
    </view>

    <view class="user-info-card" wx:if="{{userInfo}}">
      <view class="user-avatar">
        <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        <text wx:else class="avatar-placeholder">{{userInfo.nickName.substring(0, 1)}}</text>
      </view>
      <view class="user-details">
        <view class="user-name">{{userInfo.nickName}}</view>
        <view class="user-openid">已登录 · 数据已同步到云端</view>
      </view>
      <button class="logout-btn-small" bindtap="logout">退出</button>
    </view>

    <view class="setting-item" bindtap="login" wx:else>
      <view class="item-left">
        <text class="item-icon">🔑</text>
        <view class="item-label-group">
          <text class="item-label">登录账号</text>
          <text class="item-desc">登录后可同步数据并使用家庭功能</text>
        </view>
      </view>
      <view class="item-arrow">›</view>
    </view>

    <!-- 管理功能 -->
    <view class="section-title" style="margin-top: 40rpx;">{{i18n.settings.management || '管理功能'}}</view>

    <!-- 修改家长密码 -->
    <view class="setting-item" bindtap="showChangePasswordModal" wx:if="{{isParentMode}}">
      <view class="item-left">
        <text class="item-icon">🔐</text>
        <text class="item-label">修改家长密码</text>
      </view>
      <view class="item-arrow">›</view>
    </view>

    <view class="setting-item" bindtap="goToFamily">
      <view class="item-left">
        <text class="item-icon">👨‍👩‍👧‍👦</text>
        <text class="item-label">家庭管理</text>
      </view>
      <view class="item-arrow">›</view>
    </view>

    <view class="setting-item" bindtap="goToTasks">
      <view class="item-left">
        <text class="item-icon">📋</text>
        <text class="item-label">{{i18n.settings.taskManagement || '任务管理'}}</text>
      </view>
      <view class="item-arrow">›</view>
    </view>

    <view class="setting-item" bindtap="goToPrizes">
      <view class="item-left">
        <text class="item-icon">🎁</text>
        <text class="item-label">{{i18n.settings.prizeManagement || '奖品管理'}}</text>
      </view>
      <view class="item-arrow">›</view>
    </view>

    <!-- 退出登录按钮（已登录时显示） -->
    <view class="setting-item logout-item" bindtap="logout" wx:if="{{userInfo}}">
      <view class="item-left">
        <text class="item-icon">🚪</text>
        <text class="item-label">{{i18n.settings.logout || '退出登录'}}</text>
      </view>
      <view class="item-arrow">›</view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>妈妈表扬我 v1.0.0</text>
  </view>

  <!-- 家长密码弹窗 -->
  <parent-password-modal
    show="{{showPasswordModal}}"
    isFirstTime="{{isFirstTime}}"
    bindsuccess="onPasswordSuccess"
    bindcancel="onPasswordCancel"
    bindclose="onPasswordClose" />

  <!-- 修改家长密码弹窗 -->
  <view class="modal" wx:if="{{showChangePasswordModal}}">
    <view class="modal-mask" catchtap="closeChangePasswordModal">
      <view class="modal-content" catchtap="stopPropagation">
        <view class="modal-header">
          <text class="modal-title">修改家长密码</text>
        </view>
        <view class="modal-body">
          <view class="form-group">
            <view class="form-label">旧密码</view>
            <view class="password-input-wrapper">
              <input
                class="form-input"
                type="{{showOldPassword ? 'text' : 'password'}}"
                value="{{changePasswordForm.oldPassword}}"
                data-field="oldPassword"
                bindinput="onChangePasswordInput"
                placeholder="请输入旧密码" />
              <view class="password-toggle-small" bindtap="toggleOldPasswordVisibility">
                {{showOldPassword ? '👁️' : '👁️‍🗨️'}}
              </view>
            </view>
          </view>
          <view class="form-group">
            <view class="form-label">新密码</view>
            <view class="password-input-wrapper">
              <input
                class="form-input"
                type="{{showNewPassword ? 'text' : 'password'}}"
                value="{{changePasswordForm.newPassword}}"
                data-field="newPassword"
                bindinput="onChangePasswordInput"
                placeholder="请输入新密码（至少4位）" />
              <view class="password-toggle-small" bindtap="toggleNewPasswordVisibility">
                {{showNewPassword ? '👁️' : '👁️‍🗨️'}}
              </view>
            </view>
          </view>
          <view class="form-group">
            <view class="form-label">确认新密码</view>
            <view class="password-input-wrapper">
              <input
                class="form-input"
                type="{{showConfirmPassword ? 'text' : 'password'}}"
                value="{{changePasswordForm.confirmPassword}}"
                data-field="confirmPassword"
                bindinput="onChangePasswordInput"
                placeholder="请再次输入新密码" />
              <view class="password-toggle-small" bindtap="toggleConfirmPasswordVisibility">
                {{showConfirmPassword ? '👁️' : '👁️‍🗨️'}}
              </view>
            </view>
          </view>
        </view>
        <view class="modal-footer">
          <button class="modal-btn cancel" bindtap="closeChangePasswordModal">取消</button>
          <button class="modal-btn confirm" bindtap="confirmChangePassword">确定</button>
        </view>
      </view>
    </view>
  </view>
</view>
