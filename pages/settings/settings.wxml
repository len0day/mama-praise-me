<!--pages/settings/settings.wxml-->
<view class="container {{themeClass}}">
  <custom-navbar title="{{i18n.settings.title || 'и®ҫзҪ®'}}" showBack="{{false}}" />

  <!-- е®¶й•ҝжЁЎејҸзҠ¶жҖҒж Ҹ -->
  <view class="parent-mode-bar">
    <view class="mode-info">
      <text class="mode-icon">{{isParentMode ? 'рҹ”“' : 'рҹ”’'}}</text>
      <text class="mode-text">{{isParentMode ? 'еҪ“еүҚжЁЎејҸпјҡе®¶й•ҝжЁЎејҸ' : 'еҪ“еүҚжЁЎејҸпјҡе„ҝз«ҘжЁЎејҸ'}}</text>
    </view>
    <button class="mode-switch-btn" bindtap="toggleParentMode">
      {{isParentMode ? 'йҖҖеҮәе®¶й•ҝжЁЎејҸ' : 'иҝӣе…Ҙе®¶й•ҝжЁЎејҸ'}}
    </button>
  </view>

  <!-- еҪ“еүҚеӯ©еӯҗдҝЎжҒҜ -->
  <view class="child-card" wx:if="{{currentChild}}">
    <view class="child-avatar">
      <image wx:if="{{currentChild.avatar}}" src="{{currentChild.avatar}}" mode="aspectFill" />
      <text wx:else>{{currentChild.name.substring(0, 1)}}</text>
    </view>
    <view class="child-info">
      <view class="child-name">{{currentChild.name}}</view>
      <view class="child-stats">
        <text class="stat-item">рҹӘҷ {{stats.totalCoins || 0}}</text>
        <text class="stat-divider">В·</text>
        <text class="stat-item">вң… {{stats.completedTasks || 0}}</text>
        <text class="stat-divider">В·</text>
        <text class="stat-item">рҹҺҒ {{stats.redeemedPrizes || 0}}</text>
      </view>
    </view>
  </view>

  <!-- ж— еӯ©еӯҗжҸҗзӨә -->
  <view class="no-child-tip" wx:if="{{!currentChild}}">
    <text>{{i18n.common.noChild || 'иҜ·е…Ҳж·»еҠ еӯ©еӯҗд»ҘжҹҘзңӢз»ҹи®Ў'}}</text>
  </view>

  <!-- и®ҫзҪ®йҖүйЎ№ -->
  <view class="settings-section">
    <!-- ж•°жҚ®з»ҹи®Ў -->
    <view class="section-title">{{i18n.settings.dataStatistics || 'ж•°жҚ®з»ҹи®Ў'}}</view>

    <view class="setting-item" bindtap="goToChildren">
      <view class="item-left">
        <text class="item-icon">рҹ‘¶</text>
        <view class="item-label-group">
          <text class="item-label">{{i18n.settings.childManagement || 'еӯ©еӯҗз®ЎзҗҶ'}}</text>
          <text class="item-desc" wx:if="{{currentChild}}">еҪ“еүҚпјҡ{{currentChild.name}}</text>
        </view>
      </view>
      <view class="item-arrow">вҖә</view>
    </view>

    <!-- зі»з»ҹи®ҫзҪ® -->
    <view class="section-title" style="margin-top: 40rpx;">{{i18n.settings.systemSettings || 'зі»з»ҹи®ҫзҪ®'}}</view>

    <!-- дё»йўҳеҲҮжҚў -->
    <view class="setting-item">
      <view class="item-left">
        <text class="item-icon">рҹҺЁ</text>
        <text class="item-label">{{i18n.settings.theme || 'дё»йўҳ'}}</text>
      </view>
      <view class="theme-selector">
        <view
          class="theme-option {{settings.theme === 'light' ? 'active' : ''}}"
          data-theme="light"
          bindtap="switchTheme">
          {{i18n.settings.lightTheme || 'жө…иүІ'}}
        </view>
        <view
          class="theme-option {{settings.theme === 'dark' ? 'active' : ''}}"
          data-theme="dark"
          bindtap="switchTheme">
          {{i18n.settings.darkTheme || 'ж·ұиүІ'}}
        </view>
        <view
          class="theme-option {{settings.theme === 'system' ? 'active' : ''}}"
          data-theme="system"
          bindtap="switchTheme">
          {{i18n.settings.systemTheme || 'и·ҹйҡҸзі»з»ҹ'}}
        </view>
      </view>
    </view>

    <!-- иҜӯиЁҖеҲҮжҚў -->
    <view class="setting-item">
      <view class="item-left">
        <text class="item-icon">рҹҢҗ</text>
        <text class="item-label">{{i18n.settings.language || 'иҜӯиЁҖ'}}</text>
      </view>
      <view class="lang-selector">
        <view
          class="lang-option {{settings.locale === 'zh-CN' ? 'active' : ''}}"
          data-locale="zh-CN"
          bindtap="switchLanguage">
          з®Җ
        </view>
        <view
          class="lang-option {{settings.locale === 'zh-TW' ? 'active' : ''}}"
          data-locale="zh-TW"
          bindtap="switchLanguage">
          з№Ғ
        </view>
        <view
          class="lang-option {{settings.locale === 'en' ? 'active' : ''}}"
          data-locale="en"
          bindtap="switchLanguage">
          EN
        </view>
      </view>
    </view>

    <!-- з”ЁжҲ·дҝЎжҒҜ -->
    <view class="section-title" style="margin-top: 40rpx;">{{i18n.settings.account || 'иҙҰеҸ·'}}</view>

    <!-- жңӘзҷ»еҪ•зҠ¶жҖҒ -->
    <view class="login-tip-card" wx:if="{{!isLoggedIn}}">
      <view class="tip-icon">вҳҒпёҸ</view>
      <view class="tip-content">
        <view class="tip-title">жңӘзҷ»еҪ•зҠ¶жҖҒ</view>
        <view class="tip-desc">ж•°жҚ®д»…дҝқеӯҳеңЁжң¬ең°пјҢж— жі•дҪҝз”Ёе®¶еәӯеҠҹиғҪ</view>
      </view>
    </view>

    <view class="user-info-card" wx:if="{{userInfo}}">
      <view class="user-avatar">
        <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        <text wx:else class="avatar-placeholder">{{userInfo.nickName.substring(0, 1)}}</text>
      </view>
      <view class="user-details">
        <view class="user-name">{{userInfo.nickName}}</view>
        <view class="user-openid">е·Ізҷ»еҪ• В· ж•°жҚ®е·ІеҗҢжӯҘеҲ°дә‘з«Ҝ</view>
      </view>
      <button class="logout-btn-small" bindtap="logout">йҖҖеҮә</button>
    </view>

    <view class="setting-item" bindtap="login" wx:else>
      <view class="item-left">
        <text class="item-icon">рҹ”‘</text>
        <view class="item-label-group">
          <text class="item-label">зҷ»еҪ•иҙҰеҸ·</text>
          <text class="item-desc">зҷ»еҪ•еҗҺеҸҜеҗҢжӯҘж•°жҚ®е№¶дҪҝз”Ёе®¶еәӯеҠҹиғҪ</text>
        </view>
      </view>
      <view class="item-arrow">вҖә</view>
    </view>

    <!-- з®ЎзҗҶеҠҹиғҪ -->
    <view class="section-title" style="margin-top: 40rpx;">{{i18n.settings.management || 'з®ЎзҗҶеҠҹиғҪ'}}</view>

    <!-- дҝ®ж”№е®¶й•ҝеҜҶз Ғ -->
    <view class="setting-item" bindtap="showChangePasswordModal" wx:if="{{isParentMode}}">
      <view class="item-left">
        <text class="item-icon">рҹ”җ</text>
        <text class="item-label">дҝ®ж”№е®¶й•ҝеҜҶз Ғ</text>
      </view>
      <view class="item-arrow">вҖә</view>
    </view>

    <view class="setting-item" bindtap="goToFamily">
      <view class="item-left">
        <text class="item-icon">рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§вҖҚрҹ‘Ұ</text>
        <text class="item-label">е®¶еәӯз®ЎзҗҶ</text>
      </view>
      <view class="item-arrow">вҖә</view>
    </view>

    <view class="setting-item" bindtap="goToTasks">
      <view class="item-left">
        <text class="item-icon">рҹ“Ӣ</text>
        <text class="item-label">{{i18n.settings.taskManagement || 'д»»еҠЎз®ЎзҗҶ'}}</text>
      </view>
      <view class="item-arrow">вҖә</view>
    </view>

    <view class="setting-item" bindtap="goToPrizes">
      <view class="item-left">
        <text class="item-icon">рҹҺҒ</text>
        <text class="item-label">{{i18n.settings.prizeManagement || 'еҘ–е“Ғз®ЎзҗҶ'}}</text>
      </view>
      <view class="item-arrow">вҖә</view>
    </view>

    <!-- йҖҖеҮәзҷ»еҪ•жҢүй’®пјҲе·Ізҷ»еҪ•ж—¶жҳҫзӨәпјү -->
    <view class="setting-item logout-item" bindtap="logout" wx:if="{{userInfo}}">
      <view class="item-left">
        <text class="item-icon">рҹҡӘ</text>
        <text class="item-label">{{i18n.settings.logout || 'йҖҖеҮәзҷ»еҪ•'}}</text>
      </view>
      <view class="item-arrow">вҖә</view>
    </view>
  </view>

  <!-- зүҲжң¬дҝЎжҒҜ -->
  <view class="version-info">
    <text>еҰҲеҰҲиЎЁжү¬жҲ‘ v1.0.0</text>
  </view>

  <!-- е®¶й•ҝеҜҶз Ғеј№зӘ— -->
  <parent-password-modal
    show="{{showPasswordModal}}"
    isFirstTime="{{isFirstTime}}"
    bindsuccess="onPasswordSuccess"
    bindcancel="onPasswordCancel"
    bindclose="onPasswordClose" />

  <!-- дҝ®ж”№е®¶й•ҝеҜҶз Ғеј№зӘ— -->
  <view class="modal" wx:if="{{showChangePasswordModal}}">
    <view class="modal-mask" catchtap="closeChangePasswordModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">дҝ®ж”№е®¶й•ҝеҜҶз Ғ</text>
      </view>
      <view class="modal-body">
        <view class="form-group">
          <view class="form-label">ж—§еҜҶз Ғ</view>
          <view class="password-input-wrapper">
            <input
              class="form-input"
              type="{{showOldPassword ? 'text' : 'password'}}"
              value="{{changePasswordForm.oldPassword}}"
              data-field="oldPassword"
              bindinput="onChangePasswordInput"
              placeholder="иҜ·иҫ“е…Ҙж—§еҜҶз Ғ" />
            <view class="password-toggle-small" bindtap="toggleOldPasswordVisibility">
              {{showOldPassword ? 'рҹ‘ҒпёҸ' : 'рҹ‘ҒпёҸвҖҚрҹ—ЁпёҸ'}}
            </view>
          </view>
        </view>
        <view class="form-group">
          <view class="form-label">ж–°еҜҶз Ғ</view>
          <view class="password-input-wrapper">
            <input
              class="form-input"
              type="{{showNewPassword ? 'text' : 'password'}}"
              value="{{changePasswordForm.newPassword}}"
              data-field="newPassword"
              bindinput="onChangePasswordInput"
              placeholder="иҜ·иҫ“е…Ҙж–°еҜҶз ҒпјҲиҮіе°‘4дҪҚпјү" />
            <view class="password-toggle-small" bindtap="toggleNewPasswordVisibility">
              {{showNewPassword ? 'рҹ‘ҒпёҸ' : 'рҹ‘ҒпёҸвҖҚрҹ—ЁпёҸ'}}
            </view>
          </view>
        </view>
        <view class="form-group">
          <view class="form-label">зЎ®и®Өж–°еҜҶз Ғ</view>
          <view class="password-input-wrapper">
            <input
              class="form-input"
              type="{{showConfirmPassword ? 'text' : 'password'}}"
              value="{{changePasswordForm.confirmPassword}}"
              data-field="confirmPassword"
              bindinput="onChangePasswordInput"
              placeholder="иҜ·еҶҚж¬Ўиҫ“е…Ҙж–°еҜҶз Ғ" />
            <view class="password-toggle-small" bindtap="toggleConfirmPasswordVisibility">
              {{showConfirmPassword ? 'рҹ‘ҒпёҸ' : 'рҹ‘ҒпёҸвҖҚрҹ—ЁпёҸ'}}
            </view>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="closeChangePasswordModal">еҸ–ж¶Ҳ</button>
        <button class="modal-btn confirm" bindtap="confirmChangePassword">зЎ®е®ҡ</button>
      </view>
    </view>
  </view>
</view>
